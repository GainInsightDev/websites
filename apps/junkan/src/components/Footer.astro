</footer>

<style>
  .footer {
    background: var(--color-background);
    border-top: 1px solid var(--color-border);
    padding: 80px 48px 32px;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: 64px;
    padding-bottom: 48px;
  }

  /* Brand column */
  .footer-brand-col {
    max-width: 300px;
  }
  .footer-brand {
    margin-bottom: 16px;
  }
  .footer-logo {
    height: 28px;
    width: auto;
  }
  .footer-desc {
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  /* Link columns */
  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-col h4 {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 4px;
    letter-spacing: 0.02em;
  }
  .footer-col a {
    font-size: 13px;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-col a:hover {
    color: var(--color-text);
  }

  /* Bottom bar */
  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }
  .footer-copyright {
    font-size: 12px;
    color: var(--color-text-muted);
  }
  .footer-social {
    display: flex;
    gap: 12px;
  }
  .footer-social-link {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .footer-social-link:hover {
    color: var(--color-text);
    border-color: var(--color-text);
  }

  @media (max-width: 900px) {
    .footer {
      padding: 48px 24px 24px;
    }
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .footer-brand-col {
      max-width: 100%;
    }
    .footer-links {
      grid-template-columns: 1fr 1fr;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
  }
</style>
