---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <!-- Left: Brand -->
    <div class="footer-brand-col">
      <div class="footer-brand">
        <img src="/images/logos/junkan_logo_transparent.png" alt="Junkan" width="100" height="35" class="footer-logo" />
      </div>
      <p class="footer-desc">Every item, expertly sold. AI-powered resale platform for charity shops, professional resellers, and casual sellers.</p>
    </div>

    <!-- Link columns -->
    <div class="footer-links">
      <div class="footer-col">
        <h4>Platform</h4>
        <a href="/#solution">How it works</a>
        <a href="/#capabilities">AI Identification</a>
        <a href="/#manage">Key Features</a>
        <a href="/#integrations">Integrations</a>
      </div>
      <div class="footer-col">
        <h4>Who it's for</h4>
        <a href="/#segments">Charity Retailers</a>
        <a href="/#segments">Professional Resellers</a>
        <a href="/#segments">Casual Sellers</a>
      </div>
      <div class="footer-col">
        <h4>Company</h4>
        <a href="/contact">Contact</a>
        <a href="/how-it-works">How it Works</a>
        <a href="/#demo">Get Started</a>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <p class="footer-copyright">&copy; {currentYear} Junkan Ltd. All rights reserved.</p>
    <div class="footer-social">
