---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found | Junkan" description="The page you're looking for doesn't exist.">
  <section class="section">
    <div class="container">
      <div class="max-w-lg mx-auto text-center py-20">
        <h1 class="text-6xl font-semibold text-text-muted mb-4">404</h1>
        <p class="text-xl text-text-muted mb-8">This page has moved on to its next chapter.</p>
        <a href="/" class="btn btn-primary">Return Home</a>
      </div>
    </div>
  </section>
</Layout>
