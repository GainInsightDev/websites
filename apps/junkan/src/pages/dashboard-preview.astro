---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="preview-banner">
    <span>Dashboard mockup preview — for hero section review only</span>
  </div>
  <div class="preview-container">
    <!-- ═══════ DASHBOARD MOCKUP ═══════ -->
    <div class="app-shell">
      <!-- Sidebar -->
      <aside class="sidebar">
        <div class="sidebar-logo">
          <div class="logo-circle">J</div>
          <div>
            <span class="logo-name">Junkan</span>
            <span class="logo-org">Oxfam Brixton</span>
          </div>
        </div>

        <nav class="sidebar-nav">
          <a href="#" class="nav-item nav-active">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" /></svg>
            Dashboard
          </a>
          <a href="#" class="nav-item nav-cta">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
            Add Item
          </a>
          <a href="#" class="nav-item">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
            Items
          </a>
          <a href="#" class="nav-item nav-badge-item">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
            Messages
            <span class="nav-badge">2</span>
          </a>
          <a href="#" class="nav-item">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
            Totes
          </a>
          <a href="#" class="nav-item">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
            Reports
          </a>
          <a href="#" class="nav-item">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            Settings
          </a>
        </nav>

        <div class="sidebar-user">
          <div class="user-avatar">SM</div>
          <div>
            <span class="user-name">Sarah Mitchell</span>
            <span class="user-role">Volunteer</span>
          </div>
        </div>
      </aside>

      <!-- Main content -->
      <main class="main-content">
        <!-- Top bar -->
        <header class="topbar">
          <div class="topbar-search">
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
            <span>Search items...</span>
          </div>
          <div class="topbar-actions">
            <div class="topbar-icon-btn">
              <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
              <span class="notif-dot">3</span>
            </div>
            <div class="topbar-avatar">SM</div>
          </div>
        </header>

        <!-- Dashboard body -->
        <div class="dash-body">
          <div class="dash-welcome">
            <h1>Good morning, Sarah</h1>
            <p>Here's what's happening with your items today.</p>
          </div>

          <!-- Stats grid -->
          <div class="stats-grid">
            <div class="stat-card">
              <span class="stat-card-label">Items this week</span>
              <span class="stat-card-value">47</span>
              <span class="stat-card-trend trend-up">↑ 12% vs last week</span>
            </div>
            <div class="stat-card">
              <span class="stat-card-label">Total value</span>
              <span class="stat-card-value">£1,247</span>
              <span class="stat-card-trend trend-up">↑ 8% vs last week</span>
            </div>
            <div class="stat-card">
              <span class="stat-card-label">Pending listings</span>
              <span class="stat-card-value">8</span>
              <span class="stat-card-trend trend-muted">Awaiting processing</span>
            </div>
            <div class="stat-card">
              <span class="stat-card-label">Active listings</span>
              <span class="stat-card-value">23</span>
              <span class="stat-card-trend trend-muted">On eBay & Vinted</span>
            </div>
          </div>

          <!-- Activity table -->
          <div class="activity-card">
            <div class="activity-header">
              <div>
                <h2>Recent Activity</h2>
                <p>Items you've processed recently</p>
              </div>
              <div class="activity-actions">
                <button class="outline-btn">
                  <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" /></svg>
                  Filter
                </button>
                <button class="outline-btn">
                  <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                  Export
                </button>
              </div>
            </div>
            <table class="activity-table">
              <thead>
                <tr>
                  <th></th>
                  <th>Title</th>
                  <th>Category</th>
                  <th>Price</th>
                  <th>Status</th>
                  <th>Route</th>
                  <th>Date</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><div class="table-thumb">V</div></td>
                  <td class="td-title">Vintage Leather Jacket</td>
                  <td>Fashion</td>
                  <td class="td-price">£85.00</td>
                  <td><span class="badge badge-matcha">Listed</span></td>
                  <td><span class="badge badge-matcha-outline">E-commerce</span></td>
                  <td class="td-muted">2 hours ago</td>
                </tr>
                <tr>
                  <td><div class="table-thumb">C</div></td>
                  <td class="td-title">Ceramic Vase Set</td>
                  <td>Homeware</td>
                  <td class="td-price">£12.00</td>
                  <td><span class="badge badge-secondary">In Shop</span></td>
                  <td><span class="badge badge-shu-outline">Shop Floor</span></td>
                  <td class="td-muted">3 hours ago</td>
                </tr>
                <tr>
                  <td><div class="table-thumb">D</div></td>
                  <td class="td-title">Designer Handbag</td>
                  <td>Accessories</td>
                  <td class="td-price">£120.00</td>
                  <td><span class="badge badge-ai">Processing</span></td>
                  <td><span class="badge badge-ai-outline">Hybrid</span></td>
                  <td class="td-muted">5 hours ago</td>
                </tr>
                <tr>
                  <td><div class="table-thumb">H</div></td>
                  <td class="td-title">Hardcover Book Collection</td>
                  <td>Books</td>
                  <td class="td-price">£8.00</td>
                  <td><span class="badge badge-secondary">In Shop</span></td>
                  <td><span class="badge badge-shu-outline">Shop Floor</span></td>
                  <td class="td-muted">6 hours ago</td>
                </tr>
                <tr>
                  <td><div class="table-thumb">R</div></td>
                  <td class="td-title">Retro Gaming Console</td>
                  <td>Electronics</td>
                  <td class="td-price">£45.00</td>
                  <td><span class="badge badge-matcha">Listed</span></td>
                  <td><span class="badge badge-ai-outline">Hybrid</span></td>
                  <td class="td-muted">Yesterday</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </main>
    </div>
  </div>
</Layout>

<style>
  .preview-banner {
    background: var(--color-ai);
    color: #fff;
    text-align: center;
    padding: 10px;
    font-size: 13px;
    font-weight: 500;
  }
  .preview-container {
    max-width: 1100px;
    margin: 48px auto;
    padding: 0 24px;
  }

  /* ═══════ APP SHELL ═══════ */
  .app-shell {
    display: flex;
    height: 640px;
    border-radius: 16px;
    border: 1px solid var(--color-border);
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0,0,0,0.10), 0 4px 16px rgba(0,0,0,0.05);
    background: var(--color-background);
    font-family: var(--font-body);
  }

  /* ═══════ SIDEBAR ═══════ */
  .sidebar {
    width: 220px;
    background: #fff;
    border-right: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }
  .sidebar-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 16px;
    border-bottom: 1px solid var(--color-border);
  }
  .logo-circle {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-ai);
    color: #fff;
    font-weight: 700;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .logo-name {
    display: block;
    font-weight: 600;
    font-size: 14px;
    color: var(--color-text);
  }
  .logo-org {
    display: block;
    font-size: 11px;
    color: var(--color-text-muted);
  }

  .sidebar-nav {
    flex: 1;
    padding: 10px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 450;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .nav-item:hover {
    background: #f5f5f5;
    color: var(--color-text);
  }
  .nav-active {
    background: var(--color-ai-muted);
    color: var(--color-text);
    font-weight: 500;
    box-shadow: 0 1px 3px rgba(75, 123, 229, 0.12);
  }
  .nav-cta {
    background: var(--color-ai);
    color: #fff;
    font-weight: 500;
  }
  .nav-cta:hover {
    background: #3d6cd4;
    color: #fff;
  }
  .nav-badge-item {
    position: relative;
  }
  .nav-badge {
    margin-left: auto;
    background: var(--color-shu);
    color: #fff;
    font-size: 10px;
    font-weight: 600;
    padding: 1px 6px;
    border-radius: 10px;
  }

  .sidebar-user {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border-top: 1px solid var(--color-border);
  }
  .user-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-ai);
    color: #fff;
    font-size: 11px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .user-name {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text);
  }
  .user-role {
    display: block;
    font-size: 11px;
    color: var(--color-text-muted);
  }

  /* ═══════ MAIN CONTENT ═══════ */
  .main-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  /* Top bar */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 52px;
    padding: 0 20px;
    background: #fff;
    border-bottom: 1px solid var(--color-border);
    flex-shrink: 0;
  }
  .topbar-search {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 13px;
    color: var(--color-text-muted);
    width: 260px;
  }
  .topbar-actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .topbar-icon-btn {
    position: relative;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    color: var(--color-text-muted);
    cursor: pointer;
  }
  .topbar-icon-btn:hover {
    background: #f5f5f5;
  }
  .notif-dot {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--color-shu);
    color: #fff;
    font-size: 10px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .topbar-avatar {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--color-ai);
    color: #fff;
    font-size: 10px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Dashboard body */
  .dash-body {
    flex: 1;
    overflow-y: auto;
    padding: 24px;
  }
  .dash-welcome h1 {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 4px;
  }
  .dash-welcome p {
    font-size: 13px;
    color: var(--color-text-muted);
    margin-bottom: 20px;
  }

  /* Stats grid */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    margin-bottom: 24px;
  }
  .stat-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .stat-card-label {
    font-size: 12px;
    color: var(--color-text-muted);
    font-weight: 450;
  }
  .stat-card-value {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 26px;
    letter-spacing: -0.03em;
    color: var(--color-text);
  }
  .stat-card-trend {
    font-size: 11px;
    font-weight: 500;
  }
  .trend-up { color: var(--color-matcha); }
  .trend-muted { color: var(--color-text-muted); font-weight: 400; }

  /* Activity card */
  .activity-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
  }
  .activity-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 16px 20px;
  }
  .activity-header h2 {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 2px;
  }
  .activity-header p {
    font-size: 12px;
    color: var(--color-text-muted);
  }
  .activity-actions {
    display: flex;
    gap: 8px;
  }
  .outline-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: #fff;
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text);
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .outline-btn:hover {
    background: #f9f9f9;
  }

  /* Table */
  .activity-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  .activity-table th {
    text-align: left;
    padding: 8px 16px;
    font-size: 11px;
    font-weight: 500;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    border-top: 1px solid var(--color-border-subtle);
    border-bottom: 1px solid var(--color-border-subtle);
    background: #fafaf9;
  }
  .activity-table td {
    padding: 10px 16px;
    border-bottom: 1px solid var(--color-border-subtle);
    color: var(--color-text-secondary);
  }
  .activity-table tr:last-child td {
    border-bottom: none;
  }
  .table-thumb {
    width: 32px;
    height: 32px;
    border-radius: 6px;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text-muted);
  }
  .td-title {
    font-weight: 500;
    color: var(--color-text);
  }
  .td-price {
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--color-text);
  }
  .td-muted {
    color: var(--color-text-muted);
    font-size: 12px;
  }

  /* Badges */
  .badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 500;
    white-space: nowrap;
  }
  .badge-ai {
    background: var(--color-ai-muted);
    color: var(--color-ai);
  }
  .badge-matcha {
    background: var(--color-matcha-muted);
    color: var(--color-matcha);
  }
  .badge-shu {
    background: var(--color-shu-muted);
    color: var(--color-shu);
  }
  .badge-secondary {
    background: #f5f5f5;
    color: var(--color-text-muted);
  }
  .badge-ai-outline {
    background: transparent;
    border: 1px solid rgba(75, 123, 229, 0.3);
    color: var(--color-ai);
  }
  .badge-matcha-outline {
    background: transparent;
    border: 1px solid rgba(61, 166, 106, 0.3);
    color: var(--color-matcha);
  }
  .badge-shu-outline {
    background: transparent;
    border: 1px solid rgba(217, 90, 80, 0.3);
    color: var(--color-shu);
  }
</style>
