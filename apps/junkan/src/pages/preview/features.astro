---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Junkan — Features Showcase (Preview)">
  <section class="preview-hero">
    <div class="preview-container">
      <div class="preview-badge">Preview Mockup</div>
      <h1 class="preview-title">Feature Showcase</h1>
      <p class="preview-subtitle">Every capability, visualised. Each card shows a real app screen from Junkan.</p>
    </div>
  </section>

  <section class="features-section">
    <div class="features-grid">

      <!-- 1. Dashboard -->
      <div class="feature-card reveal">
        <div class="feature-mockup">
          <div class="mini-app">
            <div class="mini-topbar">
              <span class="mini-logo">J</span>
              <span class="mini-title-text">Dashboard</span>
              <div class="mini-topbar-dots"><span></span><span></span><span></span></div>
            </div>
            <div class="mini-body">
              <div class="mini-welcome">Good morning, Sarah</div>
              <div class="mini-stats-row">
                <div class="mini-stat"><span class="mini-stat-val">47</span><span class="mini-stat-label">Items</span></div>
                <div class="mini-stat"><span class="mini-stat-val">£1,247</span><span class="mini-stat-label">Value</span></div>
                <div class="mini-stat"><span class="mini-stat-val">8</span><span class="mini-stat-label">Pending</span></div>
                <div class="mini-stat"><span class="mini-stat-val">23</span><span class="mini-stat-label">Active</span></div>
              </div>
              <div class="mini-table">
                <div class="mini-table-head">Recent Activity</div>
                <div class="mini-table-row"><span class="mini-dot dot-matcha"></span><span>Vintage Jacket</span><span class="mini-price">£85</span></div>
                <div class="mini-table-row"><span class="mini-dot dot-ai"></span><span>Ceramic Vase</span><span class="mini-price">£12</span></div>
                <div class="mini-table-row"><span class="mini-dot dot-shu"></span><span>Designer Bag</span><span class="mini-price">£120</span></div>
              </div>
            </div>
          </div>
        </div>
        <div class="feature-info">
          <div class="feature-tag tag-ai">Core</div>
          <h3>Dashboard</h3>
          <p>Real-time overview of your inventory, sales activity, and key performance metrics at a glance.</p>
        </div>
      </div>

      <!-- 2. Photo Capture -->
      <div class="feature-card reveal">
        <div class="feature-mockup">
          <div class="mini-app mini-dark">
            <div class="mini-topbar mini-topbar-dark">
              <span class="mini-title-text" style="color:#fff;">Photo Capture</span>
              <span style="color:rgba(255,255,255,0.5);font-size:9px;">3 of 6</span>
            </div>
            <div class="mini-viewfinder">
              <div class="vf-grid">
                <div class="vf-line vf-h1"></div>
                <div class="vf-line vf-h2"></div>
                <div class="vf-line vf-v1"></div>
                <div class="vf-line vf-v2"></div>
              </div>
              <div class="vf-label">
                <svg width="12" height="12" fill="none" stroke="rgba(255,255,255,0.7)" viewBox="0 0 24 24" stroke-width="2"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
                <span>Front view</span>
              </div>
            </div>
            <div class="mini-strip">
              <div class="strip-dot strip-good"></div>
              <div class="strip-dot strip-good"></div>
              <div class="strip-dot strip-warn"></div>
              <div class="strip-dot strip-active"></div>
              <div class="strip-dot strip-empty"></div>
              <div class="strip-dot strip-empty"></div>
            </div>
            <div class="mini-capture-bar">
              <div class="capture-circle"><div class="capture-inner"></div></div>
            </div>
          </div>
        </div>
        <div class="feature-info">
          <div class="feature-tag tag-ai">AI-Powered</div>
          <h3>Smart Photo Capture</h3>
          <p>Guided photography with AI quality validation. Blur detection, lighting checks, and auto-crop ensure every photo is marketplace-ready.</p>
        </div>
      </div>

      <!-- 3. AI Identification -->
      <div class="feature-card reveal">
        <div class="feature-mockup">
          <div class="mini-app">
            <div class="mini-topbar">
              <span class="mini-logo">J</span>
              <span class="mini-title-text">AI Identification</span>
            </div>
            <div class="mini-body">
              <div class="mini-success-bar">
                <span class="mini-check">&#10003;</span>
                92% confidence
              </div>
              <div class="mini-id-name">Levi's 501 Original Fit</div>
              <div class="mini-id-tags">
                <span class="mini-tag">Fashion</span>
                <span class="mini-tag">W32 L32</span>
                <span class="mini-tag">Good</span>
              </div>
              <div class="mini-pricing-grid">
                <div class="mini-mp"><span>Shop</span><span class="mini-mp-price">£18</span></div>
                <div class="mini-mp mini-mp-hl"><span>eBay</span><span class="mini-mp-price">£24.99</span></div>
                <div class="mini-mp"><span>Vinted</span><span class="mini-mp-price">£22</span></div>
              </div>
            </div>
          </div>
        </div>
        <div class="feature-info">
          <div class="feature-tag tag-ai">AI-Powered</div>
          <h3>AI Identification &amp; Pricing</h3>
          <p>GPT-4 Vision identifies brand, condition, and attributes. Cross-references live marketplace data for optimal pricing.</p>
        </div>
      </div>

      <!-- 4. Smart Routing -->
      <div class="feature-card reveal">
        <div class="feature-mockup">
          <div class="mini-app">
            <div class="mini-topbar">
              <span class="mini-logo">J</span>
              <span class="mini-title-text">Smart Routing</span>
            </div>
            <div class="mini-body">
              <div class="mini-routes">
                <div class="mini-route">
                  <span class="mini-dot dot-shu"></span>
                  <span>Shop Floor</span>
                  <span class="mini-route-price">£18</span>
                </div>
                <div class="mini-route mini-route-hl">
                  <span class="mini-dot dot-ai"></span>
                  <span>Hybrid</span>
                  <span class="mini-rec-badge">Rec</span>
                  <span class="mini-route-price">£24.99</span>
                </div>
                <div class="mini-route">
                  <span class="mini-dot dot-matcha"></span>
                  <span>E-commerce</span>
                  <span class="mini-route-price">£24.99</span>
                </div>
              </div>
              <div class="mini-route-summary">
                Profit: <strong>£18.74</strong>
              </div>
            </div>
          </div>
        </div>
        <div class="feature-info">
          <div class="feature-tag tag-matcha">Intelligence</div>
          <h3>Smart Routing</h3>
          <p>AI analyses profit margins across channels and recommends the optimal sales route: shop floor, online, or hybrid.</p>
        </div>
      </div>

      <!-- 5. Marketplace Listings -->
      <div class="feature-card reveal">
        <div class="feature-mockup">
          <div class="mini-app">
            <div class="mini-topbar">
              <span class="mini-logo">J</span>
              <span class="mini-title-text">Listings</span>
            </div>
            <div class="mini-body">
              <div class="mini-listing-tabs">
                <span class="mini-ltab mini-ltab-active">eBay</span>
                <span class="mini-ltab">Vinted</span>
              </div>
              <div class="mini-listing-preview">
                <div class="mini-listing-img">
                  <svg width="20" height="20" fill="none" stroke="var(--color-text-muted)" viewBox="0 0 24 24" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                </div>
                <div>
                  <div style="font-size:10px;font-weight:600;">Levi's 501 Jeans</div>
                  <div style="font-size:12px;font-weight:700;color:var(--color-text);">£24.99</div>
                  <div style="font-size:9px;color:var(--color-matcha);">Net: £18.74</div>
                </div>
              </div>
              <div class="mini-publish-bar">
                <span class="mini-check" style="font-size:10px;">&#10003;</span>
                <span style="font-size:10px;">Published to 2 marketplaces</span>
              </div>
            </div>
          </div>
        </div>
        <div class="feature-info">
          <div class="feature-tag tag-matcha">Automation</div>
          <h3>Multi-Channel Listings</h3>
          <p>Auto-generated, optimised listings published simultaneously to eBay, Vinted, and more. AI writes compelling descriptions.</p>
        </div>
      </div>

      <!-- 6. Analytics -->
      <div class="feature-card reveal">
        <div class="feature-mockup">
          <div class="mini-app">
            <div class="mini-topbar">
              <span class="mini-logo">J</span>
              <span class="mini-title-text">Analytics</span>
            </div>
            <div class="mini-body">
              <div class="mini-kpi-row">
                <div class="mini-kpi"><span class="mini-kpi-val">£12.4k</span><span class="mini-kpi-label">Revenue</span><span class="mini-kpi-trend">&#8593;15%</span></div>
                <div class="mini-kpi"><span class="mini-kpi-val">342</span><span class="mini-kpi-label">Items</span><span class="mini-kpi-trend">&#8593;8%</span></div>
              </div>
              <div class="mini-chart">
                <svg viewBox="0 0 200 60" class="mini-chart-svg">
                  <polyline points="0,50 33,48 66,42 100,44 133,32 166,20 200,10" fill="none" stroke="var(--color-ai)" stroke-width="2"/>
                  <polyline points="0,50 33,48 66,42 100,44 133,32 166,20 200,10" fill="url(#chartGrad)" stroke="none"/>
                  <defs>
                    <linearGradient id="chartGrad" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stop-color="var(--color-ai)" stop-opacity="0.15"/>
                      <stop offset="100%" stop-color="var(--color-ai)" stop-opacity="0"/>
                    </linearGradient>
                  </defs>
                </svg>
              </div>
              <div class="mini-channels">
                <div class="mini-ch"><span class="mini-dot dot-shu"></span>Shop £4.8k</div>
                <div class="mini-ch"><span class="mini-dot dot-ai"></span>eBay £5.9k</div>
                <div class="mini-ch"><span class="mini-dot dot-matcha"></span>Vinted £3.2k</div>
              </div>
            </div>
          </div>
        </div>
        <div class="feature-info">
          <div class="feature-tag tag-shu">Insights</div>
          <h3>Analytics &amp; Reporting</h3>
          <p>Revenue trends, channel performance, sell-through rates, and pricing accuracy — all in real-time dashboards.</p>
        </div>
      </div>

      <!-- 7. Listing Queue -->
      <div class="feature-card reveal">
        <div class="feature-mockup">
          <div class="mini-app">
            <div class="mini-topbar">
              <span class="mini-logo">J</span>
              <span class="mini-title-text">Queue</span>
            </div>
            <div class="mini-body">
              <div class="mini-queue-stats">
                <span class="mini-qs"><span class="mini-dot dot-matcha"></span>3 ready</span>
                <span class="mini-qs"><span class="mini-dot dot-ai"></span>2 processing</span>
                <span class="mini-qs"><span class="mini-dot dot-shu"></span>1 review</span>
              </div>
              <div class="mini-queue-list">
                <div class="mini-qi mini-qi-selected"><span class="mini-dot dot-matcha"></span><span>Burberry Scarf</span><span class="mini-price">£95</span></div>
                <div class="mini-qi"><span class="mini-dot dot-ai dot-pulse"></span><span>Le Creuset Pot</span><span class="mini-price">—</span></div>
                <div class="mini-qi"><span class="mini-dot dot-shu"></span><span>Vintage Camera</span><span class="mini-price">£30-80</span></div>
                <div class="mini-qi"><span class="mini-dot dot-matcha"></span><span>Mulberry Bag</span><span class="mini-price">£145</span></div>
              </div>
            </div>
          </div>
        </div>
        <div class="feature-info">
          <div class="feature-tag tag-ai">Workflow</div>
          <h3>Listing Queue</h3>
          <p>Track every item from intake to sale. Batch operations, status filters, and inline actions for efficient processing.</p>
        </div>
      </div>

      <!-- 8. Fulfillment -->
      <div class="feature-card reveal">
        <div class="feature-mockup">
          <div class="mini-app">
            <div class="mini-topbar">
              <span class="mini-logo">J</span>
              <span class="mini-title-text">Fulfillment</span>
            </div>
            <div class="mini-body">
              <div class="mini-order-banner">Order sold on eBay</div>
              <div class="mini-packages">
                <div class="mini-pkg">
                  <span style="font-size:10px;">Small</span>
                  <span style="font-size:9px;color:var(--color-text-muted);">229&times;162mm</span>
                </div>
                <div class="mini-pkg mini-pkg-rec">
                  <span class="mini-rec-badge" style="position:static;">Rec</span>
                  <span style="font-size:10px;">Medium</span>
                  <span style="font-size:9px;color:var(--color-text-muted);">324&times;229mm</span>
                </div>
                <div class="mini-pkg">
                  <span style="font-size:10px;">Large</span>
                  <span style="font-size:9px;color:var(--color-text-muted);">61&times;46cm</span>
                </div>
              </div>
              <div class="mini-carrier">
                <span class="mini-dot dot-matcha"></span>
                <span style="font-size:10px;">Royal Mail Tracked 24</span>
                <span style="font-size:10px;font-weight:600;margin-left:auto;">£3.50</span>
              </div>
            </div>
          </div>
        </div>
        <div class="feature-info">
          <div class="feature-tag tag-matcha">Logistics</div>
          <h3>Fulfillment &amp; Shipping</h3>
          <p>AI-suggested packaging, carrier comparison with pricing, and integrated label printing for fast dispatch.</p>
        </div>
      </div>

      <!-- 9. AI Chat -->
      <div class="feature-card reveal">
        <div class="feature-mockup">
          <div class="mini-app">
            <div class="mini-topbar">
              <span class="mini-logo">J</span>
              <span class="mini-title-text">Messages</span>
              <span class="mini-notif-badge">2</span>
            </div>
            <div class="mini-body">
              <div class="mini-inbox">
                <div class="mini-msg mini-msg-unread">
                  <div class="mini-msg-avatar">J</div>
                  <div class="mini-msg-content">
                    <div class="mini-msg-name">buyer_jane92 <span class="mini-platform-badge">eBay</span></div>
                    <div class="mini-msg-preview">Is this still available?</div>
                  </div>
                  <div class="mini-unread-dot"></div>
                </div>
                <div class="mini-msg">
                  <div class="mini-msg-avatar mini-msg-ai-avatar">AI</div>
                  <div class="mini-msg-content">
                    <div class="mini-msg-name">vintage_lover <span class="mini-platform-badge mini-pb-vinted">Vinted</span></div>
                    <div class="mini-msg-preview">AI handled &middot; Size query</div>
                  </div>
                </div>
                <div class="mini-msg">
                  <div class="mini-msg-avatar mini-msg-ai-avatar">AI</div>
                  <div class="mini-msg-content">
                    <div class="mini-msg-name">fashion_finds <span class="mini-platform-badge">eBay</span></div>
                    <div class="mini-msg-preview">AI handled &middot; Price negotiation</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="feature-info">
          <div class="feature-tag tag-ai">AI-Powered</div>
          <h3>AI Chat &amp; Unified Inbox</h3>
          <p>All marketplace messages in one place. AI handles routine queries automatically — you only see what needs attention.</p>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  .preview-hero {
    padding: 140px 48px 60px;
    text-align: center;
  }
  .preview-container {
    max-width: 640px;
    margin: 0 auto;
  }
  .preview-badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: var(--color-ai-muted);
    color: var(--color-ai);
    margin-bottom: 24px;
  }
  .preview-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.1;
    letter-spacing: -0.04em;
    color: var(--color-text);
    margin-bottom: 16px;
  }
  .preview-subtitle {
    font-size: 18px;
    font-weight: 350;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .features-section {
    padding: 0 48px 120px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .feature-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    overflow: hidden;
    transition: transform 0.4s var(--ease-out-expo), box-shadow 0.4s var(--ease-out-expo);
  }
  .feature-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }

  .feature-mockup {
    padding: 20px 20px 0;
  }
  .feature-info {
    padding: 20px;
  }
  .feature-tag {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 4px;
    margin-bottom: 8px;
  }
  .tag-ai { background: var(--color-ai-muted); color: var(--color-ai); }
  .tag-matcha { background: var(--color-matcha-muted); color: var(--color-matcha); }
  .tag-shu { background: var(--color-shu-muted); color: var(--color-shu); }
  .feature-info h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 18px;
    letter-spacing: -0.02em;
    margin-bottom: 6px;
  }
  .feature-info p {
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* Mini app shell */
  .mini-app {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    font-size: 11px;
  }
  .mini-dark {
    background: #1a1a1a;
    border-color: #333;
  }
  .mini-topbar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 10px;
    border-bottom: 1px solid var(--color-border);
    background: #fff;
  }
  .mini-topbar-dark {
    background: #111;
    border-color: #333;
  }
  .mini-logo {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--color-ai);
    color: #fff;
    font-weight: 700;
    font-size: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mini-title-text {
    font-weight: 600;
    font-size: 11px;
    color: var(--color-text);
  }
  .mini-topbar-dots {
    margin-left: auto;
    display: flex;
    gap: 2px;
  }
  .mini-topbar-dots span {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-text-muted);
  }
  .mini-body {
    padding: 10px;
  }

  /* Mini components */
  .mini-welcome {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .mini-stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
    margin-bottom: 8px;
  }
  .mini-stat {
    background: var(--color-background);
    border: 1px solid var(--color-border-subtle);
    border-radius: 6px;
    padding: 4px;
    text-align: center;
  }
  .mini-stat-val {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 12px;
  }
  .mini-stat-label {
    display: block;
    font-size: 8px;
    color: var(--color-text-muted);
  }
  .mini-table {
    background: var(--color-background);
    border: 1px solid var(--color-border-subtle);
    border-radius: 6px;
    overflow: hidden;
  }
  .mini-table-head {
    font-weight: 600;
    font-size: 10px;
    padding: 5px 8px;
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .mini-table-row {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 8px;
    font-size: 10px;
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .mini-table-row:last-child { border-bottom: none; }
  .mini-price {
    margin-left: auto;
    font-weight: 600;
    font-size: 10px;
  }

  .mini-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot-matcha { background: var(--color-matcha); }
  .dot-ai { background: var(--color-ai); }
  .dot-shu { background: var(--color-shu); }
  .dot-pulse { animation: pulse 2s ease-in-out infinite; }

  /* Camera mini */
  .mini-viewfinder {
    height: 120px;
    background: linear-gradient(135deg, #2a2a2a 0%, #1a1a1a 50%, #2a2a2a 100%);
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 8px;
  }
  .vf-grid { position: absolute; inset: 0; }
  .vf-line { position: absolute; background: rgba(255,255,255,0.08); }
  .vf-h1 { top: 33%; left: 0; right: 0; height: 1px; }
  .vf-h2 { top: 66%; left: 0; right: 0; height: 1px; }
  .vf-v1 { left: 33%; top: 0; bottom: 0; width: 1px; }
  .vf-v2 { left: 66%; top: 0; bottom: 0; width: 1px; }
  .vf-label {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 9px;
    color: rgba(255,255,255,0.5);
    position: relative;
    z-index: 1;
  }
  .mini-strip {
    display: flex;
    gap: 4px;
    padding: 6px 10px;
    background: #111;
  }
  .strip-dot {
    width: 20px;
    height: 20px;
    border-radius: 4px;
  }
  .strip-good { background: #3a3a3a; }
  .strip-warn { background: #3a3a3a; border: 1px solid var(--color-shu); }
  .strip-active { background: var(--color-ai); }
  .strip-empty { background: #222; border: 1px dashed #444; }
  .mini-capture-bar {
    display: flex;
    justify-content: center;
    padding: 8px;
    background: #111;
  }
  .capture-circle {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid #fff;
    display: flex;
    align-items: center;
    justify-content: center;
  }
