---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Junkan — How It Works (Preview)">
  <section class="preview-hero">
    <div class="preview-container">
      <div class="preview-badge">Preview Mockup</div>
      <h1 class="preview-title">How It Works</h1>
      <p class="preview-subtitle">End-to-end flow: from photo to sold in under 2 minutes.</p>
    </div>
  </section>

  <!-- Flow connector -->
  <section class="flow-section">
    <div class="flow-container">

      <!-- Step 1: Photo Capture -->
      <div class="flow-step reveal">
        <div class="flow-step-header">
          <div class="flow-step-number step-ai">1</div>
          <div>
            <h2 class="flow-step-title">Snap a Photo</h2>
            <p class="flow-step-desc">Point, capture, done. Our quality AI ensures every shot is usable.</p>
          </div>
        </div>
        <div class="mockup-phone">
          <!-- Camera viewfinder -->
          <div class="phone-status-bar">
            <span>9:41</span>
            <span>Photo 3 of 6</span>
            <span class="phone-close-btn">X</span>
          </div>
          <div class="camera-viewfinder">
            <div class="camera-grid">
              <div class="grid-line grid-h1"></div>
              <div class="grid-line grid-h2"></div>
              <div class="grid-line grid-v1"></div>
              <div class="grid-line grid-v2"></div>
            </div>
            <div class="camera-label">
              <svg width="16" height="16" fill="none" stroke="#fff" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" /><circle cx="12" cy="13" r="4" /></svg>
              Front view
            </div>
          </div>
          <!-- Photo strip -->
          <div class="photo-strip">
            <div class="photo-thumb photo-thumb-good">
              <span>1</span>
              <div class="photo-quality quality-good">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="#fff"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              </div>
            </div>
            <div class="photo-thumb photo-thumb-good">
              <span>2</span>
              <div class="photo-quality quality-good">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="#fff"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              </div>
            </div>
            <div class="photo-thumb photo-thumb-warn">
              <span>3</span>
              <div class="photo-quality quality-warn">!</div>
            </div>
            <div class="photo-thumb photo-thumb-active">
              <span>4</span>
            </div>
            <div class="photo-thumb photo-thumb-empty"></div>
            <div class="photo-thumb photo-thumb-empty"></div>
          </div>
          <div class="camera-controls">
            <div class="camera-flash">
              <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="camera-capture-btn">
              <div class="camera-capture-inner"></div>
            </div>
            <div class="camera-switch">
              <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" stroke-linecap="round" stroke-linejoin="round"/><path d="M16 13a4 4 0 01-8 0" stroke-linecap="round"/></svg>
            </div>
          </div>
          <div class="photo-count">4 photos captured &middot; 2 good &middot; 1 warning</div>
        </div>
      </div>

      <div class="flow-arrow">
        <svg width="24" height="48" viewBox="0 0 24 48" fill="none"><path d="M12 0v40m0 0l-8-8m8 8l8-8" stroke="var(--color-border)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>

      <!-- Step 2: AI Identification -->
      <div class="flow-step reveal">
        <div class="flow-step-header">
          <div class="flow-step-number step-ai">2</div>
          <div>
            <h2 class="flow-step-title">AI Identification</h2>
            <p class="flow-step-desc">GPT-4 Vision identifies brand, condition, and attributes instantly.</p>
          </div>
        </div>
        <div class="mockup-desktop">
          <!-- Success banner -->
          <div class="ai-success-banner">
            <div class="ai-success-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            </div>
            <span>Item identified with <strong>92% confidence</strong></span>
          </div>
          <div class="ai-id-grid">
            <!-- Left: Item details -->
            <div class="ai-id-card">
              <div class="ai-id-label">Identified Item</div>
              <div class="ai-id-item-name">Levi's 501 Original Fit Jeans</div>
              <div class="ai-id-meta">
                <span class="ai-meta-tag">Fashion</span>
                <span class="ai-meta-tag">W32 L32</span>
                <span class="ai-meta-tag">Dark Blue</span>
              </div>
              <div class="ai-id-details">
                <div class="ai-detail-row">
                  <span class="ai-detail-label">Brand</span>
                  <span class="ai-detail-val">Levi's</span>
                </div>
                <div class="ai-detail-row">
                  <span class="ai-detail-label">Condition</span>
                  <span class="ai-detail-val">Good — Minor wear</span>
                </div>
                <div class="ai-detail-row">
                  <span class="ai-detail-label">Similar sold</span>
                  <span class="ai-detail-val">12 in past 30 days</span>
                </div>
              </div>
            </div>
            <!-- Right: Pricing -->
            <div class="ai-id-card ai-pricing-card">
              <div class="ai-id-label">Market Pricing</div>
              <div class="ai-price-range">
                <span class="ai-price-main">£18 — £29.99</span>
                <span class="ai-price-avg">avg: £23.50</span>
              </div>
              <div class="ai-marketplace-prices">
                <div class="ai-mp-row">
                  <span class="ai-mp-name">Shop Floor</span>
                  <span class="ai-mp-price">£18.00</span>
                  <span class="badge badge-muted">90%</span>
                </div>
                <div class="ai-mp-row ai-mp-highlight">
                  <span class="ai-mp-name">eBay</span>
                  <span class="ai-mp-price">£24.99</span>
                  <span class="badge badge-ai">85%</span>
                </div>
                <div class="ai-mp-row">
                  <span class="ai-mp-name">Vinted</span>
                  <span class="ai-mp-price">£22.00</span>
                  <span class="badge badge-matcha">83%</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="flow-arrow">
        <svg width="24" height="48" viewBox="0 0 24 48" fill="none"><path d="M12 0v40m0 0l-8-8m8 8l8-8" stroke="var(--color-border)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>

      <!-- Step 3: Smart Routing -->
      <div class="flow-step reveal">
        <div class="flow-step-header">
          <div class="flow-step-number step-matcha">3</div>
          <div>
            <h2 class="flow-step-title">Smart Routing</h2>
            <p class="flow-step-desc">AI recommends the best sales channel based on profit analysis.</p>
          </div>
        </div>
        <div class="mockup-desktop">
          <div class="routing-grid">
            <div class="route-card route-shu">
              <div class="route-dot" style="background: var(--color-shu);"></div>
              <div class="route-name">Shop Floor</div>
              <div class="route-price">£18.00</div>
              <div class="route-stats">
                <span>3-day avg sell</span>
                <span>92% success</span>
              </div>
              <div class="route-desc">Under £10 items</div>
            </div>
            <div class="route-card route-ai route-recommended">
              <div class="route-recommended-badge">Recommended</div>
              <div class="route-dot" style="background: var(--color-ai);"></div>
              <div class="route-name">Hybrid</div>
              <div class="route-price">£24.99</div>
              <div class="route-stats">
                <span>7-day avg sell</span>
                <span>87% success</span>
              </div>
              <div class="route-desc">Shop + Online</div>
            </div>
            <div class="route-card route-matcha">
              <div class="route-dot" style="background: var(--color-matcha);"></div>
              <div class="route-name">E-commerce</div>
              <div class="route-price">£24.99</div>
              <div class="route-stats">
                <span>14-day avg sell</span>
                <span>78% success</span>
              </div>
              <div class="route-desc">Over £30 items</div>
            </div>
          </div>
          <div class="routing-summary">
            <span class="routing-item">Levi's 501 Jeans</span>
            <span class="routing-arrow">&rarr;</span>
            <span class="badge badge-ai">Hybrid Route</span>
            <span class="routing-profit">Expected profit: <strong>£18.74</strong></span>
          </div>
        </div>
      </div>

      <div class="flow-arrow">
        <svg width="24" height="48" viewBox="0 0 24 48" fill="none"><path d="M12 0v40m0 0l-8-8m8 8l8-8" stroke="var(--color-border)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>

      <!-- Step 4: Marketplace Listing -->
      <div class="flow-step reveal">
        <div class="flow-step-header">
          <div class="flow-step-number step-matcha">4</div>
          <div>
            <h2 class="flow-step-title">List &amp; Sell</h2>
            <p class="flow-step-desc">Auto-generated listings published across marketplaces simultaneously.</p>
          </div>
        </div>
        <div class="mockup-desktop">
          <div class="listing-tabs">
            <div class="listing-tab listing-tab-active">eBay</div>
            <div class="listing-tab">Vinted</div>
          </div>
          <div class="listing-preview">
            <div class="listing-preview-card">
              <div class="listing-img-placeholder">
                <svg width="32" height="32" fill="none" stroke="var(--color-text-muted)" viewBox="0 0 24 24" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              </div>
              <div class="listing-details">
                <div class="listing-title-text">Levi's 501 Original Fit Jeans - W32 L32 - Dark Blue</div>
                <div class="listing-price-row">
                  <span class="listing-price">£24.99</span>
                  <span class="badge badge-ai-outline">Buy It Now</span>
                  <span class="badge badge-matcha-outline">Free Shipping</span>
                </div>
                <div class="listing-desc-text">
                  Authentic Levi's 501 Original Fit jeans in dark blue wash. Size W32 L32.
                  Good condition with minor wear. Classic straight-leg fit. 100% cotton denim.
                </div>
                <div class="listing-fee-row">
                  <span>eBay fee: £0.35</span>
                  <span class="listing-fee-divider">|</span>
                  <span>Shipping: Free</span>
                  <span class="listing-fee-divider">|</span>
                  <span class="listing-profit">Net profit: <strong>£18.74</strong></span>
                </div>
              </div>
            </div>
          </div>
          <div class="listing-success">
            <div class="listing-success-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="#fff"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            </div>
            <div>
              <div class="listing-success-title">Published to 2 marketplaces</div>
              <div class="listing-success-sub">Total expected revenue: £46.64</div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  .preview-hero {
    padding: 140px 48px 60px;
    text-align: center;
  }
  .preview-container {
    max-width: 640px;
    margin: 0 auto;
  }
  .preview-badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: var(--color-ai-muted);
    color: var(--color-ai);
    margin-bottom: 24px;
  }
  .preview-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.1;
    letter-spacing: -0.04em;
    color: var(--color-text);
    margin-bottom: 16px;
  }
  .preview-subtitle {
    font-size: 18px;
    font-weight: 350;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .flow-section {
    padding: 0 48px 120px;
  }
  .flow-container {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }
  .flow-arrow {
    padding: 16px 0;
    opacity: 0.5;
  }

  .flow-step {
    width: 100%;
  }
  .flow-step-header {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 24px;
  }
  .flow-step-number {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 16px;
    color: #fff;
    flex-shrink: 0;
  }
  .step-ai { background: var(--color-ai); }
  .step-matcha { background: var(--color-matcha); }
  .flow-step-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 24px;
    letter-spacing: -0.02em;
    margin-bottom: 4px;
  }
  .flow-step-desc {
    font-size: 15px;
    color: var(--color-text-secondary);
  }

  /* Phone mockup */
  .mockup-phone {
    background: #1a1a1a;
    border-radius: 24px;
    overflow: hidden;
    max-width: 360px;
    margin: 0 auto;
    box-shadow: 0 24px 64px rgba(0,0,0,0.15);
  }
  .phone-status-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 16px;
    background: #111;
    color: #fff;
    font-size: 11px;
    font-weight: 500;
  }
  .phone-close-btn {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
  }
  .camera-viewfinder {
    position: relative;
    height: 280px;
    background: linear-gradient(135deg, #2a2a2a 0%, #1a1a1a 50%, #2a2a2a 100%);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 16px;
  }
  .camera-grid {
    position: absolute;
    inset: 0;
  }
  .grid-line {
    position: absolute;
    background: rgba(255,255,255,0.1);
  }
  .grid-h1 { top: 33.3%; left: 0; right: 0; height: 1px; }
  .grid-h2 { top: 66.6%; left: 0; right: 0; height: 1px; }
  .grid-v1 { left: 33.3%; top: 0; bottom: 0; width: 1px; }
  .grid-v2 { left: 66.6%; top: 0; bottom: 0; width: 1px; }
  .camera-label {
    display: flex;
    align-items: center;
    gap: 6px;
    color: rgba(255,255,255,0.7);
    font-size: 12px;
    position: relative;
    z-index: 1;
  }

  .photo-strip {
    display: flex;
    gap: 6px;
    padding: 10px 16px;
    background: #111;
  }
  .photo-thumb {
    width: 40px;
    height: 40px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 600;
    position: relative;
  }
  .photo-thumb-good { background: #3a3a3a; color: #888; }
  .photo-thumb-warn { background: #3a3a3a; color: #888; }
  .photo-thumb-active { background: var(--color-ai); color: #fff; border: 2px solid #fff; }
  .photo-thumb-empty { background: #222; border: 1px dashed #444; }
  .photo-quality {
    position: absolute;
    bottom: -3px;
    right: -3px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 8px;
    font-weight: 700;
    color: #fff;
  }
  .quality-good { background: var(--color-matcha); }
  .quality-warn { background: var(--color-shu); }

  .camera-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 40px;
    padding: 16px;
    background: #111;
  }
  .camera-flash, .camera-switch {
    color: rgba(255,255,255,0.6);
  }
  .camera-capture-btn {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 3px solid #fff;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .camera-capture-inner {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #fff;
  }
  .photo-count {
    text-align: center;
    padding: 8px;
    font-size: 10px;
    color: rgba(255,255,255,0.5);
    background: #111;
  }

  /* Desktop mockup */
  .mockup-desktop {
    background: var(--color-surface);
    border-radius: 14px;
    border: 1px solid var(--color-border);
    box-shadow: 0 24px 64px rgba(0,0,0,0.08);
    overflow: hidden;
    padding: 20px;
  }

  /* AI Identification */
  .ai-success-banner {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    background: var(--color-matcha-muted);
    border: 1px solid rgba(61, 166, 106, 0.2);
    border-radius: 8px;
    margin-bottom: 16px;
    font-size: 13px;
    color: var(--color-text);
  }
  .ai-success-icon {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--color-matcha);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .ai-id-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .ai-id-card {
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 16px;
  }
  .ai-pricing-card {
    background: var(--color-ai-muted);
    border-color: rgba(75, 123, 229, 0.2);
  }
  .ai-id-label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: 10px;
  }
  .ai-id-item-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    margin-bottom: 8px;
  }
  .ai-id-meta {
    display: flex;
    gap: 6px;
    margin-bottom: 14px;
  }
  .ai-meta-tag {
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
  }
  .ai-id-details {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .ai-detail-row {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
  }
  .ai-detail-label { color: var(--color-text-muted); }
  .ai-detail-val { color: var(--color-text); font-weight: 500; }
  .ai-price-range { margin-bottom: 14px; }
  .ai-price-main {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
    color: var(--color-text);
  }
  .ai-price-avg {
    display: block;
    font-size: 12px;
    color: var(--color-text-muted);
    margin-top: 2px;
  }
  .ai-marketplace-prices {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ai-mp-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    padding: 6px 8px;
    border-radius: 6px;
  }
  .ai-mp-highlight {
    background: rgba(75, 123, 229, 0.08);
  }
  .ai-mp-name { flex: 1; color: var(--color-text-secondary); }
  .ai-mp-price { font-weight: 600; color: var(--color-text); }

  /* Badges */
  .badge {
    display: inline-block;
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 500;
    white-space: nowrap;
  }
  .badge-ai { background: var(--color-ai-muted); color: var(--color-ai); }
  .badge-matcha { background: var(--color-matcha-muted); color: var(--color-matcha); }
  .badge-muted { background: #f5f5f5; color: var(--color-text-muted); }
  .badge-ai-outline { background: transparent; border: 1px solid rgba(75, 123, 229, 0.3); color: var(--color-ai); }
  .badge-matcha-outline { background: transparent; border: 1px solid rgba(61, 166, 106, 0.3); color: var(--color-matcha); }

  /* Routing */
  .routing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 16px;
  }
  .route-card {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 16px;
    text-align: center;
    position: relative;
  }
  .route-recommended {
    border-color: var(--color-ai);
    box-shadow: 0 0 0 1px var(--color-ai);
    background: var(--color-ai-muted);
  }
  .route-recommended-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    padding: 2px 10px;
    border-radius: 100px;
    font-size: 10px;
    font-weight: 600;
    background: var(--color-ai);
    color: #fff;
    white-space: nowrap;
  }
  .route-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    margin: 0 auto 8px;
  }
  .route-name {
    font-weight: 600;
    font-size: 14px;
    margin-bottom: 4px;
  }
  .route-price {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
    color: var(--color-text);
    margin-bottom: 8px;
  }
