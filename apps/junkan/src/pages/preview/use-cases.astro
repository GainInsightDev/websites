---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Junkan — Use Cases (Preview)">
  <section class="preview-hero">
    <div class="preview-container">
      <div class="preview-badge">Preview Mockup</div>
      <h1 class="preview-title">Built for Everyone Who Resells</h1>
      <p class="preview-subtitle">From charity shops to individual sellers — one platform, tuned to your goals.</p>
    </div>
  </section>

  <!-- Use Case 1: Charity Retailers -->
  <section class="use-case">
    <div class="use-case-inner">
      <div class="use-case-header reveal">
        <div class="uc-tag uc-tag-ai">Charity retailers</div>
        <h2 class="uc-title">Maximise every donation</h2>
        <p class="uc-desc">11,200+ UK charity shops lose up to 40% of potential revenue. Junkan gives your volunteers the expertise of a professional reseller — instantly.</p>
      </div>

      <div class="uc-mockups reveal">
        <!-- Dashboard mockup -->
        <div class="uc-mockup-card">
          <div class="uc-card-label">Dashboard — Daily overview</div>
          <div class="uc-app">
            <div class="uc-topbar">
              <span class="uc-logo">J</span>
              <span class="uc-app-title">Oxfam Brixton</span>
              <div class="uc-topbar-right">
                <span class="uc-notif">3</span>
                <span class="uc-avatar">SM</span>
              </div>
            </div>
            <div class="uc-body">
              <div class="uc-welcome">Good morning, Sarah</div>
              <div class="uc-stats">
                <div class="uc-stat">
                  <span class="uc-stat-val">47</span>
                  <span class="uc-stat-label">Items this week</span>
                  <span class="uc-stat-trend uc-trend-up">&uarr; 12%</span>
                </div>
                <div class="uc-stat">
                  <span class="uc-stat-val">&pound;1,247</span>
                  <span class="uc-stat-label">Total value</span>
                  <span class="uc-stat-trend uc-trend-up">&uarr; 8%</span>
                </div>
                <div class="uc-stat">
                  <span class="uc-stat-val">8</span>
                  <span class="uc-stat-label">Pending</span>
                  <span class="uc-stat-trend uc-trend-muted">Awaiting</span>
                </div>
              </div>
              <div class="uc-activity">
                <div class="uc-activity-title">Recent Activity</div>
                <div class="uc-act-row"><span class="uc-dot dot-matcha"></span><span>Vintage Leather Jacket</span><span class="uc-badge uc-badge-matcha">Listed</span><span class="uc-act-price">&pound;85</span></div>
                <div class="uc-act-row"><span class="uc-dot dot-ai"></span><span>Designer Handbag</span><span class="uc-badge uc-badge-ai">Processing</span><span class="uc-act-price">&pound;120</span></div>
                <div class="uc-act-row"><span class="uc-dot dot-matcha"></span><span>KitchenAid Mixer</span><span class="uc-badge uc-badge-matcha">Listed</span><span class="uc-act-price">&pound;95</span></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Gift Aid mockup -->
        <div class="uc-mockup-card">
          <div class="uc-card-label">Gift Aid — Tax-efficient donations</div>
          <div class="uc-app">
            <div class="uc-topbar">
              <span class="uc-logo">J</span>
              <span class="uc-app-title">Gift Aid</span>
            </div>
            <div class="uc-body">
              <div class="uc-search-box">
                <svg width="12" height="12" fill="none" stroke="var(--color-text-muted)" viewBox="0 0 24 24" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
                <span>Search by name or donor ID</span>
              </div>
              <div class="uc-donor-list">
                <div class="uc-donor uc-donor-selected">
                  <div class="uc-donor-avatar">JS</div>
                  <div class="uc-donor-info">
                    <div class="uc-donor-name">John Smith</div>
                    <div class="uc-donor-meta">Last: 2 days ago &middot; 12 donations</div>
                  </div>
                </div>
                <div class="uc-donor">
                  <div class="uc-donor-avatar">SJ</div>
                  <div class="uc-donor-info">
                    <div class="uc-donor-name">Sarah Johnson</div>
                    <div class="uc-donor-meta">Last: 1 week ago &middot; 8 donations</div>
                  </div>
                </div>
                <div class="uc-donor">
                  <div class="uc-donor-avatar">MB</div>
                  <div class="uc-donor-info">
                    <div class="uc-donor-name">Michael Brown</div>
                    <div class="uc-donor-meta">Last: 3 weeks ago &middot; 23 donations</div>
                  </div>
                </div>
              </div>
              <div class="uc-giftaid-box">
                <div class="uc-giftaid-check">&check;</div>
                <span class="uc-giftaid-text">Gift Aid declaration confirmed</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Analytics mockup -->
        <div class="uc-mockup-card">
          <div class="uc-card-label">Analytics — Impact reporting</div>
          <div class="uc-app">
            <div class="uc-topbar">
              <span class="uc-logo">J</span>
              <span class="uc-app-title">Analytics</span>
            </div>
            <div class="uc-body">
              <div class="uc-kpis">
                <div class="uc-kpi">
                  <span class="uc-kpi-val">&pound;12.4k</span>
                  <span class="uc-kpi-sub">Revenue &uarr;15%</span>
                </div>
                <div class="uc-kpi">
                  <span class="uc-kpi-val">78%</span>
                  <span class="uc-kpi-sub">Sell-through</span>
                </div>
              </div>
              <div class="uc-chart-placeholder">
                <svg viewBox="0 0 240 80" class="uc-chart-svg">
                  <polyline points="0,65 40,60 80,50 120,55 160,35 200,25 240,15" fill="none" stroke="var(--color-ai)" stroke-width="2.5"/>
                  <polyline points="0,65 40,60 80,50 120,55 160,35 200,25 240,15 240,80 0,80" fill="url(#ucGrad1)" stroke="none"/>
                  <defs><linearGradient id="ucGrad1" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="var(--color-ai)" stop-opacity="0.12"/><stop offset="100%" stop-color="var(--color-ai)" stop-opacity="0"/></linearGradient></defs>
                </svg>
              </div>
              <div class="uc-channels">
                <div class="uc-ch"><span class="uc-dot dot-shu"></span>Shop &pound;4.8k</div>
                <div class="uc-ch"><span class="uc-dot dot-ai"></span>eBay &pound;5.9k</div>
                <div class="uc-ch"><span class="uc-dot dot-matcha"></span>Vinted &pound;3.2k</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="uc-benefits reveal">
        <div class="uc-benefit"><span class="uc-benefit-icon uc-benefit-ai">&#10003;</span>No expertise needed — AI does the pricing</div>
        <div class="uc-benefit"><span class="uc-benefit-icon uc-benefit-matcha">&#10003;</span>HMRC-compliant Gift Aid tracking</div>
        <div class="uc-benefit"><span class="uc-benefit-icon uc-benefit-matcha">&#10003;</span>Impact reporting for trustees</div>
      </div>
    </div>
  </section>

  <!-- Use Case 2: Professional Resellers -->
  <section class="use-case use-case-alt">
    <div class="use-case-inner">
      <div class="use-case-header reveal">
        <div class="uc-tag uc-tag-matcha">Professional resellers</div>
        <h2 class="uc-title">Scale without hiring</h2>
        <p class="uc-desc">Turn over more inventory, faster. Junkan handles the research and listing so you can focus on sourcing the best stock.</p>
      </div>

      <div class="uc-mockups reveal">
        <!-- Smart Routing -->
        <div class="uc-mockup-card">
          <div class="uc-card-label">Smart Routing — Profit optimisation</div>
          <div class="uc-app">
            <div class="uc-topbar">
              <span class="uc-logo">J</span>
              <span class="uc-app-title">Routing</span>
            </div>
            <div class="uc-body">
              <div class="uc-routes">
                <div class="uc-route">
                  <span class="uc-dot dot-shu"></span>
                  <div class="uc-route-info">
                    <div class="uc-route-name">Shop Floor</div>
                    <div class="uc-route-detail">3-day avg &middot; 92% success</div>
                  </div>
                  <span class="uc-route-price">&pound;18</span>
                </div>
                <div class="uc-route uc-route-hl">
                  <span class="uc-dot dot-ai"></span>
                  <div class="uc-route-info">
                    <div class="uc-route-name">Hybrid <span class="uc-rec">Recommended</span></div>
                    <div class="uc-route-detail">7-day avg &middot; 87% success</div>
                  </div>
                  <span class="uc-route-price">&pound;24.99</span>
                </div>
                <div class="uc-route">
                  <span class="uc-dot dot-matcha"></span>
                  <div class="uc-route-info">
                    <div class="uc-route-name">E-commerce</div>
                    <div class="uc-route-detail">14-day avg &middot; 78% success</div>
                  </div>
                  <span class="uc-route-price">&pound;24.99</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Marketplace Listings -->
        <div class="uc-mockup-card">
          <div class="uc-card-label">Listings — Multi-channel publishing</div>
          <div class="uc-app">
            <div class="uc-topbar">
              <span class="uc-logo">J</span>
              <span class="uc-app-title">Listings</span>
            </div>
            <div class="uc-body">
              <div class="uc-listing-item">
                <div class="uc-listing-thumb">
                  <svg width="16" height="16" fill="none" stroke="var(--color-text-muted)" viewBox="0 0 24 24" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                </div>
                <div class="uc-listing-info">
                  <div class="uc-listing-name">Levi's 501 Jeans</div>
                  <div class="uc-listing-price">&pound;24.99</div>
                </div>
              </div>
              <div class="uc-marketplace-row">
                <div class="uc-mp-chip uc-mp-active"><span class="uc-dot dot-ai"></span>eBay <span class="uc-mp-fee">&pound;0.35</span></div>
                <div class="uc-mp-chip uc-mp-active"><span class="uc-dot dot-matcha"></span>Vinted <span class="uc-mp-fee">Free</span></div>
              </div>
              <div class="uc-total-bar">
                <span>Total revenue</span>
                <span class="uc-total-val">&pound;46.64</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Fulfillment -->
        <div class="uc-mockup-card">
          <div class="uc-card-label">Fulfillment — One-click dispatch</div>
          <div class="uc-app">
            <div class="uc-topbar">
              <span class="uc-logo">J</span>
              <span class="uc-app-title">Shipping</span>
            </div>
            <div class="uc-body">
              <div class="uc-sold-banner">Sold on eBay for &pound;24.99</div>
              <div class="uc-carriers">
                <div class="uc-carrier">
                  <div class="uc-carrier-info">
                    <div class="uc-carrier-name">Royal Mail Tracked 24</div>
                    <div class="uc-carrier-detail">Next day delivery</div>
                  </div>
                  <span class="uc-carrier-price">&pound;3.50</span>
                </div>
                <div class="uc-carrier">
                  <div class="uc-carrier-info">
                    <div class="uc-carrier-name">Royal Mail Tracked 48</div>
                    <div class="uc-carrier-detail">2 day delivery</div>
                  </div>
                  <span class="uc-carrier-price">&pound;2.80</span>
                </div>
                <div class="uc-carrier">
                  <div class="uc-carrier-info">
                    <div class="uc-carrier-name">Evri</div>
                    <div class="uc-carrier-detail">2-3 day delivery</div>
                  </div>
                  <span class="uc-carrier-price">&pound;2.95</span>
                </div>
              </div>
              <div class="uc-label-preview">
                <svg width="14" height="14" fill="none" stroke="var(--color-text-muted)" viewBox="0 0 24 24" stroke-width="1.5"><path d="M6 9V2h12v7M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2M6 14h12v8H6z"/></svg>
                <span>Print label — RM123456789GB</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="uc-benefits reveal">
        <div class="uc-benefit"><span class="uc-benefit-icon uc-benefit-matcha">&#10003;</span>Process 10x more items per hour</div>
        <div class="uc-benefit"><span class="uc-benefit-icon uc-benefit-ai">&#10003;</span>Platform-specific fee optimisation</div>
        <div class="uc-benefit"><span class="uc-benefit-icon uc-benefit-matcha">&#10003;</span>Integrated shipping &amp; tracking</div>
      </div>
    </div>
  </section>

  <!-- Use Case 3: Casual Sellers -->
  <section class="use-case">
    <div class="use-case-inner">
      <div class="use-case-header reveal">
        <div class="uc-tag uc-tag-shu">Casual sellers</div>
        <h2 class="uc-title">Photograph it. Step back.</h2>
        <p class="uc-desc">Got items to sell but not the time or knowledge? Junkan makes it effortless — from your wardrobe to someone's doorstep.</p>
      </div>

      <div class="uc-mockups uc-mockups-phone reveal">
        <!-- Photo Capture (mobile) -->
        <div class="uc-mockup-card uc-phone-card">
          <div class="uc-card-label">1. Snap a photo</div>
          <div class="uc-phone">
            <div class="uc-phone-notch"></div>
            <div class="uc-phone-viewfinder">
              <div class="uc-phone-grid">
                <div class="uc-pg-h1"></div><div class="uc-pg-h2"></div>
                <div class="uc-pg-v1"></div><div class="uc-pg-v2"></div>
              </div>
              <div class="uc-phone-label">
                <svg width="14" height="14" fill="none" stroke="rgba(255,255,255,0.7)" viewBox="0 0 24 24" stroke-width="2"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
                Take a photo
              </div>
            </div>
            <div class="uc-phone-capture">
              <div class="uc-phone-btn"><div class="uc-phone-btn-inner"></div></div>
            </div>
          </div>
        </div>

        <!-- AI Result (mobile) -->
        <div class="uc-mockup-card uc-phone-card">
          <div class="uc-card-label">2. AI identifies &amp; prices</div>
          <div class="uc-phone uc-phone-light">
            <div class="uc-phone-notch"></div>
            <div class="uc-phone-body">
              <div class="uc-phone-success">
                <span class="uc-phone-check">&check;</span>
                <span>Identified &middot; 92%</span>
              </div>
              <div class="uc-phone-item">Levi's 501 Jeans</div>
              <div class="uc-phone-tags">
                <span>Fashion</span><span>W32 L32</span><span>Good</span>
              </div>
              <div class="uc-phone-price">
                <div class="uc-phone-price-main">&pound;24.99</div>
                <div class="uc-phone-price-sub">Best price on eBay</div>
              </div>
              <div class="uc-phone-action">List now &rarr;</div>
            </div>
          </div>
        </div>

        <!-- Success (mobile) -->
        <div class="uc-mockup-card uc-phone-card">
          <div class="uc-card-label">3. Sold!</div>
          <div class="uc-phone uc-phone-light">
            <div class="uc-phone-notch"></div>
            <div class="uc-phone-body uc-phone-center">
              <div class="uc-sold-circle">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="#fff"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              </div>
              <div class="uc-sold-title">Item sold!</div>
              <div class="uc-sold-amount">&pound;24.99</div>
              <div class="uc-sold-detail">Sold on eBay to buyer_jane92</div>
              <div class="uc-sold-profit">Your profit: <strong>&pound;18.74</strong></div>
            </div>
          </div>
        </div>
      </div>

      <div class="uc-benefits reveal">
        <div class="uc-benefit"><span class="uc-benefit-icon uc-benefit-shu">&#10003;</span>No marketplace knowledge needed</div>
        <div class="uc-benefit"><span class="uc-benefit-icon uc-benefit-shu">&#10003;</span>AI handles buyer messages</div>
        <div class="uc-benefit"><span class="uc-benefit-icon uc-benefit-matcha">&#10003;</span>From photo to sold in under 2 minutes</div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .preview-hero {
    padding: 140px 48px 60px;
    text-align: center;
  }
  .preview-container {
    max-width: 640px;
    margin: 0 auto;
  }
  .preview-badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: var(--color-ai-muted);
    color: var(--color-ai);
    margin-bottom: 24px;
  }
  .preview-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.1;
    letter-spacing: -0.04em;
    color: var(--color-text);
    margin-bottom: 16px;
  }
  .preview-subtitle {
    font-size: 18px;
    font-weight: 350;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* Use case sections */
  .use-case {
    padding: 80px 48px;
  }
  .use-case-alt {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border-subtle);
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .use-case-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .use-case-header {
    margin-bottom: 48px;
  }
  .uc-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 4px;
    margin-bottom: 16px;
  }
  .uc-tag-ai { background: var(--color-ai-muted); color: var(--color-ai); }
  .uc-tag-matcha { background: var(--color-matcha-muted); color: var(--color-matcha); }
  .uc-tag-shu { background: var(--color-shu-muted); color: var(--color-shu); }
  .uc-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(28px, 3.5vw, 44px);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 12px;
  }
  .uc-desc {
    font-size: 16px;
    font-weight: 350;
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 520px;
  }

  /* Mockup grid */
  .uc-mockups {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 40px;
  }
  .uc-mockups-phone {
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  .uc-mockup-card {
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
  }
  .uc-card-label {
    padding: 10px 16px;
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  /* App shell for use cases */
  .uc-app {
    font-size: 11px;
  }
  .uc-topbar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--color-border-subtle);
    background: #fff;
  }
  .uc-logo {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--color-ai);
    color: #fff;
    font-weight: 700;
    font-size: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .uc-app-title {
    font-weight: 600;
    font-size: 11px;
  }
  .uc-topbar-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .uc-notif {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--color-shu);
    color: #fff;
    font-size: 8px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .uc-avatar {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--color-ai);
    color: #fff;
    font-size: 8px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .uc-body {
    padding: 12px;
  }

  /* Dashboard components */
  .uc-welcome {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
    margin-bottom: 10px;
  }
  .uc-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
    margin-bottom: 12px;
  }
  .uc-stat {
    background: #fff;
    border: 1px solid var(--color-border-subtle);
    border-radius: 6px;
    padding: 6px;
  }
  .uc-stat-val {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14px;
  }
  .uc-stat-label {
    display: block;
    font-size: 9px;
    color: var(--color-text-muted);
  }
  .uc-stat-trend {
    font-size: 9px;
    font-weight: 500;
  }
  .uc-trend-up { color: var(--color-matcha); }
  .uc-trend-muted { color: var(--color-text-muted); }
  .uc-activity {
    background: #fff;
    border: 1px solid var(--color-border-subtle);
    border-radius: 6px;
    overflow: hidden;
  }
  .uc-activity-title {
    font-weight: 600;
    font-size: 11px;
    padding: 6px 10px;
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .uc-act-row {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px;
    font-size: 10px;
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .uc-act-row:last-child { border-bottom: none; }
  .uc-act-price {
    margin-left: auto;
    font-weight: 600;
  }

  /* Dots */
  .uc-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot-matcha { background: var(--color-matcha); }
  .dot-ai { background: var(--color-ai); }
  .dot-shu { background: var(--color-shu); }

  /* Badges */
  .uc-badge {
    font-size: 9px;
    padding: 1px 5px;
