    .pipeline-line-svg { display: none; }
    .social-proof { flex-wrap: wrap; gap: 24px; padding: 32px 24px; }
    .stat-section { padding: 100px 24px; }
    .cta-section { padding: 100px 24px; }
    .pricing-callout { flex-direction: column; gap: 24px; padding: 32px 24px; }
    .pricing-divider { width: 64px; height: 1px; }
    .pipeline-inner { padding: 80px 24px; }
    .hero-actions { flex-direction: column; }
