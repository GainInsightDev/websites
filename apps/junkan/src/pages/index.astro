---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ═══════ HERO ═══════ -->
  <section class="hero" id="hero">
    <!-- Atmospheric gradient -->
    <div class="hero-atmosphere"></div>

    <!-- Centred header text -->
    <div class="hero-header">
      <div class="hero-badge reveal reveal-delay-1">
        <span class="hero-badge-dot"></span>
        Now in early access
      </div>
      <h1 class="hero-title reveal reveal-delay-2">
        Every item,<br><span class="accent">expertly sold.</span>
      </h1>
      <p class="hero-subtitle reveal reveal-delay-3">
        Photograph your item. Our AI handles identification, research, pricing, and listing across every marketplace. You step back.
      </p>
      <div class="hero-actions reveal reveal-delay-4">
        <a href="#cta" class="btn btn-primary">
          Get early access
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="#solution" class="btn btn-secondary">See how it works</a>
      </div>
    </div>

    <!-- Dashboard + floating cards showcase -->
    <div class="hero-showcase reveal reveal-delay-3">
      <!-- Full Junkan dashboard mockup (centre) -->
      <div class="hero-visual">
        <div class="hero-app-shell">
          <!-- Mini sidebar -->
          <div class="hero-sidebar">
            <div class="hero-sidebar-logo">
              <div class="hero-logo-circle">J</div>
              <div class="hero-logo-text">
                <span class="hero-logo-name">Junkan</span>
                <span class="hero-logo-org">Oxfam Brixton</span>
              </div>
            </div>
            <nav class="hero-sidebar-nav">
              <a class="hero-nav-item hero-nav-active">
                <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" /></svg>
                Dashboard
              </a>
              <a class="hero-nav-item hero-nav-cta">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
                Add Item
              </a>
              <a class="hero-nav-item">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
                Items
              </a>
              <a class="hero-nav-item hero-nav-msg">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
                Messages
                <span class="hero-nav-badge">2</span>
              </a>
              <a class="hero-nav-item">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
                Reports
              </a>
            </nav>
            <div class="hero-sidebar-user">
              <div class="hero-user-avatar">SM</div>
              <div class="hero-user-text">
                <span class="hero-user-name">Sarah Mitchell</span>
                <span class="hero-user-role">Volunteer</span>
              </div>
            </div>
          </div>

          <!-- Main area -->
          <div class="hero-main">
            <div class="hero-topbar">
              <div class="hero-search">
                <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                <span>Search items...</span>
              </div>
              <div class="hero-topbar-right">
                <div class="hero-notif">
                  <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
                  <span class="hero-notif-dot">3</span>
                </div>
                <div class="hero-topbar-avatar">SM</div>
              </div>
            </div>

            <div class="hero-dash-body">
              <div class="hero-dash-welcome">Good morning, Sarah</div>
              <div class="hero-dash-sub">Here's what's happening with your items today.</div>

              <div class="hero-stats-row">
                <div class="hero-stat">
                  <span class="hero-stat-label">Items this week</span>
                  <span class="hero-stat-val">47</span>
                  <span class="hero-stat-trend">↑ 12%</span>
                </div>
                <div class="hero-stat">
                  <span class="hero-stat-label">Total value</span>
                  <span class="hero-stat-val">£1,247</span>
                  <span class="hero-stat-trend">↑ 8%</span>
                </div>
                <div class="hero-stat">
                  <span class="hero-stat-label">Pending</span>
                  <span class="hero-stat-val">8</span>
                  <span class="hero-stat-trend hero-stat-muted">Awaiting</span>
                </div>
                <div class="hero-stat">
                  <span class="hero-stat-label">Active</span>
                  <span class="hero-stat-val">23</span>
                  <span class="hero-stat-trend hero-stat-muted">eBay & Vinted</span>
                </div>
              </div>

              <div class="hero-activity">
                <div class="hero-activity-head">
                  <span class="hero-activity-title">Recent Activity</span>
                  <div class="hero-activity-btns">
                    <span class="hero-outline-btn">Filter</span>
                    <span class="hero-outline-btn">Export</span>
                  </div>
                </div>
                <table class="hero-table">
                  <thead>
                    <tr>
                      <th></th>
                      <th>Title</th>
                      <th>Category</th>
                      <th>Price</th>
                      <th>Status</th>
                      <th>Route</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td><div class="hero-tbl-thumb">V</div></td>
                      <td class="hero-tbl-title">Vintage Leather Jacket</td>
                      <td>Fashion</td>
                      <td class="hero-tbl-price">£85.00</td>
                      <td><span class="hero-badge hero-badge-matcha">Listed</span></td>
                      <td><span class="hero-badge hero-badge-matcha-o">E-commerce</span></td>
                    </tr>
                    <tr>
                      <td><div class="hero-tbl-thumb">C</div></td>
                      <td class="hero-tbl-title">Ceramic Vase Set</td>
                      <td>Homeware</td>
                      <td class="hero-tbl-price">£12.00</td>
                      <td><span class="hero-badge hero-badge-muted">In Shop</span></td>
                      <td><span class="hero-badge hero-badge-shu-o">Shop Floor</span></td>
                    </tr>
                    <tr>
                      <td><div class="hero-tbl-thumb">D</div></td>
                      <td class="hero-tbl-title">Designer Handbag</td>
                      <td>Accessories</td>
                      <td class="hero-tbl-price">£120.00</td>
                      <td><span class="hero-badge hero-badge-ai">Processing</span></td>
                      <td><span class="hero-badge hero-badge-ai-o">Hybrid</span></td>
                    </tr>
                    <tr>
                      <td><div class="hero-tbl-thumb">R</div></td>
                      <td class="hero-tbl-title">Retro Gaming Console</td>
                      <td>Electronics</td>
                      <td class="hero-tbl-price">£45.00</td>
                      <td><span class="hero-badge hero-badge-matcha">Listed</span></td>
                      <td><span class="hero-badge hero-badge-ai-o">Hybrid</span></td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Floating cards evenly distributed around dashboard -->
      <div class="float-card float-tl reveal reveal-delay-4">
        <div class="fc-label">AI Identification</div>
        <div class="fc-body">
          <div class="fc-success"><span class="fc-check">&#10003;</span> 92% confidence</div>
          <div class="fc-item-name">Levi's 501 Jeans</div>
          <div class="fc-tags"><span>Fashion</span><span>W32 L32</span><span>Good</span></div>
        </div>
      </div>

      <div class="float-card float-bl reveal reveal-delay-5">
        <div class="fc-label">Analytics</div>
        <div class="fc-body">
          <div class="fc-kpi-row">
            <div><span class="fc-kpi-val">£12.4k</span><span class="fc-kpi-lbl">Revenue <span class="fc-trend">↑15%</span></span></div>
            <div><span class="fc-kpi-val">342</span><span class="fc-kpi-lbl">Items <span class="fc-trend">↑8%</span></span></div>
          </div>
          <svg viewBox="0 0 200 50" class="fc-chart"><polyline points="0,42 33,40 66,34 100,36 133,24 166,16 200,8" fill="none" stroke="var(--color-ai)" stroke-width="2"/></svg>
        </div>
      </div>

      <div class="float-card float-tr reveal reveal-delay-4">
        <div class="fc-label">Smart Routing</div>
        <div class="fc-body">
          <div class="fc-route"><span class="fc-dot fc-dot-shu"></span>Shop Floor<span class="fc-rprice">£18</span></div>
          <div class="fc-route fc-route-hl"><span class="fc-dot fc-dot-ai"></span>Hybrid <span class="fc-rec">Rec</span><span class="fc-rprice">£24.99</span></div>
          <div class="fc-route"><span class="fc-dot fc-dot-matcha"></span>E-commerce<span class="fc-rprice">£24.99</span></div>
        </div>
      </div>

      <div class="float-card float-ml reveal reveal-delay-5">
        <div class="fc-label">Queue Management</div>
        <div class="fc-body">
          <div class="fc-route"><span class="fc-dot fc-dot-matcha"></span>Ready<span class="fc-rprice">12</span></div>
          <div class="fc-route fc-route-hl"><span class="fc-dot fc-dot-ai"></span>Processing<span class="fc-rprice">5</span></div>
          <div class="fc-route"><span class="fc-dot fc-dot-shu"></span>Pending<span class="fc-rprice">3</span></div>
        </div>
      </div>

      <div class="float-card float-mr reveal reveal-delay-5">
        <div class="fc-label">Marketplace Listing</div>
        <div class="fc-body">
          <div class="fc-listing-row">
            <div class="fc-listing-thumb">
              <svg width="14" height="14" fill="none" stroke="var(--color-text-muted)" viewBox="0 0 24 24" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            </div>
            <div>
              <div class="fc-listing-name">Levi's 501 Jeans</div>
              <div class="fc-listing-price">£24.99</div>
            </div>
          </div>
          <div class="fc-pub-bar"><span class="fc-check">&#10003;</span> Published to 2 marketplaces</div>
        </div>
      </div>

      <div class="float-card float-br reveal reveal-delay-6">
        <div class="fc-label">Fulfilment</div>
        <div class="fc-body">
          <div class="fc-route"><span class="fc-dot fc-dot-matcha"></span>Packed<span class="fc-rprice">✓</span></div>
          <div class="fc-route fc-route-hl"><span class="fc-dot fc-dot-ai"></span>Shipped<span class="fc-rprice">Royal Mail</span></div>
          <div class="fc-route"><span class="fc-dot fc-dot-shu"></span>Delivered<span class="fc-rprice">Pending</span></div>
        </div>
      </div>
    </div>

    <!-- Social proof -->
    <div class="hero-proof reveal reveal-delay-5">
      <div class="hero-proof-item">
        <span class="hero-proof-value">11,200+</span>
        <span class="hero-proof-label">UK charity shops</span>
      </div>
      <div class="hero-proof-divider"></div>
      <div class="hero-proof-item">
        <span class="hero-proof-value">40%</span>
        <span class="hero-proof-label">Revenue left on the table</span>
      </div>
      <div class="hero-proof-divider"></div>
      <div class="hero-proof-item">
        <span class="hero-proof-value">&lt;2 min</span>
        <span class="hero-proof-label">Photo to listed</span>
      </div>
    </div>
  </section>

  <!-- ═══════ PROBLEM ═══════ -->
  <section class="section" id="problem">
    <div class="section-label reveal">The problem</div>
    <h2 class="section-title reveal reveal-delay-1">Every resale item is different. It's the hardest sales job there is.</h2>
    <p class="section-body reveal reveal-delay-2">Selling new is easy — fixed price, fixed margin. Secondhand? Every item is its own puzzle, and every variable is shifting.</p>

    <div class="problem-grid">
      <div class="problem-card reveal reveal-delay-2">
        <div class="problem-icon problem-icon-shu">
          <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="#D95A50" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3>Manual Pricing</h3>
        <p>Every secondhand item needs individual research across multiple marketplaces. Staff spend hours comparing prices with no guarantee of accuracy — and mispriced items either sit unsold or sell at a loss.</p>
      </div>
      <div class="problem-card reveal reveal-delay-3">
        <div class="problem-icon problem-icon-ai">
          <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" stroke="#4B7BE5" stroke-width="1.25"/><path d="M12 6v6l4 2" stroke="#4B7BE5" stroke-width="1.25" stroke-linecap="round"/></svg>
        </div>
        <h3>Slow Item Processing</h3>
        <p>Identifying, researching, photographing, and listing each item takes 10–15 minutes. When donations pile up faster than staff can process them, valuable items get overlooked or binned.</p>
      </div>
      <div class="problem-card reveal reveal-delay-4">
        <div class="problem-icon problem-icon-matcha">
          <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><path d="M18 20H7c0 0 1-3.5 1-7M6 12h8M6 16h6M16.5 4.5C15.5 3.5 14.2 3 12.8 3 9.6 3 7 5.7 7 9c0 1 .2 2 .5 3" stroke="#3DA66A" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3>Lost Revenue</h3>
        <p>Without pricing intelligence, items sell for far less than they're worth — or don't sell at all. Up to 40% of potential revenue is lost to guesswork and missed opportunities.</p>
      </div>
    </div>
  </section>

  <!-- ═══════ SOLUTION / PIPELINE ═══════ -->
  <section class="solution-section" id="solution">
    <div class="solution-inner">
      <div class="solution-header">
        <div class="section-label reveal">The solution</div>
        <h2 class="section-title reveal reveal-delay-1">Photograph it.<br>We handle the rest.</h2>
        <p class="section-body reveal reveal-delay-2">Junkan's AI pipeline takes your item from photo to sold — identifying it, researching comparable sales, calculating optimal pricing, and listing it where it'll sell best.</p>
      </div>

      <div class="solution-layout reveal">
        <!-- Left: Steps -->
        <div class="solution-steps">
          <div class="solution-step reveal reveal-delay-1">
            <div class="step-icon step-icon-ai">
              <svg width="22" height="22" fill="none" viewBox="0 0 24 24"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="13" r="4" stroke="currentColor" stroke-width="1.5"/></svg>
            </div>
            <div class="step-text">
              <h3>Snap a Photo</h3>
              <p>Take a quick photo of the item. Our AI instantly recognises the brand, model, condition, and key attributes — no manual data entry needed.</p>
            </div>
          </div>

          <div class="solution-step reveal reveal-delay-2">
            <div class="step-icon step-icon-ai">
              <svg width="22" height="22" fill="none" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="step-text">
              <h3>Automatic Research</h3>
              <p>Junkan scans completed sales across eBay, Vinted, and Depop in seconds — building a real-time pricing picture so you know exactly what the item is worth.</p>
            </div>
          </div>

          <div class="solution-step reveal reveal-delay-3">
            <div class="step-icon step-icon-matcha">
              <span class="step-icon-currency">&pound;</span>
            </div>
            <div class="step-text">
              <h3>Smart Pricing</h3>
              <p>Our algorithm calculates the net profit per platform after all fees, recommending the optimal pricing strategy to maximise your returns.</p>
            </div>
          </div>

          <div class="solution-step reveal reveal-delay-4">
            <div class="step-icon step-icon-matcha">
              <svg width="22" height="22" fill="none" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="step-text">
              <h3>List &amp; Sell</h3>
              <p>Junkan creates optimised listings with compelling descriptions and posts them across marketplaces — then monitors until the sale completes.</p>
            </div>
          </div>
        </div>

        <!-- Right: Images (2 top + 1 bottom) -->
        <div class="solution-images">
          <div class="solution-images-top">
            <div class="solution-image-card">
              <img src="/images/thrift-store.jpg" alt="Woman browsing secondhand clothing at a vintage thrift store" width="800" height="533" loading="lazy" />
            </div>
            <div class="solution-image-card">
              <img src="/images/item-inspection.jpg" alt="Two people inspecting clothing items at a thrift store" width="800" height="533" loading="lazy" />
            </div>
          </div>
          <div class="solution-image-card solution-image-wide">
            <img src="/images/phone-scanning.jpg" alt="Person browsing clothing listings with prices on a mobile app" width="800" height="1200" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ CAPABILITIES ═══════ -->
  <section class="capabilities-section" id="capabilities">
    <div class="capabilities-layout">
      <!-- Left: Mockup with floating cards -->
      <div class="cap-visual reveal reveal-delay-1">
        <div class="cap-mockup">
          <!-- AI Identification card (main) -->
          <div class="cap-main-card">
            <div class="cap-card-header">
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke="var(--color-ai)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>AI Identification</span>
            </div>
            <div class="cap-card-body">
              <div class="cap-item-row">
                <div class="cap-item-thumb">
                  <svg width="20" height="20" fill="none" stroke="var(--color-text-muted)" viewBox="0 0 24 24" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                </div>
                <div>
                  <div class="cap-item-name">Vintage Leather Jacket</div>
                  <div class="cap-item-meta">Fashion · Size M · Good condition</div>
                </div>
                <div class="cap-confidence">
                  <span class="cap-confidence-val">92%</span>
                  <span class="cap-confidence-lbl">Match</span>
                </div>
              </div>
              <div class="cap-prices">
                <div class="cap-price-card">
                  <span class="cap-price-label">Shop Floor</span>
                  <span class="cap-price-val">£35</span>
                </div>
                <div class="cap-price-card cap-price-hl">
                  <span class="cap-price-label">eBay</span>
                  <span class="cap-price-val">£85</span>
                  <span class="cap-price-rec">Recommended</span>
                </div>
                <div class="cap-price-card">
                  <span class="cap-price-label">Vinted</span>
                  <span class="cap-price-val">£72</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Floating mini cards -->
          <div class="cap-float cap-float-tr">
            <div class="cap-mini-card">
              <span class="cap-mini-icon cap-mini-matcha">✓</span>
              <span>Listed on eBay</span>
            </div>
          </div>
          <div class="cap-float cap-float-bl">
            <div class="cap-mini-card">
              <span class="cap-mini-icon cap-mini-ai">
                <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span>AI processing &lt;2s</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Text content with feature highlights -->
      <div class="cap-content reveal reveal-delay-2">
        <div class="section-label">Intelligent resale</div>
        <h2 class="cap-title">Powerful AI that works<br>for every item.</h2>
        <p class="cap-body">Junkan's AI engine handles the expertise gap — instantly identifying items, researching comparable sales across marketplaces, and recommending the optimal sales channel and price point.</p>

        <div class="cap-features">
          <div class="cap-feature">
            <div class="cap-feature-icon cap-fi-ai">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
              <h4>Instant Identification</h4>
              <p>Brand, model, condition, and key attributes recognised from a single photo.</p>
            </div>
          </div>
          <div class="cap-feature">
            <div class="cap-feature-icon cap-fi-matcha">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
              <h4>Smart Routing</h4>
              <p>Each item automatically directed to its most profitable sales channel.</p>
            </div>
          </div>
