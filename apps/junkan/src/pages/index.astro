</style>

<script>
  // Enso reveal on load
  window.addEventListener('load', () => {
    setTimeout(() => {
      document.getElementById('heroEnso')?.classList.add('visible');
    }, 400);
    document.querySelectorAll('.hero .reveal').forEach(el => el.classList.add('visible'));
  });

  // Intersection Observer for scroll reveals
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // Pipeline animation
  function easeOutExpo(t: number): number {
    return t >= 1 ? 1 : 1 - Math.pow(2, -10 * t);
  }

  function lerpColor(a: string, b: string, t: number): string {
    const ah = parseInt(a.replace('#',''), 16);
    const bh = parseInt(b.replace('#',''), 16);
    const ar = (ah >> 16) & 0xff, ag = (ah >> 8) & 0xff, ab = ah & 0xff;
    const br = (bh >> 16) & 0xff, bg = (bh >> 8) & 0xff, bb = bh & 0xff;
    const rr = Math.round(ar + (br - ar) * t);
    const rg = Math.round(ag + (bg - ag) * t);
    const rb = Math.round(ab + (bb - ab) * t);
    return `rgb(${rr},${rg},${rb})`;
  }

  function initPipeline() {
    const pipeline = document.getElementById('pipeline');
    const svg = document.getElementById('pipelineSvg');
    const track = document.getElementById('pipelineTrack');
    const flow = document.getElementById('pipelineFlow');
    const glow = document.getElementById('pipelineGlow');
    const head = document.getElementById('pipelineHead');
    const headHalo = document.getElementById('pipelineHeadHalo');
    if (!pipeline || !svg) return;
    const circles = pipeline.querySelectorAll('.step-circle');
    if (circles.length < 2) return;

    const pipelineRect = pipeline.getBoundingClientRect();
    const centres = Array.from(circles).map(c => {
      const r = c.getBoundingClientRect();
      return {
        x: r.left + r.width / 2 - pipelineRect.left,
        y: r.top + r.height / 2 - pipelineRect.top
      };
    });

    const svgH = centres[0].y * 2 + 24;
    svg.setAttribute('viewBox', `0 0 ${pipelineRect.width} ${svgH}`);
    svg.style.height = svgH + 'px';
    svg.style.width = '100%';

    const y = centres[0].y;
    const x1 = centres[0].x;
    const x2 = centres[centres.length - 1].x;
    const lineLength = x2 - x1;

    track?.setAttribute('x1', String(x1));
    track?.setAttribute('y1', String(y));
    track?.setAttribute('x2', String(x2));
    track?.setAttribute('y2', String(y));

    [flow, glow, head, headHalo].forEach(el => {
      el?.setAttribute('x1', String(x1));
      el?.setAttribute('y1', String(y));
      el?.setAttribute('x2', String(x1));
      el?.setAttribute('y2', String(y));
    });

    const fractions = centres.map(c => (c.x - x1) / lineLength);
    const litState = new Array(circles.length).fill(false);

    const pipelineObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          pipelineObs.unobserve(entry.target);
          animatePipeline({ flow: flow!, glow: glow!, head: head!, headHalo: headHalo!, x1, x2, y, lineLength, circles, fractions, litState });
        }
      });
    }, { threshold: 0.25 });

    pipelineObs.observe(pipeline);
  }

  function animatePipeline({ flow, glow, head, headHalo, x1, x2, y, lineLength, circles, fractions, litState }: any) {
    const duration = 2200;
    const headLength = 60;
    let start: number | null = null;
    const aiBlue = '#4B7BE5';
    const matchaGreen = '#3DA66A';

    function tick(timestamp: number) {
      if (!start) start = timestamp;
      const elapsed = timestamp - start;
      const rawProgress = Math.min(elapsed / duration, 1);
      const progress = easeOutExpo(rawProgress);
      const currentX = x1 + lineLength * progress;

      flow.setAttribute('x2', String(currentX));
      glow.setAttribute('x2', String(currentX));

      const headStart = Math.max(x1, currentX - headLength);
      const headColor = lerpColor(aiBlue, matchaGreen, progress);

      head.setAttribute('x1', String(headStart));
      head.setAttribute('x2', String(currentX));
      head.setAttribute('y1', String(y));
      head.setAttribute('y2', String(y));
      head.setAttribute('stroke', headColor);

      headHalo.setAttribute('x1', String(headStart));
      headHalo.setAttribute('x2', String(currentX));
      headHalo.setAttribute('y1', String(y));
      headHalo.setAttribute('y2', String(y));
      headHalo.setAttribute('stroke', headColor);

      if (rawProgress >= 1) {
        head.style.transition = 'opacity 0.6s ease';
        head.style.opacity = '0';
        headHalo.style.transition = 'opacity 0.6s ease';
        headHalo.style.opacity = '0';
      }

      fractions.forEach((frac: number, i: number) => {
        if (!litState[i] && progress >= frac) {
          litState[i] = true;
          circles[i].classList.add('lit');
        }
      });

      if (rawProgress < 1) {
        requestAnimationFrame(tick);
      }
    }

    requestAnimationFrame(tick);
  }

  // Init after layout settles
  window.addEventListener('load', () => {
    requestAnimationFrame(() => {
      requestAnimationFrame(() => initPipeline());
    });
  });

  // Re-measure on resize
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      const pipeline = document.getElementById('pipeline');
      if (!pipeline) return;
      const circles = pipeline.querySelectorAll('.step-circle');
      circles.forEach(c => c.classList.remove('lit'));
      const head = document.getElementById('pipelineHead');
      const headHalo = document.getElementById('pipelineHeadHalo');
      [head, headHalo].forEach(el => {
        if (el instanceof HTMLElement || el instanceof SVGElement) {
          (el as any).style.transition = '';
          (el as any).style.opacity = '';
        }
      });
      initPipeline();
    }, 300);
  });
</script>
