    border-bottom: 1px solid var(--color-border-subtle);
  }
  .fc-body {
    padding: 10px;
  }
  .fc-body.fc-dark {
    background: #1a1a1a;
    border-radius: 0 0 11px 11px;
    padding: 0;
  }

  /* Dashboard float card */
  .fc-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
    margin-bottom: 6px;
  }
  .fc-stat {
    background: var(--color-background);
    border: 1px solid var(--color-border-subtle);
    border-radius: 4px;
    padding: 4px 6px;
    text-align: center;
  }
  .fc-stat-val {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 12px;
  }
  .fc-stat-lbl {
    display: block;
    font-size: 8px;
    color: var(--color-text-muted);
  }
  .fc-row {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 3px 0;
    font-size: 10px;
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .fc-row:last-child { border-bottom: none; }
  .fc-price {
    margin-left: auto;
    font-weight: 600;
  }

  /* Dots */
  .fc-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .fc-dot-matcha { background: var(--color-matcha); }
  .fc-dot-ai { background: var(--color-ai); }
  .fc-dot-shu { background: var(--color-shu); }

  /* AI ID float card */
  .fc-success {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 3px 6px;
    background: var(--color-matcha-muted);
    border-radius: 4px;
    font-size: 9px;
    font-weight: 500;
    margin-bottom: 6px;
  }
  .fc-check {
    color: var(--color-matcha);
    font-weight: 700;
    font-size: 10px;
  }
  .fc-item-name {
    font-weight: 600;
    font-size: 11px;
    margin-bottom: 4px;
  }
  .fc-tags {
    display: flex;
    gap: 3px;
    margin-bottom: 6px;
  }
  .fc-tags span {
    font-size: 8px;
    padding: 1px 4px;
    border-radius: 3px;
    background: var(--color-background);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
  }
  .fc-mp-grid {
    display: flex;
    gap: 3px;
  }
  .fc-mp {
    flex: 1;
    text-align: center;
    padding: 3px;
    border-radius: 3px;
    background: var(--color-background);
    font-size: 8px;
    color: var(--color-text-muted);
    line-height: 1.3;
  }
  .fc-mp strong { font-size: 10px; color: var(--color-text); }
  .fc-mp-hl {
    background: var(--color-ai-muted);
    color: var(--color-ai);
  }

  /* Analytics float card */
  .fc-kpi-row {
    display: flex;
    gap: 8px;
    margin-bottom: 6px;
  }
  .fc-kpi-val {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
  }
  .fc-kpi-lbl {
    display: block;
    font-size: 8px;
    color: var(--color-text-muted);
  }
  .fc-trend {
    color: var(--color-matcha);
    font-weight: 500;
  }
  .fc-chart {
    width: 100%;
    height: 35px;
  }

  /* Routing float card */
  .fc-route {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 4px 6px;
    border-radius: 4px;
    margin-bottom: 3px;
    font-size: 10px;
    border: 1px solid var(--color-border-subtle);
  }
  .fc-route-hl {
    background: var(--color-ai-muted);
    border-color: var(--color-ai);
  }
  .fc-rec {
    font-size: 7px;
    padding: 1px 4px;
    border-radius: 3px;
    background: var(--color-ai);
    color: #fff;
    font-weight: 600;
  }
  .fc-rprice {
    margin-left: auto;
    font-weight: 600;
    font-size: 10px;
  }
  .fc-profit {
    text-align: center;
    font-size: 9px;
    color: var(--color-matcha);
    padding: 3px;
    background: var(--color-matcha-muted);
    border-radius: 3px;
    margin-top: 2px;
  }

  /* Listing float card */
  .fc-listing-row {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 8px;
  }
  .fc-listing-thumb {
    width: 28px;
    height: 28px;
    border-radius: 4px;
    background: var(--color-border-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .fc-listing-name {
    font-weight: 500;
    font-size: 10px;
  }
  .fc-listing-price {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
  }
  .fc-pub-bar {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 4px 8px;
    background: var(--color-matcha-muted);
    border-radius: 4px;
    font-size: 9px;
    font-weight: 500;
    color: var(--color-matcha);
  }

  /* Photo capture float card */
  .fc-viewfinder {
    height: 80px;
    background: linear-gradient(135deg, #2a2a2a, #1a1a1a, #2a2a2a);
    position: relative;
  }
  .fc-vf-grid { position: absolute; inset: 0; }
  .fc-vf-h1, .fc-vf-h2, .fc-vf-v1, .fc-vf-v2 {
    position: absolute;
    background: rgba(255,255,255,0.08);
  }
  .fc-vf-h1 { top: 33%; left: 0; right: 0; height: 1px; }
  .fc-vf-h2 { top: 66%; left: 0; right: 0; height: 1px; }
  .fc-vf-v1 { left: 33%; top: 0; bottom: 0; width: 1px; }
  .fc-vf-v2 { left: 66%; top: 0; bottom: 0; width: 1px; }
  .fc-strip {
    display: flex;
    gap: 4px;
    padding: 6px 10px;
    background: #111;
    border-radius: 0 0 11px 11px;
  }
  .fc-strip-dot {
    width: 16px;
    height: 16px;
    border-radius: 3px;
  }
  .fc-sd-good { background: #3a3a3a; }
  .fc-sd-warn { background: #3a3a3a; border: 1px solid var(--color-shu); }
  .fc-sd-active { background: var(--color-ai); }

  /* ═══════════════════════════════════════════════════
     CAPABILITIES SECTION
     ═══════════════════════════════════════════════════ */
  .capabilities-section {
    padding: 120px 48px;
    position: relative;
    overflow: hidden;
  }
  .capabilities-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    max-width: 1200px;
    margin: 0 auto;
    align-items: center;
  }

  /* Left: Mockup visual */
  .cap-visual {
    position: relative;
  }
  .cap-mockup {
    position: relative;
    padding: 20px;
  }
  .cap-main-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    box-shadow: 0 16px 48px rgba(0,0,0,0.08), 0 4px 12px rgba(0,0,0,0.04);
    overflow: hidden;
  }
  .cap-card-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 18px;
    border-bottom: 1px solid var(--color-border);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
  }
  .cap-card-body {
    padding: 18px;
  }
  .cap-item-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }
  .cap-item-thumb {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--color-bg);
    border: 1px solid var(--color-border-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .cap-item-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
  }
  .cap-item-meta {
    font-size: 11px;
    color: var(--color-text-muted);
    margin-top: 2px;
  }
  .cap-confidence {
    margin-left: auto;
    text-align: center;
    flex-shrink: 0;
  }
  .cap-confidence-val {
    display: block;
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--color-matcha);
    letter-spacing: -0.02em;
  }
  .cap-confidence-lbl {
    display: block;
    font-size: 10px;
    color: var(--color-text-muted);
    font-weight: 500;
  }
  .cap-prices {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }
  .cap-price-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border-subtle);
    border-radius: 10px;
    padding: 10px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .cap-price-label {
    font-size: 10px;
    font-weight: 500;
    color: var(--color-text-muted);
  }
  .cap-price-val {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }
  .cap-price-hl {
    border-color: var(--color-ai);
    background: var(--color-ai-muted);
  }
  .cap-price-rec {
    font-size: 9px;
    font-weight: 600;
    color: var(--color-ai);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Floating mini cards */
  .cap-float {
    position: absolute;
    z-index: 3;
  }
  .cap-float-tr {
    top: 0;
    right: -10px;
    transform: rotate(2deg);
  }
  .cap-float-bl {
    bottom: 0;
    left: -10px;
    transform: rotate(-2deg);
  }
  .cap-mini-card {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 8px 14px;
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text);
    box-shadow: 0 6px 20px rgba(0,0,0,0.06);
    white-space: nowrap;
  }
  .cap-mini-icon {
    width: 22px;
    height: 22px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
  }
  .cap-mini-matcha {
    background: var(--color-matcha-muted);
    color: var(--color-matcha);
  }
  .cap-mini-ai {
    background: var(--color-ai-muted);
    color: var(--color-ai);
  }

  /* Right: Text content */
  .cap-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(28px, 3vw, 44px);
    line-height: 1.12;
    letter-spacing: -0.04em;
    color: var(--color-text);
    margin-bottom: 20px;
  }
  .cap-body {
    font-size: clamp(15px, 1.1vw, 17px);
    font-weight: 350;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin-bottom: 36px;
  }

  /* Feature list */
  .cap-features {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 40px;
  }
  .cap-feature {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .cap-feature-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .cap-fi-ai {
    background: var(--color-ai-muted);
    color: var(--color-ai);
  }
  .cap-fi-matcha {
    background: var(--color-matcha-muted);
    color: var(--color-matcha);
  }
  .cap-fi-shu {
    background: rgba(217, 90, 80, 0.08);
    color: var(--color-shu);
  }
  .cap-feature h4 {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 4px;
  }
  .cap-feature p {
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* Big stat */
  .cap-stat {
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border-subtle);
  }
  .cap-stat-value {
    font-family: var(--font-display);
    font-size: clamp(32px, 3vw, 48px);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--color-ai);
  }
  .cap-stat-label {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  /* ═══════════════════════════════════════════════════
     MANAGE & TRACK SECTION
     ═══════════════════════════════════════════════════ */
  .manage-section {
    padding: 120px 48px;
    background: var(--color-bg-deep, #ECEAE7);
    position: relative;
  }
  .manage-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    max-width: 1200px;
    margin: 0 auto;
    align-items: center;
  }
  .manage-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(28px, 3vw, 44px);
    line-height: 1.12;
    letter-spacing: -0.04em;
    color: var(--color-text);
    margin-bottom: 20px;
  }
  .manage-body {
    font-size: clamp(15px, 1.1vw, 17px);
    font-weight: 350;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin-bottom: 36px;
  }
  .manage-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .manage-feature {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .manage-feature-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .mf-icon-ai { background: var(--color-ai-muted); color: var(--color-ai); }
  .mf-icon-matcha { background: var(--color-matcha-muted); color: var(--color-matcha); }
  .mf-icon-shu { background: rgba(217, 90, 80, 0.08); color: var(--color-shu); }
  .manage-feature h4 {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 4px;
  }
  .manage-feature p {
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* 3D phone mockup images — grouped & overlapping */
  .manage-phones {
    position: relative;
    height: 520px;
    overflow: visible;
  }
  .manage-phone-img {
    position: absolute;
    height: auto;
    object-fit: contain;
  }
  .manage-phone-back {
    width: 90%;
    top: -10%;
    right: -25%;
    z-index: 1;
  }
  .manage-phone-front {
    width: 82%;
    top: -5%;
    left: -15%;
    z-index: 2;
  }

  /* ═══════════════════════════════════════════════════
     PROBLEM CARDS
     ═══════════════════════════════════════════════════ */
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .problem-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 32px;
    position: relative;
    overflow: hidden;
    transition: transform 0.4s var(--ease-out-expo), box-shadow 0.4s var(--ease-out-expo);
  }
  .problem-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
  }
  .problem-card::before {
    content: '';
    position: absolute;
    top: -40px;
    left: -40px;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    filter: blur(50px);
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
  }
  .problem-card:nth-child(1)::before { background: var(--color-shu); }
  .problem-card:nth-child(2)::before { background: var(--color-ai); }
  .problem-card:nth-child(3)::before { background: var(--color-matcha); }
  .problem-card.visible::before,
  .problem-card:hover::before { opacity: 0.07; }
  .problem-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 48px;
    height: 2px;
    border-radius: 0 0 2px 0;
    opacity: 0.5;
    transition: width 0.6s var(--ease-out-expo), opacity 0.4s ease;
  }
  .problem-card:nth-child(1)::after { background: var(--color-shu); }
  .problem-card:nth-child(2)::after { background: var(--color-ai); }
  .problem-card:nth-child(3)::after { background: var(--color-matcha); }
  .problem-card:hover::after { width: 100%; opacity: 0.35; }

  .problem-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    position: relative;
  }
  .problem-icon::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    opacity: 0.5;
    filter: blur(8px);
    z-index: 0;
  }
  .problem-icon svg { position: relative; z-index: 1; }
  .problem-icon-shu { background: rgba(217, 90, 80, 0.08); }
  .problem-icon-shu::before { background: rgba(217, 90, 80, 0.12); }
  .problem-icon-ai { background: rgba(75, 123, 229, 0.08); }
  .problem-icon-ai::before { background: rgba(75, 123, 229, 0.12); }
  .problem-icon-matcha { background: rgba(61, 166, 106, 0.08); }
  .problem-icon-matcha::before { background: rgba(61, 166, 106, 0.12); }

  .problem-card h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 18px;
    letter-spacing: -0.02em;
    margin-bottom: 10px;
  }
  .problem-card p {
    font-size: 14px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  /* ═══════════════════════════════════════════════════
     SOLUTION / STEPS
     ═══════════════════════════════════════════════════ */
  .solution-section {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border-subtle);
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .solution-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 48px;
  }
  .solution-header {
    margin-bottom: 80px;
  }

  .solution-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .solution-images {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .solution-images-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .solution-image-card {
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
    height: 200px;
  }
  .solution-image-wide {
    height: 240px;
  }
  .solution-image-card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .solution-steps {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  .solution-step {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }
  .step-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .step-icon-ai {
    color: var(--color-ai);
    background: var(--color-ai-muted);
    border: 1.5px solid var(--color-ai);
  }
  .step-icon-matcha {
    color: var(--color-matcha);
    background: var(--color-matcha-muted);
    border: 1.5px solid var(--color-matcha);
  }
  .step-icon-currency {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 20px;
    line-height: 1;
  }
  .step-text h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
    letter-spacing: -0.02em;
    margin-bottom: 6px;
    color: var(--color-text);
  }
  .step-text p {
    font-size: 15px;
    font-weight: 350;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  /* ═══════════════════════════════════════════════════
     BIG STAT
     ═══════════════════════════════════════════════════ */
  .stat-section {
    padding: 140px 48px;
    text-align: center;
    position: relative;
  }
  .stat-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(217, 90, 80, 0.03) 0%, transparent 70%);
    pointer-events: none;
  }
  .big-number {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(72px, 12vw, 160px);
    line-height: 1;
    letter-spacing: -0.05em;
    color: var(--color-text);
    position: relative;
  }
  .big-number-unit {
    font-size: 0.35em;
    font-weight: 600;
    color: var(--color-text-muted);
    vertical-align: top;
    margin-left: 4px;
