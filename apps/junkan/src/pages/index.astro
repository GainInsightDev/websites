  /* ═══════════════════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════════════════ */
  @media (max-width: 900px) {
    .hero { padding: 100px 24px 60px; }
    .problem-grid,
    .segments-grid { grid-template-columns: 1fr; }
