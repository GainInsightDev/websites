---
import Layout from '../layouts/Layout.astro';
import { fetchOne } from '../lib/sanity';

const contactPage = await fetchOne('contactPage');

const heroTitle = contactPage?.heroTitle || 'Get in Touch';
const heroSubtitle = contactPage?.heroSubtitle || 'Interested in Junkan? We\'d love to hear from you. Request a demo or ask us anything.';
const email = contactPage?.email || 'hello@junkan.ai';
const phone = contactPage?.phone || '';
const location = contactPage?.location || 'United Kingdom';
---

<Layout
  title="Contact | Junkan"
  description="Get in touch with the Junkan team. Request a demo of our AI-powered circular retail intelligence platform."
>
  <!-- Hero -->
  <section class="hero-section bg-text text-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-semibold mb-6">
          {heroTitle}
        </h1>
        <p class="text-lg text-white/80 leading-relaxed max-w-2xl mx-auto">
          {heroSubtitle}
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="section">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-12 max-w-4xl mx-auto">
        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-semibold mb-6">Request a Demo</h2>
          <form class="space-y-5" action="https://api.web3forms.com/submit" method="POST" id="contact-form">
            <input type="hidden" name="access_key" value="e16ca85f-40fa-4eb3-8c65-f1e09b381074" />
            <input type="hidden" name="subject" value="New Contact Form Submission — junkan.ai" />
            <input type="hidden" name="from_name" value="Junkan Website" />
            <!-- Honeypot spam protection -->
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
            <div>
              <label for="name" class="block text-sm font-medium mb-2">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full h-12 px-4 border border-border rounded-lg bg-surface text-text placeholder:text-text-muted focus:border-ai focus:outline-none transition-colors"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium mb-2">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full h-12 px-4 border border-border rounded-lg bg-surface text-text placeholder:text-text-muted focus:border-ai focus:outline-none transition-colors"
                placeholder="you@organisation.org"
              />
            </div>
            <div>
              <label for="organisation" class="block text-sm font-medium mb-2">Organisation</label>
              <input
                type="text"
                id="organisation"
                name="organisation"
                class="w-full h-12 px-4 border border-border rounded-lg bg-surface text-text placeholder:text-text-muted focus:border-ai focus:outline-none transition-colors"
                placeholder="Your charity or organisation"
              />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium mb-2">Message</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                class="w-full px-4 py-3 border border-border rounded-lg bg-surface text-text placeholder:text-text-muted focus:border-ai focus:outline-none transition-colors resize-y"
                placeholder="Tell us about your needs..."
              ></textarea>
            </div>
            <button type="submit" class="btn btn-primary w-full">
              Send Message
            </button>
          </form>
          <!-- Success message -->
          <div id="form-success" class="hidden text-center py-8">
            <div class="text-matcha text-xl font-semibold mb-2">Message Sent!</div>
            <p class="text-text-muted">Thank you for reaching out. We'll get back to you shortly.</p>
          </div>
        </div>

        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-semibold mb-6">Contact Information</h2>
          <div class="space-y-6">
            <div class="card">
              <h3 class="text-sm font-medium text-text-muted mb-1">Email</h3>
              <a href={`mailto:${email}`} class="text-ai hover:underline">{email}</a>
            </div>

            {phone && (
              <div class="card">
                <h3 class="text-sm font-medium text-text-muted mb-1">Phone</h3>
                <a href={`tel:${phone}`} class="text-ai hover:underline">{phone}</a>
              </div>
            )}

            <div class="card">
              <h3 class="text-sm font-medium text-text-muted mb-1">Location</h3>
              <p>{location}</p>
            </div>

            <div class="card bg-ai-muted border-ai/20">
              <h3 class="text-sm font-medium mb-2">Why Junkan?</h3>
              <ul class="space-y-2 text-sm text-text-muted">
                <li class="flex items-start gap-2">
                  <span class="text-ai mt-0.5">&#10003;</span>
                  <span>Process donations faster with AI assistance</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-ai mt-0.5">&#10003;</span>
                  <span>Maximise revenue across all marketplaces</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-ai mt-0.5">&#10003;</span>
                  <span>Data-driven pricing for every item</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-ai mt-0.5">&#10003;</span>
                  <span>Built specifically for charity retail</span>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successDiv = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'Sending...';
    submitBtn.disabled = true;

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
      });

      if (response.ok) {
        form.style.display = 'none';
        if (successDiv) successDiv.classList.remove('hidden');
        form.reset();
      } else {
        submitBtn.textContent = 'Something went wrong. Try again.';
        submitBtn.disabled = false;
        setTimeout(() => {
          submitBtn.textContent = originalText;
        }, 3000);
      }
    } catch {
      submitBtn.textContent = 'Something went wrong. Try again.';
      submitBtn.disabled = false;
      setTimeout(() => {
        submitBtn.textContent = originalText;
      }, 3000);
    }
  });
</script>
