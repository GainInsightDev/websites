---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Terms of Use | Gain Insight" description="Terms governing use of the Gain Insight website.">
  <section class="hero-section section-light">
    <div class="container">
      <h1 class="text-[40px] md:text-[48px] text-text-dark leading-[1.1] mb-6">
        Terms of Use
      </h1>
      <p class="text-[14px] text-text-light font-light">Last updated: March 2026</p>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container max-w-[720px]">
      <div class="prose">
        <h2 class="text-[24px] text-text leading-[1.2] mb-4">Introduction</h2>
        <p class="text-[15px] text-text-muted leading-relaxed mb-8 font-light">
          These terms govern your use of the Gain Insight website (gaininsight.ai). By accessing this website, you agree to be bound by these terms. If you do not agree, please do not use the website.
        </p>

        <h2 class="text-[24px] text-text leading-[1.2] mb-4">Use of this website</h2>
        <p class="text-[15px] text-text-muted leading-relaxed mb-8 font-light">
          This website is provided for general information about Gain Insight and our portfolio of ventures. The content is provided "as is" without any warranties, express or implied.
        </p>

        <h2 class="text-[24px] text-text leading-[1.2] mb-4">Intellectual property</h2>
        <p class="text-[15px] text-text-muted leading-relaxed mb-8 font-light">
          All content on this website — including text, design, logos, and layout — is the property of Gain Insight Analytics Ltd and is protected by applicable intellectual property laws. You may not reproduce, distribute, or create derivative works without our written permission.
        </p>

        <h2 class="text-[24px] text-text leading-[1.2] mb-4">Third-party links</h2>
        <p class="text-[15px] text-text-muted leading-relaxed mb-8 font-light">
          This website may contain links to external websites operated by our portfolio ventures or partners. We are not responsible for the content or privacy practices of those sites.
        </p>

        <h2 class="text-[24px] text-text leading-[1.2] mb-4">Limitation of liability</h2>
        <p class="text-[15px] text-text-muted leading-relaxed mb-8 font-light">
          To the fullest extent permitted by law, Gain Insight Analytics Ltd shall not be liable for any direct, indirect, or consequential damages arising from your use of this website.
        </p>

        <h2 class="text-[24px] text-text leading-[1.2] mb-4">Governing law</h2>
        <p class="text-[15px] text-text-muted leading-relaxed mb-8 font-light">
          These terms are governed by the laws of Gibraltar. Any disputes arising from the use of this website shall be subject to the exclusive jurisdiction of the courts of Gibraltar.
        </p>

        <h2 class="text-[24px] text-text leading-[1.2] mb-4">Contact</h2>
        <p class="text-[15px] text-text-muted leading-relaxed font-light">
          For any questions regarding these terms, please contact us at <a href="mailto:hello@gaininsight.global" class="text-steel hover:text-text transition-colors">hello@gaininsight.global</a>.
        </p>
      </div>
    </div>
  </section>
</Layout>
