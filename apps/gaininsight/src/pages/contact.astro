---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Gain Insight" description="Get in touch with Gain Insight.">
  <!-- Hero -->
  <section class="hero-section section-light">
    <div class="container">
      <div class="section-label text-text-light">
        <span>Contact</span>
      </div>
      <h1 class="text-[48px] md:text-[64px] text-text-dark leading-[1.05] mb-6">
        Get <em>in touch.</em>
      </h1>
      <p class="text-[18px] text-text-light leading-relaxed max-w-[560px] font-light">
        If you have domain expertise and an idea worth building, we'd like to hear from you.
      </p>
    </div>
  </section>

  <!-- Contact details — dark -->
  <section class="section section-dark">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
        <div>
          <h2 class="text-[32px] md:text-[40px] text-text leading-[1.1] mb-6">
            Start a <em>conversation.</em>
          </h2>
          <p class="text-[16px] text-text-muted leading-relaxed mb-8 font-light">
            Whether you're looking to enhance an existing business with AI or launch something entirely new, the first step is a conversation. Tell us about your domain, your challenge, and what you want to build.
          </p>
          <div class="flex flex-col gap-6">
            <div>
              <h3 class="text-[10px] font-semibold text-text-muted uppercase tracking-[0.12em] mb-2 font-body">Email</h3>
              <a href="mailto:hello@gaininsight.global" class="text-[16px] text-steel hover:text-text transition-colors font-body">hello@gaininsight.global</a>
            </div>
            <div>
              <h3 class="text-[10px] font-semibold text-text-muted uppercase tracking-[0.12em] mb-2 font-body">Location</h3>
              <p class="text-[14px] text-text-muted font-light">Gibraltar &middot; United Kingdom</p>
            </div>
          </div>
        </div>

        <!-- Placeholder for future form -->
        <div class="card flex flex-col items-center justify-center min-h-[300px] text-center">
          <p class="text-[14px] text-text-muted mb-4 font-body">Drop us an email to get started.</p>
          <a href="mailto:hello@gaininsight.global" class="btn btn-steel">Email us</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
