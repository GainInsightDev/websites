---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found | Gain Insight">
  <section class="section-lg section-dark text-center">
    <div class="container">
      <h1 class="text-[56px] text-text leading-[1.1] mb-6">404</h1>
      <p class="text-[16px] text-text-muted mb-10 font-light">This page doesn't exist.</p>
      <a href="/" class="btn btn-steel">Back to home</a>
    </div>
  </section>
</Layout>
