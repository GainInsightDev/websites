---
import Layout from '../../layouts/Layout.astro';
import { fetchAll, fetchBySlug } from '../../lib/sanity';
import { ventureLogoRaw, hiddenSlugs, projectOverrides, wideLogoSlugs } from '../../lib/venture-logos';

interface Capability {
  title: string;
  description: string;
}

interface Result {
  title: string;
  description: string;
}

interface Project {
  name: string;
  slug: { current: string };
  tagline: string;
  description: string;
  domain: string;
  accent: string;
  url?: string;
  caseStudyUrl?: string;
}

export async function getStaticPaths() {
  const projects = await fetchAll<Project>('project');
  return projects.map((p) => ({
    params: { slug: p.slug.current },
  }));
}

const { slug } = Astro.params;
const project = await fetchBySlug<Project>('project', slug!);

if (!project) {
  return Astro.redirect('/404');
}

// Apply display overrides (e.g. Helm → Juncta)
const override = projectOverrides[slug!];
const displayName = override?.name ?? project.name;
const displaySlug = override?.displaySlug ?? slug!;
const displayDomain = override?.domain ?? project.domain;
const displayTagline = override?.tagline ?? project.tagline;

// Get related projects (other visible projects, max 3)
const allProjects = await fetchAll<Project>('project');
const related = allProjects
  .filter(p => p.slug.current !== slug && !hiddenSlugs.has(p.slug.current))
  .map(p => {
    const override = projectOverrides[p.slug.current];
    if (override) {
      return { ...p, name: override.name, displaySlug: override.displaySlug, tagline: override.tagline, domain: override.domain };
    }
    return { ...p, displaySlug: p.slug.current };
  })
  .slice(0, 3);

// Project-specific content (will migrate to Sanity once schema is deployed)
const projectContent: Record<string, {
  overviewHeading: string;
  overview: string[];
  capabilitiesLabel?: string;
  capabilitiesHeading?: string;
  capabilities: Capability[];
  results?: Result[];
  caseStudyUrl?: string;
}> = {
  indigo: {
    overviewHeading: 'Legacy system transformation through <em>AI-powered modernisation.</em>',
    overview: [
      'Indigo Capital Partners trades over $30 billion in positions annually across 100+ banking relationships. Their core trading platform had become an opaque legacy system — built on obsolete form-based technology and unmaintained PHP applications — that no one fully understood or could maintain.',
      'The system\'s complexity had created a dangerous operational dependency on manual offshore data entry, and left the organisation unable to extract meaningful insights from their own data. Traditional modernisation approaches — big-bang replacement, lift-and-shift, or manual refactoring — all posed unacceptable risks.',
      'Gain Insight delivered a comprehensive transformation using AI-powered system archaeology, behaviour-driven development, and incremental modernisation. We deconstructed the legacy application, achieved complete intellectual ownership of its functionality, and rebuilt it as a modern service-based architecture on AWS — all while maintaining 100% functional equivalence.',
    ],
    capabilitiesLabel: 'Our Approach',
    capabilitiesHeading: 'How we <em>delivered.</em>',
    capabilities: [
      { title: 'System archaeology', description: 'AI-powered analysis deconstructed the entire technology stack — extracting business logic, mapping data flows, and documenting all process flows from an opaque legacy codebase.' },
      { title: 'Executable specifications', description: 'Comprehensive BDD test suite achieving 100% code coverage. Every business rule, edge case, and data transformation captured as executable proof of understanding.' },
      { title: 'Incremental migration', description: 'Service-by-service reconstruction and deployment — no big-bang cutover. Each component validated against the test suite before going live.' },
      { title: 'Modern architecture', description: 'Rebuilt on AWS with Next.js, TypeScript, and service-based design. Auto-scaling, managed services, and API-first architecture enabling future integration.' },
    ],
    results: [
      { title: 'Eliminated legacy dependency', description: 'Removed reliance on unmaintainable legacy code and manual offshore data entry processes that had become an existential operational risk.' },
      { title: '100% test coverage', description: 'Complete BDD test suite providing mathematical certainty of functional equivalence between legacy and modernised systems.' },
      { title: 'Modern AWS platform', description: 'State-of-the-art infrastructure with auto-scaling, redundancy, and comprehensive observability — built for growth.' },
      { title: 'Full transparency', description: 'From opaque black box to comprehensively documented, fully understood system. Business logic visible and modifiable for the first time in years.' },
    ],
    caseStudyUrl: '/projects/indigo/case-study',
  },
};

const content = projectContent[slug!];

// Fallback capabilities for projects without specific content
const defaultCapabilities: Capability[] = [
  { title: 'Intelligent automation', description: 'Advanced algorithms process complex data in real-time, reducing manual intervention and eliminating human error across critical workflows.' },
  { title: 'Domain-specific AI', description: 'Purpose-built models trained on industry data deliver insights that generic tools cannot — understanding the nuances of each sector.' },
  { title: 'Enterprise integration', description: 'Designed to work with existing systems and data sources. No rip-and-replace — we enhance what is already there.' },
  { title: 'Continuous improvement', description: 'The platform learns from every interaction, refining its accuracy and expanding its capabilities over time.' },
];

const capabilities = content?.capabilities ?? defaultCapabilities;
const capabilitiesLabel = content?.capabilitiesLabel ?? 'Capabilities';
const capabilitiesHeading = content?.capabilitiesHeading ?? `What <em>${displayName} does.</em>`;
const results = content?.results;
const overviewParagraphs = content?.overview ?? [project.description];
const overviewHeading = content?.overviewHeading ?? 'The <em>problem</em> and our <em>approach.</em>';
const caseStudyLink = content?.caseStudyUrl ?? project.caseStudyUrl;
---

<Layout title={`${displayName} | Gain Insight`} description={displayTagline}>
  <!-- Hero — white, split layout: description left, logo right -->
  <section class="detail-hero section-light">
    <div class="container">
      <a href="/projects" class="detail-back-link">Back to Projects</a>
      <div class="detail-hero-split">
        <div class="detail-hero-content">
          <h1 class="detail-hero-title">{displayName}</h1>
          <div class="detail-hero-meta">
            <span class="tag">{displayDomain}</span>
            {project.url && (
              <a href={project.url} target="_blank" rel="noopener noreferrer" class="detail-hero-visit">
                Visit {displayName} &rarr;
              </a>
            )}
            {caseStudyLink && (
              <a href={caseStudyLink} class="detail-hero-visit">
                Read the case study &rarr;
              </a>
            )}
          </div>
          <p class="detail-hero-tagline">
            {displayTagline}
          </p>
        </div>
        {ventureLogoRaw[displaySlug] && (
          <div class="detail-hero-logo-stage">
            <img
              src={ventureLogoRaw[displaySlug]}
              alt={`${displayName} logo`}
              width="400"
              height="160"
              class="detail-hero-logo"
            />
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Overview — dark -->
  <section class="section section-dark">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
        <div class="reveal">
          <div class="section-label text-text-muted">
            <span>Overview</span>
          </div>
          <h2 class="text-[32px] md:text-[40px] text-text leading-[1.1] mb-6" set:html={overviewHeading} />
        </div>
        <div class="flex flex-col gap-6 reveal">
          {overviewParagraphs.map((p) => (
            <p class="text-[16px] text-text-muted leading-relaxed font-light">{p}</p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities — surface -->
  <section class="section section-surface">
    <div class="container">
      <div class="section-label text-text-muted reveal">
        <span>{capabilitiesLabel}</span>
      </div>
      <h2 class="text-[32px] md:text-[40px] text-text leading-[1.1] mb-12 reveal" set:html={capabilitiesHeading} />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 reveal-stagger">
        {capabilities.map((cap) => (
          <div class="card reveal">
            <h3 class="text-[16px] font-medium text-text mb-3 font-body">{cap.title}</h3>
            <p class="text-[14px] text-text-muted leading-relaxed font-light">{cap.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Results — dark (only if results exist) -->
  {results && (
    <section class="section section-dark">
      <div class="container">
        <div class="section-label text-text-muted reveal">
          <span>Results</span>
        </div>
        <h2 class="text-[32px] md:text-[40px] text-text leading-[1.1] mb-12 reveal">
          What we <em>delivered.</em>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 reveal-stagger">
          {results.map((r) => (
            <div class="card reveal">
              <h3 class="text-[16px] font-medium text-text mb-3 font-body">{r.title}</h3>
              <p class="text-[14px] text-text-muted leading-relaxed font-light">{r.description}</p>
            </div>
          ))}
        </div>
        {caseStudyLink && (
          <div class="mt-12 text-center">
            <a href={caseStudyLink} class="btn btn-steel">Read the full case study &rarr;</a>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Related Projects -->
  <section class={`section ${results ? 'section-surface' : 'section-dark'}`}>
    <div class="container">
      <div class="section-label text-text-muted reveal">
        <span>Portfolio</span>
      </div>
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-4 reveal">
        <h2 class="text-[32px] md:text-[40px] text-text leading-[1.1]">
          More <em>projects.</em>
        </h2>
        <a href="/projects" class="text-[13px] text-steel hover:text-text transition-colors font-body">View all projects &rarr;</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 reveal-stagger">
        {related.map((p) => (
          <a href={`/projects/${p.slug.current}`} class="project-card group block reveal">
            <div class="project-card-logo-stage">
              {ventureLogoRaw[p.displaySlug] ? (
                <img src={ventureLogoRaw[p.displaySlug]} alt={`${p.name} logo`} width="200" height="80" class={`project-card-logo${wideLogoSlugs.has(p.displaySlug) ? ' logo-wide' : ''}`} loading="lazy" />
              ) : (
                <span class="project-card-wordmark">{p.name}</span>
              )}
            </div>
            <div class="project-card-body">
              {!ventureLogoRaw[p.displaySlug] && (
                <h3 class="project-card-title">{p.name}</h3>
              )}
              <p class="project-card-tagline">{p.tagline}</p>
              <div class="project-card-meta">
                <span class="tag">{p.domain}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA — offwhite -->
  <section class="section section-offwhite text-center">
    <div class="container reveal">
      <h2 class="text-[40px] md:text-[48px] text-text-dark leading-[1.1] mb-6">
        Interested in <em>this project?</em>
      </h2>
      <p class="text-[16px] text-text-light leading-relaxed max-w-[420px] mx-auto mb-10 font-light">
        If you'd like to know more about {displayName} or explore a similar partnership, get in touch.
      </p>
      <a href="/contact" class="btn btn-steel">Get in touch</a>
    </div>
  </section>
</Layout>
