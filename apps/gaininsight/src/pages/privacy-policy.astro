---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy Policy | Gain Insight" description="How Gain Insight handles your data.">
  <section class="hero-section section-light">
    <div class="container">
      <h1 class="text-[40px] md:text-[48px] text-text-dark leading-[1.1] mb-6">
        Privacy Policy
      </h1>
      <p class="text-[14px] text-text-light font-light">Last updated: March 2026</p>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container max-w-[720px]">
      <div class="prose">
        <h2 class="text-[24px] text-text leading-[1.2] mb-4">Who we are</h2>
        <p class="text-[15px] text-text-muted leading-relaxed mb-8 font-light">
          Gain Insight Analytics Ltd is a company registered in Gibraltar (Company Number 124646). Our website address is gaininsight.ai.
        </p>

        <h2 class="text-[24px] text-text leading-[1.2] mb-4">What data we collect</h2>
        <p class="text-[15px] text-text-muted leading-relaxed mb-4 font-light">
          When you contact us via email, we collect the information you provide — typically your name, email address, and the content of your message.
        </p>
        <p class="text-[15px] text-text-muted leading-relaxed mb-8 font-light">
          We do not use cookies for tracking or analytics. We do not use any third-party analytics services.
        </p>

        <h2 class="text-[24px] text-text leading-[1.2] mb-4">How we use your data</h2>
        <p class="text-[15px] text-text-muted leading-relaxed mb-8 font-light">
          We use the information you provide solely to respond to your enquiry and, if relevant, to discuss potential partnership opportunities. We will not share your information with third parties without your consent.
        </p>

        <h2 class="text-[24px] text-text leading-[1.2] mb-4">Data retention</h2>
        <p class="text-[15px] text-text-muted leading-relaxed mb-8 font-light">
          We retain your contact information for as long as is necessary to maintain our business relationship or respond to your enquiry. You may request deletion of your data at any time by emailing hello@gaininsight.global.
        </p>

        <h2 class="text-[24px] text-text leading-[1.2] mb-4">Your rights</h2>
        <p class="text-[15px] text-text-muted leading-relaxed mb-8 font-light">
          You have the right to access, correct, or delete your personal data. You may also withdraw consent for us to contact you at any time. To exercise these rights, please email hello@gaininsight.global.
        </p>

        <h2 class="text-[24px] text-text leading-[1.2] mb-4">Contact</h2>
        <p class="text-[15px] text-text-muted leading-relaxed font-light">
          For any questions regarding this privacy policy, please contact us at <a href="mailto:hello@gaininsight.global" class="text-steel hover:text-text transition-colors">hello@gaininsight.global</a>.
        </p>
      </div>
    </div>
  </section>
</Layout>
