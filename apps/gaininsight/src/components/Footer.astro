---
// Gain Insight footer — dark background
---

<footer class="section-dark border-t border-border">
  <div class="container py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Wordmark -->
      <div>
        <div class="mb-6">
          <div class="whitespace-nowrap">
            <span class="font-display font-bold text-[48px] text-text leading-none">G</span><span class="font-display font-bold text-[48px] text-steel leading-none">AI</span><span class="font-display font-bold text-[48px] text-text leading-none">N</span>
          </div>
          <div class="h-[1px] bg-border-subtle my-[2px]"></div>
          <div class="flex justify-between" style="max-width: 95px;">
            <span class="font-display font-bold text-[15px] text-text leading-none">I</span>
            <span class="font-display font-bold text-[15px] text-text leading-none">N</span>
            <span class="font-display font-bold text-[15px] text-text leading-none">S</span>
            <span class="font-display font-bold text-[15px] text-text leading-none">I</span>
            <span class="font-display font-bold text-[15px] text-text leading-none">G</span>
            <span class="font-display font-bold text-[15px] text-text leading-none">H</span>
            <span class="font-display font-bold text-[15px] text-text leading-none">T</span>
          </div>
        </div>
        <p class="text-[13px] text-text-muted leading-relaxed max-w-[280px]">
          We work with domain experts to build AI-first products and services.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-[10px] font-semibold text-text-muted uppercase tracking-[0.12em] mb-4 font-body">Navigation</h4>
        <nav class="flex flex-col gap-3" aria-label="Footer navigation">
          <a href="/projects" class="text-[14px] text-text-muted hover:text-text transition-colors font-body">Projects</a>
          <a href="/partners" class="text-[14px] text-text-muted hover:text-text transition-colors font-body">Partners</a>
          <a href="/approach" class="text-[14px] text-text-muted hover:text-text transition-colors font-body">Approach</a>
          <a href="/contact" class="text-[14px] text-text-muted hover:text-text transition-colors font-body">Contact</a>
        </nav>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-[10px] font-semibold text-text-muted uppercase tracking-[0.12em] mb-4 font-body">Contact</h4>
        <a href="mailto:hello@gaininsight.global" class="text-[14px] text-steel hover:text-text transition-colors font-body">hello@gaininsight.global</a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-6 border-t border-border flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <p class="text-[11px] text-text-muted font-body">
        &copy; {new Date().getFullYear()} Gain Insight Analytics Ltd. Gibraltar Company 124646.
      </p>
      <div class="flex gap-6">
        <a href="/privacy-policy" class="text-[11px] text-text-muted hover:text-text transition-colors font-body">Privacy Policy</a>
        <a href="/terms" class="text-[11px] text-text-muted hover:text-text transition-colors font-body">Terms</a>
      </div>
    </div>
  </div>
</footer>
