---
import Logo from './Logo.astro';
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <!-- Main CTA area -->
  <div class="footer-main">
    <div class="footer-logo-large">
      <Logo size={48} />
      <span class="footer-wordmark-large">JUNCTA</span>
    </div>
    <div class="footer-tagline">AI proposes. Humans decide.</div>
    <p class="footer-body">
      Juncta is in early development. If you're a PM, founder, or team lead who wants to manage projects through conversation — we'd like to hear from you.
    </p>
    <a href="/contact" class="btn btn-cta">Request early access</a>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="footer-brand">
      <Logo size={20} color="#8B8A85" />
      <span class="footer-wordmark-small">JUNCTA</span>
    </div>
    <div class="footer-etymology">From Latin <em>jungere</em> — to join, to connect</div>
    <div class="footer-copy">&copy; {currentYear}</div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-slate-dark);
  }
  .footer-main {
    padding: 80px 64px;
    text-align: center;
  }
  .footer-logo-large {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    margin-bottom: 24px;
  }
  .footer-wordmark-large {
    font-family: var(--font-mono);
    font-size: 32px;
    color: var(--color-near-white);
    letter-spacing: 4px;
  }
  .footer-tagline {
    font-weight: 700;
    font-size: 24px;
    color: var(--color-warm-stone);
    margin-bottom: 12px;
  }
  .footer-body {
    font-size: 15px;
    color: var(--color-stone);
    max-width: 480px;
    margin: 0 auto 32px;
    line-height: 1.6;
  }
  .btn-cta {
    display: inline-block;
    font-weight: 700;
    font-size: 14px;
    color: var(--color-slate-dark);
    background-color: var(--color-near-white);
    padding: 14px 36px;
    text-decoration: none;
    cursor: pointer;
  }
  .btn-cta:hover {
    background-color: var(--color-surface);
  }
  .footer-bottom {
    margin-top: 64px;
    padding: 32px 64px;
    border-top: 1px solid var(--color-slate-mid);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .footer-wordmark-small {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-stone);
    letter-spacing: 2px;
  }
  .footer-etymology {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-stone);
  }
  .footer-etymology em {
    font-style: italic;
  }
  .footer-copy {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-stone);
  }

  @media (max-width: 900px) {
    .footer-main { padding: 60px 24px; }
    .footer-bottom {
      padding: 24px;
      flex-direction: column;
      gap: 12px;
    }
  }
</style>
