---
const columns = [
  { time: 'Week 1', items: ['Your current project', 'Key deadlines', 'Team members'] },
  { time: 'Week 2', items: ['How you work', 'Communication style', 'Estimation patterns'] },
  { time: 'Week 4', items: ['Vendor relationships', 'Approval processes', 'Team dynamics'] },
  { time: 'Week 8', items: ['Organisational memory', 'Cross-project patterns', 'Institutional knowledge'] },
];
---

<section class="memory-section" id="memory">
  <div class="memory-inner">
    <div class="section-label" style="color: var(--color-accent);">07 — GETS SMARTER OVER TIME</div>
    <h2 class="memory-title">
      After a month, Juncta knows things no new hire ever could.
    </h2>
    <p class="memory-body">
      Every conversation, every project, every interaction makes it more valuable. Knowledge that accumulates and compounds.
    </p>

    <div class="memory-chart reveal">
      {columns.map((col, i) => (
        <div class="memory-col">
          <div class="memory-bar" style={`height: ${120 + i * 60}px;`}>
            {col.items.map(item => (
              <div class="memory-item">{item}</div>
            ))}
          </div>
          <div class="memory-time">{col.time}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .memory-section {
    padding: 120px 64px;
    background-color: var(--color-slate-dark);
  }
  .memory-inner {
    max-width: 1000px;
    margin: 0 auto;
    text-align: center;
  }
  .memory-title {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: clamp(32px, 4vw, 44px);
    line-height: 1.1;
    color: var(--color-near-white);
    margin: 0 auto 24px;
    max-width: 640px;
  }
  .memory-body {
    font-size: 16px;
    color: var(--color-stone);
    line-height: 1.7;
    max-width: 520px;
    margin: 0 auto 56px;
  }
  .memory-chart {
    display: flex;
    gap: 0;
    justify-content: center;
  }
  .memory-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .memory-bar {
    width: 100%;
    background: linear-gradient(to bottom, rgba(201, 74, 30, 0.15), rgba(201, 74, 30, 0.05));
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 12px 16px;
    border-left: 1px solid var(--color-slate-mid);
  }
  .memory-col:first-child .memory-bar {
    border-left: none;
  }
  .memory-item {
    font-size: 11px;
    color: var(--color-warm-stone);
    line-height: 1.8;
  }
  .memory-time {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-stone);
    margin-top: 12px;
    letter-spacing: 0.5px;
  }

  @media (max-width: 900px) {
    .memory-section { padding: 80px 24px; }
  }
</style>
