---
import Logo from './Logo.astro';
---

<section class="hero grid-bg" id="hero">
  <!-- Hero content -->
  <div class="hero-content">
    <div class="hero-brand">
      <Logo size={100} />
      <div class="hero-wordmark">JUNCTA</div>
    </div>
    <div class="hero-tagline">AI PROJECT MANAGEMENT</div>
    <h1 class="hero-title">
      You don't manage<br>projects <em>in</em> Juncta.<br>You manage them <em>with</em> it.
    </h1>
    <p class="hero-body">
      An AI that takes on the cognitive work of planning, organising, and managing — so you can focus on judgment, relationships, and decisions.
    </p>
    <div class="hero-actions">
      <a href="/contact" class="btn btn-primary">Request early access</a>
      <a href="/#shift" class="btn btn-secondary">Read the vision</a>
    </div>
  </div>

  <!-- Chat preview -->
  <div class="chat-preview">
    <div class="chat-breadcrumb">
      <span class="chat-crumb">Programme</span>
      <span class="chat-sep">›</span>
      <span class="chat-crumb">Property</span>
      <span class="chat-sep">›</span>
      <span class="chat-crumb-active">Lease Negotiation</span>
    </div>
    <div class="chat-messages">
      <div class="chat-msg-ai">
        <div class="chat-sender">
          <span class="chat-sender-name">juncta</span>
          <span class="chat-sender-time">2 min ago</span>
        </div>
        <div class="chat-bubble chat-bubble-ai">
          The <span class="entity-ref">Heads of Terms</span> is due in 3 days. James updated <span class="entity-ref">Draft Lease</span> — solicitor reviewed with minor amendments.
          <div class="chat-action">Approve this update?</div>
        </div>
      </div>
      <div class="chat-msg-user">
        <div class="chat-bubble chat-bubble-user">
          <span id="typed-text"></span><span class="cursor"></span>
        </div>
      </div>
      <div class="chat-msg-ai">
        <div class="chat-sender">
          <span class="chat-sender-name">juncta</span>
          <span class="chat-sender-time">just now</span>
        </div>
        <div class="chat-bubble chat-bubble-ai">
          Done. <span class="entity-ref">Draft Lease</span> updated to 85%. Created <span class="entity-ref">Review Break Clause</span> and assigned to you.
        </div>
      </div>
    </div>
    <div class="chat-input-wrap">
      <div class="chat-input">Ask Juncta about this scope...</div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 80px 64px;
    position: relative;
    overflow: hidden;
    gap: 48px;
  }
  .hero-content {
    max-width: 720px;
    padding-top: 40px;
  }
  .hero-brand {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 32px;
  }
  .hero-wordmark {
    font-family: var(--font-mono);
    font-size: clamp(48px, 7vw, 88px);
    color: var(--color-text);
    letter-spacing: 6px;
    line-height: 1;
  }
  .hero-tagline {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-accent);
    letter-spacing: 1px;
    margin-bottom: 20px;
  }
  .hero-title {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: clamp(28px, 3.5vw, 40px);
    line-height: 1.12;
    color: var(--color-text);
    margin: 0 0 28px;
  }
  .hero-title em {
    font-style: italic;
    color: var(--color-accent);
  }
  .hero-body {
    font-size: 18px;
    line-height: 1.65;
    color: var(--color-text-mid);
    max-width: 560px;
    margin: 0 0 40px;
  }
  .hero-actions {
    display: flex;
    gap: 16px;
  }

  /* Chat preview */
  .chat-preview {
    width: 380px;
    flex-shrink: 0;
    background-color: var(--color-cream);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 1px 3px rgba(201, 197, 188, 0.25);
  }
  .chat-breadcrumb {
    padding: 10px 16px;
    border-bottom: 1px solid var(--color-sand);
    font-family: var(--font-body);
    font-size: 11px;
  }
  .chat-crumb { color: var(--color-stone); }
  .chat-sep {
    font-family: var(--font-mono);
    color: var(--color-warm-stone);
    margin: 0 5px;
  }
  .chat-crumb-active {
    font-weight: 700;
    color: var(--color-text);
  }
  .chat-messages {
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .chat-msg-ai { max-width: 82%; }
  .chat-msg-user {
    max-width: 70%;
    align-self: flex-end;
  }
  .chat-sender {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-bottom: 4px;
  }
  .chat-sender-name {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 11px;
    color: var(--color-slate-mid);
  }
  .chat-sender-time {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--color-stone);
  }
  .chat-action {
    font-weight: 700;
    font-size: 12px;
    color: var(--color-text);
    margin-top: 6px;
  }
  .chat-input-wrap { padding: 10px 16px; }
  .chat-input {
    border: 1px solid var(--color-warm-stone);
    border-radius: 100px;
    background-color: var(--color-cream);
    padding: 9px 14px;
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-light);
  }
  .cursor {
    display: inline-block;
    width: 2px;
    height: 14px;
    background-color: var(--color-text);
    margin-left: 1px;
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
  }

  @media (max-width: 1100px) {
    .hero {
      flex-direction: column;
      padding: 120px 24px 80px;
    }
    .chat-preview {
      width: 100%;
      max-width: 420px;
    }
  }
</style>

<script>
  const el = document.getElementById('typed-text');
  const txt = "Move the investor prep to Thursday and flag the break clause for my review.";
  let i = 0;
  const iv = setInterval(() => {
    if (i < txt.length && el) {
      i++;
      el.textContent = txt.slice(0, i);
    } else {
      clearInterval(iv);
    }
  }, 35);
</script>
