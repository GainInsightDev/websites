---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';
---

<Layout title="404 — Juncta">
  <section style="padding: 200px 64px 120px; text-align: center;">
    <Logo size={48} />
    <h1 style="font-weight: 700; font-size: 32px; margin: 24px 0 12px;">Page not found</h1>
    <p style="color: var(--color-text-mid); margin-bottom: 32px;">The page you're looking for doesn't exist.</p>
    <a href="/" class="btn btn-primary">Back to home</a>
  </section>
</Layout>
