---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-content reveal">
        <div class="section-label" style="color: var(--color-stage-s2);">Global Climbing Standard</div>
        <h1 class="hero-title">
          The <em>PADI</em> of climbing.
        </h1>
        <p class="hero-subtitle">
          A globally portable climbing qualification framework — structured progression
          from first climb to advanced climber, recognised worldwide.
        </p>
        <div class="hero-actions">
          <a href="/for-centres" class="btn btn-primary">Accredit your centre</a>
          <a href="/how-it-works" class="btn btn-secondary">How it works</a>
        </div>
      </div>
      <div class="hero-stage-visual reveal reveal-delay-2" aria-hidden="true">
        <div class="stage-pills">
          <span class="stage-pill" style="--stage-color: var(--color-stage-ey);">Early Years</span>
          <span class="stage-pill" style="--stage-color: var(--color-stage-s1);">Discover</span>
          <span class="stage-pill" style="--stage-color: var(--color-stage-s2);">Explore</span>
          <span class="stage-pill" style="--stage-color: var(--color-stage-s3);">Develop</span>
          <span class="stage-pill" style="--stage-color: var(--color-stage-s4);">Perform</span>
          <span class="stage-pill" style="--stage-color: var(--color-stage-s5);">Evolve</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Value Props -->
  <section class="section" id="value">
    <div class="container">
      <div class="section-label reveal">Why GCS</div>
      <h2 class="section-title reveal">One standard.<br>Every wall. Worldwide.</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12">
        <div class="card reveal reveal-delay-1">
          <div class="card-icon" style="color: var(--color-stage-s2);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3 class="card-title">Globally recognised</h3>
          <p class="card-body">One qualification, recognised everywhere. Take your credentials from London to Sydney — they mean the same thing.</p>
        </div>
        <div class="card reveal reveal-delay-2">
          <div class="card-icon" style="color: var(--color-stage-s3);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <h3 class="card-title">Structured progression</h3>
          <p class="card-body">Six stages from Early Years to Evolve. Each stage builds on the last across six skill domains — clear milestones, real achievement.</p>
        </div>
        <div class="card reveal reveal-delay-3">
          <div class="card-icon" style="color: var(--color-stage-s4);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="card-title">For everyone</h3>
          <p class="card-body">Climbers get a clear pathway. Parents see real progress. Coaches deliver structured sessions. Centres grow their business.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works (summary) -->
  <section class="section-dark">
    <div class="section">
      <div class="container">
        <div class="section-label reveal" style="color: var(--color-stage-s1);">The Framework</div>
        <h2 class="section-title reveal" style="color: #FFFFFF;">Six stages. Six domains.<br>One global standard.</h2>
        <p class="section-body reveal" style="color: rgba(255,255,255,0.65);">
          Every climber progresses through structured stages, assessed across six skill domains.
          Like belt colours in martial arts — visible, meaningful, and universally understood.
        </p>
        <a href="/how-it-works" class="btn btn-outline-light reveal">Explore the framework</a>
      </div>
    </div>
  </section>

  <!-- Audiences -->
  <section class="section" id="audiences">
    <div class="container">
      <div class="section-label reveal">Who it's for</div>
      <h2 class="section-title reveal">Built for the whole climbing ecosystem.</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12">
        <div class="audience-card reveal reveal-delay-1">
          <h3>Climbers &amp; Parents</h3>
          <p>Track progress through clear stages. See exactly where you are and what comes next. Share achievements and earn recognised credentials.</p>
          <a href="/how-it-works">Learn about stages &rarr;</a>
        </div>
        <div class="audience-card reveal reveal-delay-2">
          <h3>Coaches &amp; Instructors</h3>
          <p>Deliver structured sessions backed by a global curriculum. Mark progress digitally. Build your professional credentials with GCS certification.</p>
          <a href="/how-it-works">See coach tools &rarr;</a>
        </div>
        <div class="audience-card reveal reveal-delay-3">
          <h3>Climbing Centres</h3>
          <p>Differentiate with GCS accreditation. Drive participation, retention, and revenue through structured programming that parents and schools trust.</p>
          <a href="/for-centres">Accredit your centre &rarr;</a>
        </div>
        <div class="audience-card reveal reveal-delay-4">
          <h3>Franchise Partners</h3>
          <p>Become a Master Franchisee and bring GCS to your territory. Exclusive rights, full support, and a proven model for the climbing industry.</p>
          <a href="/for-franchisees">Franchise opportunity &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-brand">
    <div class="section">
      <div class="container" style="text-align: center;">
        <h2 class="section-title reveal" style="color: #FFFFFF; max-width: none;">Ready to raise the standard?</h2>
        <p class="section-body reveal" style="color: rgba(255,255,255,0.65); max-width: 480px; margin-left: auto; margin-right: auto;">
          Whether you're a climbing centre, prospective franchisee, or just curious — we'd love to hear from you.
        </p>
        <div class="reveal" style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
          <a href="/for-centres" class="btn btn-outline-light">Accredit your centre</a>
          <a href="/contact" class="btn btn-outline-light">Get in touch</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    padding: 160px 48px 100px;
    position: relative;
  }
  .hero-content {
    max-width: 640px;
  }
  .hero-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(40px, 6vw, 64px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 12px 0 24px;
  }
  .hero-title em {
    font-style: normal;
    color: var(--color-stage-s3);
  }
  .hero-subtitle {
    font-size: 18px;
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 520px;
    margin-bottom: 36px;
  }
  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* Stage pills */
  .hero-stage-visual {
    margin-top: 64px;
  }
  .stage-pills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .stage-pill {
    display: inline-flex;
    align-items: center;
    padding: 8px 20px;
    border-radius: 24px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    color: #FFFFFF;
    background: var(--stage-color);
  }

  /* Dark section */
  .section-dark {
    background: var(--color-brand);
  }
  .section-dark .section-title {
    color: #FFFFFF;
  }

  /* Brand section */
  .section-brand {
    background: var(--color-brand);
  }

  /* Audience cards */
  .audience-card {
    padding: 32px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .audience-card:hover {
    border-color: var(--color-text-muted);
    box-shadow: var(--shadow-card-lg);
  }
  .audience-card h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    margin-bottom: 12px;
  }
  .audience-card p {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin-bottom: 16px;
  }
  .audience-card a {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-stage-s3);
    text-decoration: none;
  }
  .audience-card a:hover {
    text-decoration: underline;
  }

  /* Card enhancements */
  .card-icon {
    margin-bottom: 16px;
  }
  .card-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    margin-bottom: 8px;
  }
  .card-body {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .hero {
      padding: 120px 24px 64px;
    }
  }
</style>
