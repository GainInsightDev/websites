---
import Layout from '../layouts/Layout.astro';

const stages = [
  { name: 'Early Years', short: 'EY', token: 'var(--color-stage-ey)', ages: 'Ages 4–7', description: 'Introduction to climbing for young learners. Building confidence, basic movement skills, and a love of the sport through play-based sessions.' },
  { name: 'Stage 1: Discover', short: 'S1', token: 'var(--color-stage-s1)', ages: 'Foundation', description: 'Foundation techniques. Learning fundamental movement patterns, basic safety, and route reading. The start of structured progression.' },
  { name: 'Stage 2: Explore', short: 'S2', token: 'var(--color-stage-s2)', ages: 'Intermediate', description: 'Expanding skills. More complex techniques, problem-solving on the wall, building endurance, and developing independence.' },
  { name: 'Stage 3: Develop', short: 'S3', token: 'var(--color-stage-s3)', ages: 'Advanced', description: 'Refining ability. Advanced footwork, route strategy, mental preparation, and developing a personal climbing style.' },
  { name: 'Stage 4: Perform', short: 'S4', token: 'var(--color-stage-s4)', ages: 'Elite', description: 'High-level performance. Technical mastery, competition readiness, coaching fundamentals, and leadership on the wall.' },
  { name: 'Stage 5: Evolve', short: 'S5', token: 'var(--color-stage-s5)', ages: 'Expert', description: 'Expert level. Mentoring others, pushing boundaries, contributing to the climbing community, and shaping the future of the sport.' },
];

const domains = [
  { name: 'Movement & Technique', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`, description: 'Body positioning, footwork, handholds, and efficient movement on the wall.' },
  { name: 'Strength & Conditioning', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>`, description: 'Physical preparation — grip strength, endurance, flexibility, and injury prevention.' },
  { name: 'Mental Skills', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>`, description: 'Focus, confidence, managing fear, problem-solving under pressure.' },
  { name: 'Safety & Awareness', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`, description: 'Belaying, equipment checks, hazard recognition, and responsible climbing.' },
  { name: 'Route Reading', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>`, description: 'Analysing routes, planning sequences, and adapting strategies on the wall.' },
  { name: 'Climbing Knowledge', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`, description: 'Understanding grades, styles, ethics, history, and the broader climbing world.' },
];
---

<Layout
  title="How it Works — GCS"
  description="Learn how the Global Climbing Standard's 5-stage framework and 6 skill domains create a clear progression pathway for every climber."
>
  <!-- Hero -->
  <section class="hero-page">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container">
      <span class="hero-badge reveal">
        <span class="hero-badge-dot"></span>
        The Framework
      </span>
      <h1 class="hero-title reveal">
        A clear pathway from<br><em>first climb to expert.</em>
      </h1>
      <p class="hero-subtitle reveal">
        GCS assesses climbers across six skill domains as they progress through structured stages.
        Like belt colours in martial arts — visible, meaningful, and universally understood.
      </p>
    </div>
  </section>

  <!-- Visual overview -->
  <section class="stage-overview">
    <div class="container">
      <div class="stage-timeline">
        {stages.map((stage, i) => (
          <div class={`timeline-item reveal reveal-delay-${(i % 4) + 1}`} style={`--stage-color: ${stage.token};`}>
            <div class="timeline-marker">
              <span class="timeline-dot"></span>
              {i < stages.length - 1 && <span class="timeline-line"></span>}
            </div>
            <div class="timeline-content">
              <span class="timeline-badge">{stage.ages}</span>
              <h3>{stage.name}</h3>
              <p>{stage.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Domains -->
  <section class="section-dark">
    <div class="domains-glow" aria-hidden="true"></div>
    <div class="section">
      <div class="container">
        <div class="section-label reveal" style="color: var(--color-stage-s1);">Skill Domains</div>
        <h2 class="section-title reveal" style="color: #FFFFFF;">
          Assessed across <em class="gradient-text">six dimensions.</em>
        </h2>
        <p class="section-body reveal" style="color: rgba(255,255,255,0.6);">
          Every stage requires demonstrated competency across all six domains.
          This ensures well-rounded development — not just strong fingers.
        </p>
        <div class="domains-grid">
          {domains.map((domain, i) => (
            <div class={`domain-card reveal reveal-delay-${(i % 4) + 1}`} style={`--accent: ${stages[i].token};`}>
              <div class="domain-icon" set:html={domain.icon}></div>
              <h3>{domain.name}</h3>
              <p>{domain.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- How assessment works -->
  <section class="section">
    <div class="container">
      <div class="section-label reveal">Assessment</div>
      <h2 class="section-title reveal">How climbers progress.</h2>
      <p class="section-body reveal">
        Progression is evidence-based, coach-assessed, and digitally tracked. No written exams —
        just real climbing observed by qualified GCS coaches.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
        <div class="assess-card reveal reveal-delay-1">
          <div class="assess-number">01</div>
          <h3>Climb & learn</h3>
          <p>Attend structured GCS sessions at an accredited centre. Each session targets specific elements within your current stage.</p>
        </div>
        <div class="assess-card reveal reveal-delay-2">
          <div class="assess-number">02</div>
          <h3>Demonstrate skills</h3>
          <p>Coaches observe and mark competency elements during sessions. Progress is tracked digitally across all six domains in real-time.</p>
        </div>
        <div class="assess-card reveal reveal-delay-3">
          <div class="assess-number">03</div>
          <h3>Earn your stage</h3>
          <p>Complete all elements in a stage and you earn your GCS credential — a globally recognised, digitally verifiable climbing qualification.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-brand">
    <div class="cta-glow" aria-hidden="true"></div>
    <div class="section">
      <div class="container" style="text-align: center; position: relative; z-index: 1;">
        <h2 class="section-title reveal" style="color: #FFFFFF; max-width: none;">Want to bring GCS to your centre?</h2>
        <p class="section-body reveal" style="color: rgba(255,255,255,0.55); max-width: 480px; margin-left: auto; margin-right: auto;">
          Accredit your climbing centre and start delivering structured GCS sessions.
        </p>
        <div class="reveal" style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
          <a href="/for-centres" class="btn btn-outline-light">Accredit your centre</a>
          <a href="/contact" class="btn btn-outline-light">Ask a question</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Timeline stages */
  .stage-overview {
    padding: 80px 48px;
  }
  .stage-timeline {
    max-width: 720px;
    margin: 0 auto;
  }
  .timeline-item {
    display: flex;
    gap: 24px;
    position: relative;
  }
  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 20px;
  }
  .timeline-dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--stage-color);
    border: 3px solid var(--color-surface);
    box-shadow: 0 0 0 2px var(--stage-color);
    flex-shrink: 0;
    z-index: 1;
    transition: transform 0.3s var(--ease-spring);
  }
  .timeline-item:hover .timeline-dot {
    transform: scale(1.3);
  }
  .timeline-line {
    width: 2px;
    flex: 1;
    background: linear-gradient(to bottom, var(--stage-color), var(--color-border));
    min-height: 32px;
  }
  .timeline-content {
    padding-bottom: 40px;
  }
  .timeline-badge {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--stage-color);
    margin-bottom: 8px;
  }
  .timeline-content h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    margin-bottom: 8px;
    color: var(--color-text);
  }
  .timeline-content p {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.65;
    max-width: 480px;
  }

  /* Domains */
  .domains-glow {
    position: absolute;
    top: -200px;
    left: -200px;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(101, 116, 184, 0.12) 0%,
      transparent 70%
    );
    pointer-events: none;
  }
  .domains-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
    margin-top: 40px;
  }
  .domain-card {
    padding: 28px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-card);
    background: rgba(255, 255, 255, 0.03);
    transition: transform 0.3s var(--ease-spring), background 0.3s ease, border-color 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  .domain-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--ease-out-expo);
  }
  .domain-card:hover {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.15);
  }
  .domain-card:hover::after {
    transform: scaleX(1);
  }
  .domain-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    color: var(--accent);
  }
  .domain-card h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
    color: #FFFFFF;
    margin-bottom: 8px;
  }
  .domain-card p {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.65;
  }

  /* Assessment cards */
  .assess-card {
    padding: 32px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    position: relative;
    overflow: hidden;
    transition: transform 0.3s var(--ease-spring), box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .assess-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-lg);
    border-color: var(--color-text-muted);
  }
  .assess-number {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 36px;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--color-stage-s2), var(--color-stage-s4));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 16px;
    line-height: 1;
  }
  .assess-card h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    margin-bottom: 10px;
  }
  .assess-card p {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .stage-overview {
      padding: 48px 24px;
    }
    .timeline-content {
      padding-bottom: 28px;
    }
  }
</style>
