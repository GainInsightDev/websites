---
import Layout from '../layouts/Layout.astro';

const stats = [
  { number: '10–15%', label: 'Annual growth in indoor climbing' },
  { number: '2024', label: 'Olympic inclusion cemented' },
  { number: '0', label: 'Global climbing qualifications' },
];
---

<Layout
  title="About — GCS"
  description="GCS is the Global Climbing Standard — a globally portable climbing qualification framework created by ClimbHQ Limited."
>
  <!-- Hero -->
  <section class="hero-page">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container">
      <span class="hero-badge reveal">
        <span class="hero-badge-dot" style="background: var(--color-stage-s3);"></span>
        About GCS
      </span>
      <h1 class="hero-title reveal">
        Building the global standard<br><em>for climbing education.</em>
      </h1>
      <p class="hero-subtitle reveal">
        GCS is the world's only globally portable climbing qualification — a structured
        framework that brings rigour, visibility, and recognition to an industry that has none.
      </p>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="proof-bar">
    <div class="container">
      <div class="proof-stats">
        {stats.map((stat, i) => (
          <>
            <div class={`proof-stat reveal reveal-delay-${i + 1}`}>
              <span class="proof-number">{stat.number}</span>
              <span class="proof-label">{stat.label}</span>
            </div>
            {i < stats.length - 1 && <div class="proof-divider" aria-hidden="true"></div>}
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- Problem -->
  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
        <div>
          <div class="section-label reveal">The Problem</div>
          <h2 class="section-title reveal">Climbing has no<br>global standard.</h2>
        </div>
        <div>
          <div class="problem-text reveal">
            <p>
              Indoor climbing is one of the fastest-growing sports in the world — driven by
              Olympic inclusion and a new generation of climbers. Yet the industry has no globally
              recognised qualification framework.
            </p>
            <p>
              Existing certifications are fragmented by country, largely outdoor-focused,
              non-portable, and entirely analogue. Instructors can't take qualifications
              abroad. Centres can't differentiate on coaching quality. Parents have no
              visibility into their child's development.
            </p>
          </div>
          <div class="problem-highlight reveal reveal-delay-2">
            <span class="problem-highlight-text">GCS changes that.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Vision -->
  <section class="section-dark">
    <div class="vision-glow" aria-hidden="true"></div>
    <div class="section">
      <div class="container">
        <div class="section-label reveal" style="color: var(--color-stage-s1);">Vision</div>
        <h2 class="section-title reveal" style="color: #FFFFFF;">
          Every serious climbing centre,<br><em class="gradient-text">GCS-accredited.</em>
        </h2>
        <div class="vision-grid reveal reveal-delay-1">
          <div class="vision-card">
            <div class="vision-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h3>For instructors</h3>
            <p>Every climbing coach carries a GCS credential — recognised and portable worldwide.</p>
          </div>
          <div class="vision-card">
            <div class="vision-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
            <h3>For parents</h3>
            <p>Every parent trusts GCS centres for structured, visible, and measurable coaching.</p>
          </div>
          <div class="vision-card">
            <div class="vision-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            </div>
            <h3>For climbers</h3>
            <p>Every climber has a clear, portable pathway from first climb to expert.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ClimbHQ -->
  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
        <div>
          <div class="section-label reveal">ClimbHQ</div>
          <h2 class="section-title reveal">Built by climbers,<br>for climbing.</h2>
        </div>
        <div>
          <p class="about-text reveal">
            GCS is created by ClimbHQ Limited — a team that combines deep climbing industry
            experience with technology expertise. We're building the standard, the digital
            platform, and the global franchise network to bring it to every climbing wall
            in the world.
          </p>
          <p class="about-text reveal reveal-delay-1">
            Our technology partner, Gain Insight, provides the AI and platform engineering
            that powers the GCS digital experience — from mobile apps to web dashboards.
          </p>
          <div class="tech-pills reveal reveal-delay-2">
            <span class="pill">Coach App</span>
            <span class="pill">Learner App</span>
            <span class="pill">Parent Dashboard</span>
            <span class="pill">Management Console</span>
            <span class="pill">Digital Credentials</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-brand">
    <div class="cta-glow" aria-hidden="true"></div>
    <div class="section">
      <div class="container" style="text-align: center; position: relative; z-index: 1;">
        <h2 class="section-title reveal" style="color: #FFFFFF; max-width: none;">Want to be part of it?</h2>
        <p class="section-body reveal" style="color: rgba(255,255,255,0.55); max-width: 480px; margin-left: auto; margin-right: auto;">
          Whether you're a climbing centre, prospective franchisee, or just curious — let's talk.
        </p>
        <div class="reveal" style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
          <a href="/for-centres" class="btn btn-outline-light">Accredit your centre</a>
          <a href="/for-franchisees" class="btn btn-outline-light">Franchise opportunity</a>
          <a href="/contact" class="btn btn-outline-light">Get in touch</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero overrides */
  .hero-glow {
    background: radial-gradient(
      circle,
      rgba(91, 154, 107, 0.06) 0%,
      rgba(139, 110, 175, 0.05) 40%,
      transparent 70%
    );
  }
  .hero-title em {
    background: linear-gradient(135deg, var(--color-stage-s3), var(--color-stage-s5));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Problem */
  .problem-text p {
    font-size: 16px;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin-bottom: 20px;
  }
  .problem-highlight {
    padding: 20px 24px;
    border-left: 3px solid var(--color-stage-s3);
    margin-top: 8px;
  }
  .problem-highlight-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    color: var(--color-text);
  }

  /* Vision section */
  .vision-glow {
    position: absolute;
    bottom: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(101, 116, 184, 0.12) 0%,
      transparent 70%
    );
    pointer-events: none;
  }
  .vision-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
    margin-top: 40px;
  }
  .vision-card {
    padding: 28px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-card);
    background: rgba(255, 255, 255, 0.03);
    transition: transform 0.3s var(--ease-spring), background 0.3s ease, border-color 0.3s ease;
  }
  .vision-card:hover {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.15);
  }
  .vision-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    color: var(--color-stage-s2);
  }
  .vision-card h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
    color: #FFFFFF;
    margin-bottom: 8px;
  }
  .vision-card p {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.65;
  }

  /* About / ClimbHQ */
  .about-text {
    font-size: 16px;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin-bottom: 20px;
  }
  .tech-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 8px;
  }
  .pill {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 100px;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .pill:hover {
    border-color: var(--color-stage-s3);
    color: var(--color-stage-s3);
  }

</style>
