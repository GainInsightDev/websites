---
import Layout from '../layouts/Layout.astro';

const benefits = [
  { title: 'Structured progression', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`, accent: 'var(--color-stage-ey)', body: 'Move beyond "just climbing." GCS gives your sessions structure, purpose, and visible milestones that keep participants coming back.' },
  { title: 'Parent engagement', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`, accent: 'var(--color-stage-s1)', body: 'Parents see real-time progress updates, session summaries, and stage achievements. Visibility builds trust — and trust drives retention.' },
  { title: 'New revenue streams', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`, accent: 'var(--color-stage-s2)', body: 'Registration fees, progression fees, and certification create recurring revenue beyond day passes and memberships.' },
  { title: 'Competitive advantage', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`, accent: 'var(--color-stage-s3)', body: 'GCS accreditation is a quality mark. Parents and schools actively seek accredited centres — differentiate on coaching, not just walls.' },
  { title: 'Turnkey curriculum', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`, accent: 'var(--color-stage-s4)', body: 'No programme design needed. GCS provides the curriculum, digital platform, assessment criteria, and marketing support.' },
  { title: 'Coach credentials', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`, accent: 'var(--color-stage-s5)', body: 'Your instructors earn globally recognised GCS coaching certifications — raising your team\'s professional standing.' },
];
---

<Layout
  title="For Climbing Centres — GCS"
  description="Accredit your climbing centre with the Global Climbing Standard. Drive participation, retention, and revenue with a structured qualification framework."
>
  <!-- Hero -->
  <section class="hero-page">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container">
      <span class="hero-badge reveal">
        <span class="hero-badge-dot"></span>
        For Centres
      </span>
      <h1 class="hero-title reveal">
        Grow your centre with<br><em>structured progression.</em>
      </h1>
      <p class="hero-subtitle reveal">
        GCS accreditation gives your centre a proven framework for coaching, new revenue
        streams, and a quality mark that parents and schools trust.
      </p>
      <div class="hero-actions reveal">
        <a href="/contact" class="btn btn-primary">Apply for accreditation</a>
        <a href="/how-it-works" class="btn btn-secondary">See the framework</a>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="section">
    <div class="container">
      <div class="section-label reveal">Benefits</div>
      <h2 class="section-title reveal">Why centres choose GCS.</h2>
      <div class="benefits-grid">
        {benefits.map((item, i) => (
          <div class={`benefit-card reveal reveal-delay-${(i % 4) + 1}`} style={`--accent: ${item.accent};`}>
            <div class="benefit-icon" set:html={item.icon}></div>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How accreditation works -->
  <section class="section-dark">
    <div class="process-glow" aria-hidden="true"></div>
    <div class="section">
      <div class="container">
        <div class="section-label reveal" style="color: var(--color-stage-s1);">Process</div>
        <h2 class="section-title reveal" style="color: #FFFFFF;">
          How accreditation <em class="gradient-text">works.</em>
        </h2>
        <div class="process-steps">
          <div class="process-step reveal reveal-delay-1">
            <div class="process-number">01</div>
            <div class="process-content">
              <h3>Apply</h3>
              <p>Contact your local GCS Master Franchisee or apply directly through our website. We'll discuss your facility and goals.</p>
            </div>
          </div>
          <div class="process-step reveal reveal-delay-2">
            <div class="process-number">02</div>
            <div class="process-content">
              <h3>Assess</h3>
              <p>We review your facility, coaching staff, and safety standards. This ensures your centre is ready to deliver the GCS experience.</p>
            </div>
          </div>
          <div class="process-step reveal reveal-delay-3">
            <div class="process-number">03</div>
            <div class="process-content">
              <h3>Train</h3>
              <p>Your instructors complete GCS certification training — learning the framework, assessment criteria, and digital tools.</p>
            </div>
          </div>
          <div class="process-step reveal reveal-delay-4">
            <div class="process-number">04</div>
            <div class="process-content">
              <h3>Launch</h3>
              <p>Go live with GCS sessions. We provide curriculum, materials, platform access, and ongoing marketing support.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social proof -->
  <section class="proof-bar">
    <div class="container">
      <div class="proof-stats">
        <div class="proof-stat reveal">
          <span class="proof-number">5</span>
          <span class="proof-label">Progressive stages</span>
        </div>
        <div class="proof-divider" aria-hidden="true"></div>
        <div class="proof-stat reveal reveal-delay-1">
          <span class="proof-number">6</span>
          <span class="proof-label">Skill domains</span>
        </div>
        <div class="proof-divider" aria-hidden="true"></div>
        <div class="proof-stat reveal reveal-delay-2">
          <span class="proof-number">3</span>
          <span class="proof-label">Digital platforms</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-brand">
    <div class="cta-glow" aria-hidden="true"></div>
    <div class="section">
      <div class="container" style="text-align: center; position: relative; z-index: 1;">
        <h2 class="section-title reveal" style="color: #FFFFFF; max-width: none;">Ready to accredit your centre?</h2>
        <p class="section-body reveal" style="color: rgba(255,255,255,0.55); max-width: 480px; margin-left: auto; margin-right: auto;">
          Get in touch to discuss accreditation. We'll walk you through the process and answer any questions.
        </p>
        <a href="/contact" class="btn btn-outline-light reveal">Apply for accreditation</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero-page {
    padding: 160px 48px 80px;
    position: relative;
    overflow: hidden;
  }
  .hero-glow {
    position: absolute;
    top: -200px;
    right: -200px;
    width: 800px;
    height: 800px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(91, 154, 107, 0.08) 0%,
      rgba(78, 151, 168, 0.05) 40%,
      transparent 70%
    );
    pointer-events: none;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 20px;
  }
  .hero-badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-stage-s2);
    animation: pulse 2s ease-in-out infinite;
  }
  .hero-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(40px, 6vw, 64px);
    line-height: 1.05;
    letter-spacing: -0.035em;
    color: var(--color-text);
    margin-bottom: 24px;
  }
  .hero-title em {
    font-style: normal;
    background: linear-gradient(135deg, var(--color-stage-s2), var(--color-stage-s3));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-subtitle {
    font-size: 18px;
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 580px;
    margin-bottom: 36px;
  }
  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* Benefits grid */
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 16px;
    margin-top: 40px;
  }
  .benefit-card {
    padding: 32px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    position: relative;
    overflow: hidden;
    transition: transform 0.3s var(--ease-spring), box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .benefit-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--ease-out-expo);
  }
  .benefit-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-lg);
    border-color: var(--color-text-muted);
  }
  .benefit-card:hover::after {
    transform: scaleX(1);
  }
  .benefit-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    color: var(--accent);
  }
  .benefit-card h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    margin-bottom: 10px;
  }
  .benefit-card p {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  /* Process */
  .section-dark {
    background: var(--color-brand);
    position: relative;
    overflow: hidden;
  }
  .process-glow {
    position: absolute;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(101, 116, 184, 0.12) 0%,
      transparent 70%
    );
    pointer-events: none;
  }
  .gradient-text {
    font-style: normal;
    background: linear-gradient(135deg, var(--color-stage-s1), var(--color-stage-s3));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .process-steps {
    display: flex;
    flex-direction: column;
    gap: 32px;
    margin-top: 48px;
    max-width: 640px;
  }
  .process-step {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }
  .process-number {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 32px;
    letter-spacing: -0.02em;
    color: rgba(255, 255, 255, 0.15);
    flex-shrink: 0;
    line-height: 1;
    padding-top: 4px;
  }
  .process-content h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    color: #FFFFFF;
    margin-bottom: 6px;
  }
  .process-content p {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.65;
  }

  /* Proof bar */
  .proof-bar {
    padding: 48px;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .proof-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 48px;
  }
  .proof-stat { text-align: center; }
  .proof-number {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(36px, 4vw, 52px);
    letter-spacing: -0.02em;
    color: var(--color-text);
    display: block;
    line-height: 1;
  }
  .proof-label {
    font-size: 14px;
    color: var(--color-text-muted);
    margin-top: 8px;
    display: block;
  }
  .proof-divider {
    width: 1px;
    height: 48px;
    background: var(--color-border);
  }

  /* Brand CTA */
  .section-brand {
    background: var(--color-brand);
    position: relative;
    overflow: hidden;
  }
  .cta-glow {
    position: absolute;
    bottom: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(101, 116, 184, 0.15) 0%,
      rgba(139, 110, 175, 0.08) 50%,
      transparent 70%
    );
    pointer-events: none;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  @media (max-width: 900px) {
    .hero-page {
      padding: 120px 24px 48px;
    }
    .proof-stats {
      flex-direction: column;
      gap: 24px;
    }
    .proof-divider {
      width: 48px;
      height: 1px;
    }
    .benefits-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
