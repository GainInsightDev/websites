---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <!-- Top row: Logo + nav -->
  <div class="footer-top">
    <img src="/images/logos/climbhq-logo.svg" alt="ClimbHQ" width="120" height="120" decoding="async" class="footer-logo" />
    <nav class="footer-nav" aria-label="Footer navigation">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about/">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>
  </div>

  <!-- Middle row: 3 columns -->
  <div class="footer-columns">
    <!-- Column 1: About + NICAS + Social -->
    <div class="footer-col">
      <h2>About ClimbHQ</h2>
      <p>ClimbHQ is a commercial services provider dedicated to helping climbing centres grow. We combine industry expertise with digital marketing strategies to attract more visitors, boost engagement, and drive memberships.</p>
      <img src="/images/logos/nicas-logo.png" alt="NICAS Partner" width="300" height="107" decoding="async" class="footer-nicas" />
      <div class="footer-social" role="list">
        <a href="https://www.facebook.com/profile.php?id=61574224461872" target="_blank" rel="noopener noreferrer" role="listitem" aria-label="Facebook">
          <i aria-hidden="true" class="fab fa-facebook-f"></i>
        </a>
        <a href="https://www.instagram.com/climb_hq?igsh=ZnFjZ3N0aWpwdDU2" target="_blank" rel="noopener noreferrer" role="listitem" aria-label="Instagram">
          <i aria-hidden="true" class="fab fa-instagram"></i>
        </a>
        <a href="https://www.linkedin.com/company/climbhq/" target="_blank" rel="noopener noreferrer" role="listitem" aria-label="LinkedIn">
          <i aria-hidden="true" class="fab fa-linkedin"></i>
        </a>
      </div>
    </div>

    <!-- Column 2: Contact -->
    <div class="footer-col">
      <h5>Contact Info</h5>
      <p class="footer-contact-item">
        <i aria-hidden="true" class="fas fa-envelope"></i>
        hello@climbhq.co.uk
      </p>
    </div>

    <!-- Column 3: Newsletter -->
    <div class="footer-col">
      <h5>Subscribe Our Newsletter</h5>
      <form method="post" class="footer-newsletter">
        <div class="footer-newsletter-row">
          <input type="email" name="email" placeholder="Email Address" aria-label="Email address for newsletter signup" required />
          <button type="submit" aria-label="Subscribe">
            <i aria-hidden="true" class="fab fa-telegram-plane"></i>
          </button>
        </div>
      </form>
      <p class="footer-disclaimer">* Trust me, we will not spam your email</p>
    </div>
  </div>

  <!-- Bottom row: Copyright + legal -->
  <div class="footer-bottom">
    <p>Copyright &copy; {currentYear} ClimbHQ All rights reserved.</p>
    <ul class="footer-legal">
      <li><a href="/privacy-policy/">Privacy Policy</a></li>
      <li><a href="/terms/">Terms &amp; Conditions</a></li>
    </ul>
  </div>
</footer>

<style is:global>
/* ===== Site Footer ===== */
.site-footer {
  background: #03071F;
  color: #9796A3;
  padding: 60px 24px 24px;
  font-family: 'Montserrat', sans-serif;
  font-size: 14px;
  line-height: 1.6;
}

/* Top row */
.footer-top {
  max-width: 1200px;
  margin: 0 auto 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 40px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}
.footer-logo {
  height: 60px;
  width: auto;
}
.footer-nav ul {
  display: flex;
  gap: 24px;
  list-style: none;
  margin: 0;
  padding: 0;
}
.footer-nav a {
  color: #ffffff;
  text-decoration: none;
  font-size: 14px;
  font-weight: 500;
}
.footer-nav a:hover {
  color: #5ED4F5;
}

/* Columns */
.footer-columns {
  max-width: 1200px;
  margin: 0 auto 40px;
  display: grid;
  grid-template-columns: 2fr 1fr 1.5fr;
  gap: 40px;
}
.footer-col h2 {
  font-family: 'Unbounded', sans-serif !important;
  font-size: 18px !important;
  font-weight: 600 !important;
  color: #ffffff !important;
  margin-bottom: 16px;
}
.footer-col h5 {
  font-family: 'Unbounded', sans-serif;
  font-size: 14px;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 16px;
}
.footer-col p {
  color: #9796A3;
  margin-bottom: 16px;
}
.footer-nicas {
  width: 120px;
  height: auto;
  margin-bottom: 16px;
}
.footer-social {
  display: flex;
  gap: 12px;
}
.footer-social a {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  color: #5ED4F5;
  font-size: 16px;
  text-decoration: none;
  transition: background 0.2s ease;
}
.footer-social a:hover {
  background: #5ED4F5;
  color: #03071F;
}
.footer-contact-item {
  display: flex;
  align-items: center;
  gap: 8px;
  color: #9796A3;
}
.footer-contact-item i {
  color: #5ED4F5;
}

/* Newsletter */
.footer-newsletter-row {
  display: flex;
  gap: 0;
}
.footer-newsletter-row input {
  flex: 1;
  padding: 10px 14px;
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-right: none;
  border-radius: 4px 0 0 4px;
  background: rgba(255, 255, 255, 0.05);
  color: #ffffff;
  font-family: 'Montserrat', sans-serif;
  font-size: 14px;
}
.footer-newsletter-row input::placeholder {
  color: #9796A3;
}
.footer-newsletter-row button {
  padding: 10px 16px;
  border: 1px solid #5ED4F5;
  border-radius: 0 4px 4px 0;
  background: #5ED4F5;
  color: #03071F;
  cursor: pointer;
  font-size: 16px;
  transition: background 0.2s ease;
}
.footer-newsletter-row button:hover {
  background: #4DC4E5;
}
.footer-disclaimer {
  font-size: 12px;
  color: #6b6a77;
  margin-top: 8px;
}

/* Bottom row */
.footer-bottom {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 24px;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}
.footer-bottom p {
  color: #6b6a77;
  font-size: 13px;
  margin: 0;
}
.footer-legal {
  display: flex;
  gap: 24px;
  list-style: none;
  margin: 0;
  padding: 0;
}
.footer-legal a {
  color: #9796A3;
  text-decoration: none;
  font-size: 13px;
}
.footer-legal a:hover {
  color: #ffffff;
}

/* Mobile responsive */
@media (max-width: 768px) {
  .footer-top {
    flex-direction: column;
    gap: 20px;
    text-align: center;
  }
  .footer-columns {
    grid-template-columns: 1fr;
    text-align: center;
  }
  .footer-social {
    justify-content: center;
  }
  .footer-bottom {
    flex-direction: column;
    gap: 16px;
    text-align: center;
  }
}
</style>
