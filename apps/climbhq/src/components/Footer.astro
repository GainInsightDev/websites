---
const currentYear = new Date().getFullYear();

const footerLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const socialLinks = [
  { label: 'Facebook', href: 'https://www.facebook.com/profile.php?id=61574224461872', icon: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z' },
  { label: 'Instagram', href: 'https://www.instagram.com/climb_hq', icon: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/company/climbhq/', icon: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z' },
];
---

<footer class="footer">
  <div class="footer-top">
    <div class="footer-brand">
      <img src="/images/logos/climbhq-logo.svg" alt="ClimbHQ" width="140" height="40" class="footer-logo" />
      <ul class="footer-nav">
        {footerLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>
  </div>
  <div class="footer-main">
    <div class="footer-col">
      <h5 class="footer-heading">About ClimbHQ</h5>
      <p class="footer-text">ClimbHQ is a commercial services provider dedicated to helping climbing centres grow. We combine industry expertise with digital marketing strategies to attract more visitors, boost engagement, and drive memberships.</p>
      <img src="/images/logos/nicas-logo.png" alt="NICAS Partner" width="150" height="54" class="footer-nicas" />
      <div class="footer-social">
        {socialLinks.map((link) => (
          <a href={link.href} aria-label={link.label} target="_blank" rel="noopener noreferrer" class="social-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d={link.icon} /></svg>
          </a>
        ))}
      </div>
    </div>
    <div class="footer-col">
      <h5 class="footer-heading">Contact Info</h5>
      <p class="footer-text">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline-block;vertical-align:middle;margin-right:6px;"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <a href="mailto:hello@climbhq.co.uk" class="footer-email">hello@climbhq.co.uk</a>
      </p>
    </div>
    <div class="footer-col">
      <h5 class="footer-heading">Subscribe Our Newsletter</h5>
      <form class="footer-newsletter">
        <input type="email" placeholder="Email Address" class="footer-input" />
        <button type="submit" class="footer-submit" aria-label="Subscribe">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </form>
      <p class="footer-disclaimer">*Trust me, we will not spam your email</p>
    </div>
  </div>
  <div class="footer-bottom">
    <p>Copyright &copy; {currentYear} ClimbHQ All rights reserved.</p>
    <ul class="footer-legal">
      <li><a href="/privacy-policy">Privacy Policy</a></li>
      <li><a href="/terms">Terms &amp; Conditions</a></li>
    </ul>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-footer-bg);
    color: #FFFFFF;
  }
  .footer-top {
    padding: 40px 48px 24px;
    border-bottom: 1px solid var(--color-border);
  }
  .footer-brand {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .footer-logo {
    height: 32px;
    width: auto;
    filter: brightness(0) invert(1);
  }
  .footer-nav {
    display: flex;
    gap: 24px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .footer-nav a {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-nav a:hover { color: #FFFFFF; }
  .footer-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 48px;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 48px;
  }
  .footer-heading {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    color: #FFFFFF;
    margin-bottom: 16px;
    text-transform: none;
  }
  .footer-text {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.6;
    margin-bottom: 16px;
  }
  .footer-email {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
  }
  .footer-email:hover { color: var(--color-accent); }
  .footer-nicas {
    margin-bottom: 16px;
    height: 40px;
    width: auto;
  }
  .footer-social {
    display: flex;
    gap: 10px;
  }
  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.6);
    transition: background 0.2s ease, color 0.2s ease;
  }
  .social-link:hover {
    background: var(--color-accent);
    color: #FFFFFF;
  }
  .footer-newsletter {
    display: flex;
    gap: 0;
  }
  .footer-input {
    flex: 1;
    padding: 10px 14px;
    border: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.05);
    color: #FFFFFF;
    font-size: 14px;
    border-radius: var(--radius-btn) 0 0 var(--radius-btn);
    outline: none;
  }
  .footer-input::placeholder { color: rgba(255, 255, 255, 0.3); }
  .footer-submit {
    padding: 10px 16px;
    background: var(--color-accent);
    border: none;
    color: #FFFFFF;
    cursor: pointer;
    border-radius: 0 var(--radius-btn) var(--radius-btn) 0;
    transition: background 0.2s ease;
  }
  .footer-submit:hover { background: var(--color-accent-hover); }
  .footer-disclaimer {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.3);
    margin-top: 8px;
  }
  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px 48px;
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-bottom p {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.35);
  }
  .footer-legal {
    display: flex;
    gap: 24px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .footer-legal a {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
  }
  .footer-legal a:hover { color: rgba(255, 255, 255, 0.6); }

  @media (max-width: 900px) {
    .footer-top { padding: 32px 20px 20px; }
    .footer-brand { flex-direction: column; gap: 16px; }
    .footer-main {
      grid-template-columns: 1fr;
      padding: 32px 20px;
      gap: 32px;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 12px;
      padding: 20px;
      text-align: center;
    }
  }
</style>
