---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Hero with background image -->
  <section class="hero">
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-content">
      <p class="hero-label reveal">W E L C O M E &nbsp; T O &nbsp; C L I M B I N G</p>
      <h1 class="hero-title reveal reveal-delay-1">Helping grow your climbing centre</h1>
      <p class="hero-body reveal reveal-delay-2">At ClimbHQ, we're all about helping climbing centres thrive. Whether you're running a local wall or a sprawling facility, we understand the challenges (and joys!) of getting more people through your doors and onto the walls.</p>
    </div>
  </section>

  <!-- Vision & Mission -->
  <section class="section" style="text-align: center;">
    <div class="vm-grid">
      <div class="vm-item reveal">
        <div class="vm-icon vm-icon-green" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </div>
        <div>
          <h2 class="vm-title">Our Vision</h2>
          <p class="vm-text">Enabling Climbing Wall operators to concentrate on their passion - Climbing</p>
        </div>
      </div>
      <div class="vm-item reveal reveal-delay-1">
        <div class="vm-icon vm-icon-blue" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <div>
          <h2 class="vm-title">Our Mission</h2>
          <p class="vm-text">Be the go to provider of professional Head Office services for the indoor climbing sector</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why work with us -->
  <section class="why-section">
    <div class="why-inner">
      <div class="why-text">
        <h2 class="why-heading reveal">Why work with us?</h2>
        <ul class="why-list reveal reveal-delay-1">
          <li><strong>NICAS Partners:</strong> We're proud to partner with the National Indoor Climbing Award Schemes, supporting centres and encouraging the next generation of climbers</li>
          <li><strong>We're experienced specialists:</strong> Be it climbing, marketing, finance &amp; data or Human Resources our team has decades of experience and are happy to share it with you</li>
          <li><strong>We are industry specific –</strong> Our team is dedicated to working within the Indoor Climbing Sector.</li>
        </ul>
      </div>
      <div class="why-image reveal reveal-delay-2">
        <img src="/images/stock/climbing-woman.jpg" alt="Young woman exercising at indoor climbing gym wall" width="1024" height="682" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="testimonial-section">
    <div class="testimonial-inner">
      <div class="testimonial-card reveal">
        <div class="testimonial-stars" aria-label="5 out of 5 stars">★ ★ ★ ★ ★</div>
        <p class="testimonial-text">We are delighted to partner with ClimbHQ. The quality of support services they provide to the Climbing sector is unrivaled. The bring an innovate cost effect approach that delivers fantastic return on investment.</p>
        <div class="testimonial-author">
          <strong>Nicholas Parkin</strong>
          <span>CEO, NICAS</span>
        </div>
      </div>
      <div class="testimonial-heading reveal reveal-delay-1">
        <p class="section-label">TESTIMONIALS</p>
        <h2 class="section-title" style="color: #FFFFFF;">Partner of NICAS</h2>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-inner">
      <div class="cta-text reveal">
        <h2 class="cta-heading">Ready to Elevate Your Centre?</h2>
        <p class="cta-body">Let's work together to grow your community, fill your classes, and make your climbing centre the go-to spot for adventure.</p>
      </div>
      <div class="cta-form-wrap reveal reveal-delay-1">
        <h3 class="cta-form-title">Get in touch</h3>
        <p class="cta-form-desc">Add your email below and we'll be in touch about how we can help find more customers for your centre.</p>
        <form class="cta-form">
          <input type="email" placeholder="Your Email" required class="cta-input" />
          <button type="submit" class="btn btn-primary" style="width: 100%;">Submit</button>
        </form>
        <p class="cta-disclaimer">*Trust me, we will not spam your email</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 500px;
    display: flex;
    align-items: flex-end;
    padding: 80px 48px 60px;
    background-image: url('/images/stock/hero-bg.jpg');
    background-size: cover;
    background-position: center;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(26, 26, 46, 0.5), rgba(26, 26, 46, 0.85));
  }
  .hero-content {
    position: relative;
    max-width: 600px;
  }
  .hero-label {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: var(--color-accent);
    margin-bottom: 16px;
  }
  .hero-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(36px, 5vw, 52px);
    line-height: 1.1;
    color: #FFFFFF;
    margin-bottom: 20px;
  }
  .hero-body {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.75);
    max-width: 520px;
  }

  /* Vision & Mission */
  .vm-grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 560px;
    margin: 0 auto;
  }
  .vm-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    text-align: left;
  }
  .vm-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .vm-icon-green { background: #e8f5e9; color: #4caf50; }
  .vm-icon-blue { background: #e3f2fd; color: #2196f3; }
  .vm-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    color: var(--color-text-dark);
    margin-bottom: 4px;
  }
  .vm-text {
    font-size: 15px;
    color: #666;
    line-height: 1.5;
  }

  /* Why section */
  .why-section {
    background: var(--color-background);
    padding: 80px 48px;
  }
  .why-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .why-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 3vw, 36px);
    color: var(--color-accent);
    margin-bottom: 24px;
  }
  .why-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .why-list li {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-text-dark);
    margin-bottom: 16px;
    padding-left: 20px;
    position: relative;
  }
  .why-list li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }
  .why-image img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-card);
    object-fit: cover;
  }

  /* Testimonial */
  .testimonial-section {
    background: var(--color-section-bg);
    padding: 80px 48px;
  }
  .testimonial-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .testimonial-card {
    background: linear-gradient(135deg, rgba(6, 147, 227, 0.15), rgba(6, 147, 227, 0.05));
    border: 1px solid rgba(6, 147, 227, 0.2);
    border-radius: var(--radius-card-lg);
    padding: 40px;
  }
  .testimonial-stars {
    color: #FFD700;
    font-size: 18px;
    margin-bottom: 20px;
    letter-spacing: 4px;
  }
  .testimonial-text {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 24px;
  }
  .testimonial-author strong {
    display: block;
    color: #FFFFFF;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
  }
  .testimonial-author span {
    color: var(--color-accent);
    font-size: 14px;
  }

  /* CTA */
  .cta-section {
    padding: 80px 48px;
  }
  .cta-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .cta-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 3vw, 36px);
    color: var(--color-text-dark);
    margin-bottom: 16px;
  }
  .cta-body {
    font-size: 16px;
    color: #666;
    line-height: 1.7;
  }
  .cta-form-wrap {
    background: var(--color-section-bg);
    border-radius: var(--radius-card-lg);
    padding: 40px;
  }
  .cta-form-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    color: #FFFFFF;
    margin-bottom: 12px;
  }
  .cta-form-desc {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
    margin-bottom: 24px;
  }
  .cta-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .cta-input {
    padding: 14px 16px;
    border: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.05);
    color: #FFFFFF;
    font-size: 15px;
    border-radius: var(--radius-btn);
    outline: none;
  }
  .cta-input::placeholder { color: rgba(255, 255, 255, 0.3); }
  .cta-input:focus { border-color: var(--color-accent); }
  .cta-disclaimer {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.35);
    margin-top: 8px;
  }

  @media (max-width: 900px) {
    .hero {
      padding: 100px 20px 48px;
      min-height: 400px;
    }
    .why-section { padding: 48px 20px; }
    .why-inner { grid-template-columns: 1fr; }
    .testimonial-section { padding: 48px 20px; }
    .testimonial-inner { grid-template-columns: 1fr; }
    .cta-section { padding: 48px 20px; }
    .cta-inner { grid-template-columns: 1fr; }
  }
</style>
