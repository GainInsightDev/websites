---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-content">
      <span class="hero-badge reveal">
        <span class="hero-badge-dot" aria-hidden="true"></span>
        NICAS Partners
      </span>
      <h1 class="hero-title reveal reveal-delay-1">Helping grow your <em>climbing centre</em></h1>
      <p class="hero-subtitle reveal reveal-delay-2">Professional head office services covering marketing, accounting, and HR — so you can focus on your passion for climbing.</p>
      <div class="hero-actions reveal reveal-delay-3">
        <a href="/contact" class="btn btn-primary">Get in touch</a>
        <a href="/about" class="btn btn-secondary">Learn more</a>
      </div>
    </div>
  </section>

  <!-- Proof bar -->
  <div class="proof-bar">
    <div class="proof-stats">
      <div class="proof-stat reveal">
        <span class="proof-number">20+</span>
        <span class="proof-label">Years experience</span>
      </div>
      <div class="proof-divider" aria-hidden="true"></div>
      <div class="proof-stat reveal reveal-delay-1">
        <span class="proof-number">3</span>
        <span class="proof-label">Core services</span>
      </div>
      <div class="proof-divider" aria-hidden="true"></div>
      <div class="proof-stat reveal reveal-delay-2">
        <span class="proof-number">100%</span>
        <span class="proof-label">Climbing focused</span>
      </div>
    </div>
  </div>

  <!-- Vision -->
  <section class="section">
    <div class="section-label reveal">Our Vision</div>
    <h2 class="section-title reveal">Enabling climbing wall operators to concentrate on their passion — <em class="gradient-text">climbing</em></h2>
    <p class="section-body reveal">Be the go-to provider of professional head office services for the indoor climbing sector. We combine industry expertise with specialist knowledge to help your centre thrive.</p>
  </section>

  <!-- Services -->
  <section class="section-dark">
    <div class="section" style="padding-top: 120px; padding-bottom: 120px;">
      <div class="section-label reveal">What We Do</div>
      <h2 class="section-title reveal">Professional services built for climbing centres</h2>
      <p class="section-body reveal">Three specialist areas, one shared goal — helping your climbing centre reach new heights.</p>
      <div class="services-grid">
        <div class="service-card reveal">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </div>
          <h3 class="service-name">Marketing</h3>
          <p class="service-desc">Social media, SEO, PPC, email marketing, website design, and content creation — all tailored for the climbing sector.</p>
          <a href="/marketing-services" class="service-link">View packages →</a>
        </div>
        <div class="service-card reveal reveal-delay-1">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3 class="service-name">Accounting</h3>
          <p class="service-desc">Bookkeeping, financial reporting, KPI dashboards, and CFO access — no jargon, just clear numbers that make sense.</p>
          <a href="/accounting-services" class="service-link">View packages →</a>
        </div>
        <div class="service-card reveal reveal-delay-2">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="service-name">HR Services</h3>
          <p class="service-desc">Policies, recruitment, training, compliance, and employee engagement — creating amazing places to work.</p>
          <a href="/hr-services" class="service-link">View packages →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why ClimbHQ -->
  <section class="section">
    <div class="section-label reveal">Why ClimbHQ</div>
    <h2 class="section-title reveal">Like having an in-house team, without the overhead</h2>
    <p class="section-body reveal">We exclusively serve climbing centres, bringing deep industry knowledge and NICAS partnership to every engagement.</p>
    <div class="why-grid">
      <div class="why-item reveal">
        <span class="why-number">01</span>
        <h3 class="why-title">Climbing specialists</h3>
        <p class="why-desc">We only work with climbing centres — our entire team has deep industry experience and understands your unique challenges.</p>
      </div>
      <div class="why-item reveal reveal-delay-1">
        <span class="why-number">02</span>
        <h3 class="why-title">NICAS Partners</h3>
        <p class="why-desc">Proud partners of the National Indoor Climbing Award Scheme, recognised for our quality and commitment to the sector.</p>
      </div>
      <div class="why-item reveal reveal-delay-2">
        <span class="why-number">03</span>
        <h3 class="why-title">Cost effective</h3>
        <p class="why-desc">Flexible packages and tailored solutions that deliver fantastic ROI without the cost of building an in-house team.</p>
      </div>
      <div class="why-item reveal reveal-delay-3">
        <span class="why-number">04</span>
        <h3 class="why-title">Proven results</h3>
        <p class="why-desc">Over 20 years of combined experience in senior commercial, marketing, finance, and people leadership roles.</p>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="section-brand">
    <div class="section" style="text-align: center; padding-top: 100px; padding-bottom: 100px;">
      <div class="cta-glow" aria-hidden="true"></div>
      <blockquote class="testimonial reveal" style="position: relative;">
        <p class="testimonial-text">"The quality of support services they provide to the Climbing sector is unrivaled. They bring an innovative cost-effective approach that delivers fantastic ROI."</p>
        <cite class="testimonial-cite">Nicholas Parkin, CEO of NICAS</cite>
      </blockquote>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="text-align: center;">
    <h2 class="section-title reveal" style="max-width: 600px; margin-left: auto; margin-right: auto;">Ready to take your climbing centre to <em class="gradient-text">new heights</em>?</h2>
    <p class="section-body reveal" style="margin-left: auto; margin-right: auto;">Get in touch to discover how ClimbHQ can help your centre grow.</p>
    <div class="hero-actions reveal" style="justify-content: center;">
      <a href="/contact" class="btn btn-primary">Get in touch</a>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    padding: 160px 48px 100px;
    position: relative;
    overflow: hidden;
  }
  .hero-content {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Services grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }
  .service-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-card-lg);
    padding: 40px 32px;
    transition: transform 0.3s var(--ease-spring), background 0.3s ease;
  }
  .service-card:hover {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.08);
  }
  .service-icon {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background: rgba(13, 110, 253, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    color: var(--color-brand-light);
  }
  .service-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    color: #FFFFFF;
    margin-bottom: 12px;
  }
  .service-desc {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
    margin-bottom: 20px;
  }
  .service-link {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-brand-light);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .service-link:hover {
    color: #FFFFFF;
  }

  /* Why grid */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px 48px;
    margin-top: 48px;
  }
  .why-item {
    padding-left: 24px;
    border-left: 2px solid var(--color-border);
  }
  .why-number {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    color: var(--color-brand);
    letter-spacing: 0.05em;
    margin-bottom: 8px;
    display: block;
  }
  .why-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    color: var(--color-text);
    margin-bottom: 8px;
  }
  .why-desc {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* Testimonial */
  .testimonial-text {
    font-family: var(--font-display);
    font-size: clamp(20px, 3vw, 28px);
    font-weight: 600;
    color: #FFFFFF;
    line-height: 1.4;
    max-width: 720px;
    margin: 0 auto 24px;
  }
  .testimonial-cite {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.5);
    font-style: normal;
  }

  @media (max-width: 900px) {
    .hero {
      padding: 120px 20px 64px;
    }
    .services-grid {
      grid-template-columns: 1fr;
    }
    .why-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
