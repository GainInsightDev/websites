---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ClimbHQ — Supporting the growth of the climbing industry" description="Professional head office services for climbing centres. Marketing, HR and finance support from people who know the sector — helping you grow." bodyClass="page-home">

<!-- Hero with slideshow -->
<section class="home-hero">
  <div class="hero-slideshow" aria-hidden="true">
    <div class="hero-slideshow__slide active">
      <img src="/images/stock/young-woman-climbing-wall.jpg" alt="" width="1920" height="1080" loading="eager" />
    </div>
    <div class="hero-slideshow__slide">
      <img src="/images/stock/rear-view-athlete-climbing.jpg" alt="" width="1920" height="1080" loading="eager" />
    </div>
    <div class="hero-slideshow__slide">
      <img src="/images/stock/climbing-in-gym.jpg" alt="" width="1920" height="1080" loading="eager" />
    </div>
    <div class="hero-slideshow__slide">
      <img src="/images/stock/woman-climbing-indoor-wall.jpg" alt="" width="1920" height="1080" loading="eager" />
    </div>
  </div>
  <div class="hero-slideshow-overlay"></div>
  <div class="home-hero-inner">
    <p class="home-subtitle">Welcome to ClimbHQ</p>
    <h1>Helping grow your climbing centre</h1>
    <p class="home-hero-desc">At ClimbHQ, we're all about helping climbing centres thrive. Whether you're running a local wall or a sprawling facility, we understand the challenges (and joys!) of getting more people through your doors and onto the walls.</p>
  </div>
</section>

<!-- Vision & Mission -->
<section class="home-values">
  <div class="home-values-grid">
    <div class="value-card">
      <div class="value-icon"><i aria-hidden="true" class="jki jki-Target-light"></i></div>
      <div class="value-body">
        <h2>Our Vision</h2>
        <p>Enabling Climbing Wall operators to concentrate on their passion - Climbing</p>
      </div>
    </div>
    <div class="value-card">
      <div class="value-icon"><i aria-hidden="true" class="jki jki-compass-line"></i></div>
      <div class="value-body">
        <h2>Our Mission</h2>
        <p>Be the go to provider of professional Head Office services for the indoor climbing sector</p>
      </div>
    </div>
  </div>
</section>

<!-- Why work with us -->
<section class="home-why">
  <div class="home-why-grid">
    <div class="home-why-content">
      <h2>Why work with us?</h2>
      <ul>
        <li><strong>NICAS Partners:</strong> We're proud to partner with the National Indoor Climbing Award Schemes, supporting centres and encouraging the next generation of climbers</li>
        <li><strong>We're experienced specialists:</strong> Be it climbing, marketing, finance &amp; data or Human Resources our team has decades of experience and are happy to share it with you</li>
        <li><strong>We are industry specific –</strong> Our team is dedicated to working within the Indoor Climbing Sector.</li>
      </ul>
    </div>
    <div class="home-why-image">
      <img src="/images/stock/climbing-woman-1024.jpg" alt="young woman exercising at indoor climbing gym wall" width="800" height="533" loading="lazy" decoding="async" />
    </div>
  </div>
</section>

<!-- Testimonial -->
<section class="home-testimonial">
  <div class="home-testimonial-grid">
    <div class="testimonial-quote">
      <div class="testimonial-stars">
        <i aria-hidden="true" class="jki jki-star-solid"></i>
        <i aria-hidden="true" class="jki jki-star-solid"></i>
        <i aria-hidden="true" class="jki jki-star-solid"></i>
        <i aria-hidden="true" class="jki jki-star-solid"></i>
        <i aria-hidden="true" class="jki jki-star-solid"></i>
      </div>
      <blockquote>We are delighted to partner with ClimbHQ. The quality of support services they provide to the Climbing sector is unrivaled. The bring an innovate cost effect approach that delivers fantastic return on investment.</blockquote>
      <p class="testimonial-author"><strong>Nicholas Parkin</strong></p>
      <p class="testimonial-role">CEO, NICAS</p>
    </div>
    <div class="testimonial-label">
      <p class="home-subtitle">Testimonials</p>
      <h2>Partner of NICAS</h2>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="home-cta">
  <div class="home-cta-grid">
    <div class="home-cta-text">
      <h2>Ready to Elevate Your Centre?</h2>
      <p>Let's work together to grow your community, fill your classes, and make your climbing centre the go-to spot for adventure.</p>
    </div>
    <div class="home-cta-form">
      <h3>Get in touch</h3>
      <p>Add your email below and we'll be in touch about how we can help find more customers for your centre.</p>
      <form method="post" class="home-email-form">
        <div class="home-email-row">
          <input type="email" name="email" placeholder="Your Email" required />
          <button type="submit">Submit</button>
        </div>
      </form>
      <p class="home-email-disclaimer">* Trust me, we will not spam your email</p>
    </div>
  </div>
</section>

</Layout>

<style is:global>
/* ===== Homepage Hero ===== */
.home-hero {
  position: relative;
  overflow: hidden;
  padding: 250px 24px 220px;
  margin-bottom: -4.5%;
  z-index: 1;
}
.hero-slideshow {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.hero-slideshow__slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 500ms ease-in-out;
  will-change: opacity, transform;
}
.hero-slideshow__slide.active {
  opacity: 1;
}
.hero-slideshow__slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}
@keyframes kenBurnsOut {
  0% { transform: scale(1.2); }
  100% { transform: scale(1); }
}
.hero-slideshow__slide.active img {
  animation: kenBurnsOut 5.5s ease-out forwards;
}
.hero-slideshow-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(200deg, #071F33 20%, rgba(47, 36, 27, 0.78) 80%);
  z-index: 1;
  opacity: 0.75;
  pointer-events: none;
}
.home-hero-inner {
  position: relative;
  z-index: 2;
  max-width: 700px;
}
.home-subtitle {
  font-family: 'Montserrat', sans-serif;
  font-size: 15px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 4px;
  color: #5ED4F5;
  margin-bottom: 16px;
}
.home-hero h1 {
  font-family: 'Unbounded', sans-serif;
  font-size: clamp(36px, 5vw, 60px);
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
  margin: 0 0 24px;
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
}
.home-hero-desc {
  font-family: 'Montserrat', sans-serif;
  font-size: 16px;
  line-height: 1.8;
  color: #d0d4dc;
  margin: 0;
}

/* ===== Values (Vision/Mission) ===== */
.home-values {
  background: url('/images/bg/shape-6.png') 0px -1% / contain no-repeat,
    #03071F;
  padding: 80px 24px;
  position: relative;
  z-index: 2;
}
.home-values-grid {
  max-width: 600px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 24px;
}
.value-card {
  display: flex;
  gap: 20px;
  align-items: flex-start;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 12px;
  padding: 32px;
}
.value-icon {
  font-size: 32px;
  color: #5ED4F5;
  flex-shrink: 0;
}
.value-body h2 {
  font-family: 'Unbounded', sans-serif !important;
  font-size: 20px !important;
  font-weight: 700 !important;
  color: #ffffff !important;
  margin: 0 0 8px;
}
.value-body p {
  font-family: 'Montserrat', sans-serif;
  font-size: 14px;
  line-height: 1.7;
  color: #9796A3;
  margin: 0;
}

/* ===== Why Work With Us ===== */
.home-why {
  background: #03071F;
  padding: 60px 24px 80px;
}
.home-why-grid {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: center;
}
.home-why-content h2 {
  font-family: 'Unbounded', sans-serif !important;
  font-size: 28px !important;
  font-weight: 700 !important;
  color: #ffffff !important;
  margin: 0 0 24px;
}
.home-why-content ul {
  list-style: none;
  padding: 0;
  margin: 0;
}
.home-why-content li {
  font-family: 'Montserrat', sans-serif;
  font-size: 15px;
  line-height: 1.8;
  color: #9796A3;
  padding: 12px 0 12px 24px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  position: relative;
}
.home-why-content li::before {
  content: '✓';
  position: absolute;
  left: 0;
  color: #5ED4F5;
}
.home-why-content strong {
  color: #ffffff;
}
.home-why-image img {
  width: 100%;
  height: auto;
  border-radius: 12px;
}

/* ===== Testimonial ===== */
.home-testimonial {
  background: url('/images/bg/shape-6.png') 0px -1% / contain no-repeat,
    #071F33;
  padding: 80px 24px;
}
.home-testimonial-grid {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.5fr 1fr;
  gap: 48px;
  align-items: center;
}
.testimonial-stars {
  color: #FFA269;
  font-size: 18px;
  margin-bottom: 16px;
  display: flex;
  gap: 4px;
}
.testimonial-quote blockquote {
  font-family: 'Montserrat', sans-serif;
  font-size: 16px;
  line-height: 1.8;
  color: #eef0f4;
  margin: 0 0 20px;
  padding: 0;
  border: none;
}
.testimonial-author {
  font-family: 'Montserrat', sans-serif;
  font-size: 14px;
  color: #ffffff;
  margin: 0;
}
.testimonial-role {
  font-family: 'Montserrat', sans-serif;
  font-size: 13px;
  color: #9796A3;
  margin: 4px 0 0;
}
.testimonial-label h2 {
  font-family: 'Unbounded', sans-serif !important;
  font-size: clamp(28px, 4vw, 40px) !important;
  font-weight: 700 !important;
  color: #ffffff !important;
  margin: 0;
}

/* ===== CTA ===== */
.home-cta {
  background: url('/images/bg/shape-8.png') top center / contain no-repeat,
    #03071F;
  padding: 80px 24px;
}
.home-cta-grid {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: center;
}
.home-cta-text h2 {
  font-family: 'Unbounded', sans-serif !important;
  font-size: clamp(24px, 3vw, 32px) !important;
  font-weight: 700 !important;
  color: #ffffff !important;
  margin: 0 0 16px;
}
.home-cta-text p {
  font-family: 'Montserrat', sans-serif;
  font-size: 15px;
  line-height: 1.8;
  color: #9796A3;
  margin: 0;
}
.home-cta-form {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12px;
  padding: 40px 32px;
}
.home-cta-form h3 {
  font-family: 'Unbounded', sans-serif;
  font-size: 20px;
  font-weight: 600;
  color: #ffffff;
  margin: 0 0 8px;
}
.home-cta-form > p {
  font-family: 'Montserrat', sans-serif;
  font-size: 14px;
  color: #9796A3;
  margin: 0 0 20px;
  line-height: 1.6;
}
.home-email-row {
  display: flex;
  gap: 0;
}
.home-email-row input {
  flex: 1;
  padding: 12px 16px;
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-right: none;
  border-radius: 4px 0 0 4px;
  background: rgba(255, 255, 255, 0.05);
  color: #ffffff;
  font-family: 'Montserrat', sans-serif;
  font-size: 14px;
}
.home-email-row input::placeholder {
  color: #9796A3;
}
.home-email-row button {
  padding: 12px 24px;
  border: 1px solid #5ED4F5;
  border-radius: 0 4px 4px 0;
  background: #5ED4F5;
  color: #03071F;
  font-family: 'Unbounded', sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s ease;
}
.home-email-row button:hover {
  background: #4DC4E5;
}
.home-email-disclaimer {
  font-size: 12px;
  color: #6b6a77;
  margin-top: 8px;
}

/* ===== Mobile ===== */
@media (max-width: 768px) {
  .home-hero {
    padding: 160px 24px 140px;
  }
  .home-values-grid {
    max-width: 100%;
  }
  .home-why-grid {
    grid-template-columns: 1fr;
  }
  .home-testimonial-grid {
    grid-template-columns: 1fr;
  }
  .home-cta-grid {
    grid-template-columns: 1fr;
  }
}
</style>

<script>
  // Hero slideshow — Ken Burns fade effect
  (function() {
    const slides = document.querySelectorAll('.hero-slideshow__slide');
    if (slides.length < 2) return;
    let current = 0;
    const duration = 5000;

    setInterval(() => {
      slides[current].classList.remove('active');
      current = (current + 1) % slides.length;
      slides[current].classList.add('active');
    }, duration);
  })();
</script>
