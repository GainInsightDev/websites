---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — ClimbHQ" description="Get in touch with ClimbHQ. Discover how we can help your climbing centre grow.">
  <!-- Hero -->
  <section class="hero-page">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container">
      <span class="hero-badge reveal">
        <span class="hero-badge-dot" aria-hidden="true"></span>
        Contact
      </span>
      <h1 class="hero-title reveal reveal-delay-1">Let's <em>talk</em></h1>
      <p class="hero-subtitle reveal reveal-delay-2">We'd love to hear from you. Complete the form and discover how we can help your climbing centre grow.</p>
    </div>
  </section>

  <!-- Contact form + info -->
  <section class="section">
    <div class="contact-grid">
      <div class="contact-form-col reveal">
        <form class="contact-form" name="contact" method="POST" data-netlify="true">
          <div class="form-group">
            <label for="name" class="form-label">Name</label>
            <input type="text" id="name" name="name" required class="form-input" placeholder="Your name" />
          </div>
          <div class="form-group">
            <label for="phone" class="form-label">Phone</label>
            <input type="tel" id="phone" name="phone" class="form-input" placeholder="Your phone number" />
          </div>
          <div class="form-group">
            <label for="email" class="form-label">Email</label>
            <input type="email" id="email" name="email" required class="form-input" placeholder="you@example.com" />
          </div>
          <div class="form-group">
            <label for="message" class="form-label">Message</label>
            <textarea id="message" name="message" required rows="5" class="form-input form-textarea" placeholder="Tell us about your climbing centre and how we can help..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width: 100%;">Send message</button>
        </form>
      </div>
      <div class="contact-info-col reveal reveal-delay-2">
        <div class="contact-info-card">
          <h3 class="contact-info-title">Email us</h3>
          <a href="mailto:hello@climbhq.co.uk" class="contact-info-link">hello@climbhq.co.uk</a>
        </div>
        <div class="contact-info-card">
          <h3 class="contact-info-title">Follow us</h3>
          <div class="contact-socials">
            <a href="https://www.facebook.com/profile.php?id=61574224461872" target="_blank" rel="noopener noreferrer">Facebook</a>
            <a href="https://www.instagram.com/climb_hq" target="_blank" rel="noopener noreferrer">Instagram</a>
            <a href="https://www.linkedin.com/company/climbhq/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          </div>
        </div>
        <div class="contact-info-card">
          <h3 class="contact-info-title">Our services</h3>
          <p class="contact-info-text">We provide marketing, accounting, and HR services exclusively for climbing centres across the UK.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .form-label {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
  }
  .form-input {
    padding: 14px 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-btn);
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--color-text);
    background: var(--color-surface);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    outline: none;
  }
  .form-input:focus {
    border-color: var(--color-brand);
    box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.1);
  }
  .form-input::placeholder {
    color: var(--color-text-muted);
  }
  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }
  .contact-info-col {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .contact-info-card {
    padding: 28px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
  }
  .contact-info-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
    color: var(--color-text);
    margin-bottom: 12px;
  }
  .contact-info-link {
    font-size: 16px;
    color: var(--color-brand);
    text-decoration: none;
    font-weight: 600;
  }
  .contact-info-link:hover {
    text-decoration: underline;
  }
  .contact-info-text {
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
  .contact-socials {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .contact-socials a {
    font-size: 15px;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .contact-socials a:hover {
    color: var(--color-brand);
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
</style>
