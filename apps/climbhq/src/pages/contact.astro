---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — ClimbHQ" description="Get in touch with ClimbHQ — book a free call with our marketing, HR or finance specialists. We work exclusively with indoor climbing centres." bodyClass="page-contact">

<section class="contact-hero">
  <div class="contact-hero-inner">
    <h1>Contact</h1>
  </div>
</section>

<section class="contact-content">
  <div class="contact-grid">
    <!-- Contact form -->
    <div class="contact-form-col">
      <form class="contact-form" method="post" name="contact">
        <div class="form-field">
          <label for="contact-name">Name</label>
          <input type="text" name="name" id="contact-name" placeholder="Name" />
        </div>
        <div class="form-field">
          <label for="contact-phone">Phone</label>
          <input type="tel" name="phone" id="contact-phone" placeholder="Phone" required pattern="[0-9()#&+*\-=.]+" title="Only numbers and phone characters (#, -, *, etc) are accepted." />
        </div>
        <div class="form-field">
          <label for="contact-email">Email</label>
          <input type="email" name="email" id="contact-email" placeholder="Email" required />
        </div>
        <div class="form-field">
          <label for="contact-message">Message</label>
          <textarea name="message" id="contact-message" rows="4" placeholder="Message"></textarea>
        </div>
        <!-- Honeypot -->
        <input type="text" name="hp_field" style="display:none !important;" tabindex="-1" autocomplete="off" />
        <button type="submit" class="contact-submit">Send</button>
      </form>
    </div>

    <!-- Info column -->
    <div class="contact-info-col">
      <p class="contact-subtitle">Get In Touch</p>
      <h2>Send Us Message</h2>
      <p>We'd love to hear from you. Complete the form and discover how we can help your climbing centre grow.</p>

      <hr class="contact-divider" />

      <h3>Our Social Media</h3>
      <div class="contact-social">
        <a href="https://www.facebook.com/profile.php?id=61574224461872" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <i aria-hidden="true" class="fab fa-facebook"></i>
        </a>
        <a href="https://www.instagram.com/climb_hq?igsh=ZnFjZ3N0aWpwdDU2" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <i aria-hidden="true" class="fab fa-instagram"></i>
        </a>
        <a href="https://www.linkedin.com/company/climbhq/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <i aria-hidden="true" class="fab fa-linkedin"></i>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
/* Contact hero */
.contact-hero {
  background: linear-gradient(200deg, #071F33 20%, rgba(47, 36, 27, 0.78) 80%),
    url('/images/bg/silhouette-rock-climber-sunset.jpg') center/cover no-repeat;
  padding: 200px 24px 170px;
  text-align: center;
  margin-bottom: -4.5%;
  position: relative;
  z-index: 1;
}
.contact-hero h1 {
  font-family: 'Unbounded', sans-serif;
  font-size: clamp(36px, 5vw, 60px);
  font-weight: 700;
  color: #ffffff;
  margin: 0;
}

/* Content section */
.contact-content {
  background: url('/images/bg/shape-8.png') top center / contain no-repeat,
    #03071F;
  padding: 80px 24px;
  position: relative;
  z-index: 2;
}
.contact-grid {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
}

/* Form */
.contact-form {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.form-field label {
  display: block;
  font-family: 'Montserrat', sans-serif;
  font-size: 14px;
  font-weight: 500;
  color: #ffffff;
  margin-bottom: 6px;
}
.form-field input,
.form-field textarea {
  width: 100%;
  padding: 12px 16px;
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 4px;
  background: rgba(255, 255, 255, 0.05);
  color: #ffffff;
  font-family: 'Montserrat', sans-serif;
  font-size: 14px;
}
.form-field input::placeholder,
.form-field textarea::placeholder {
  color: #9796A3;
}
.form-field input:focus,
.form-field textarea:focus {
  outline: none;
  border-color: #5ED4F5;
}
.contact-submit {
  padding: 14px 40px;
  border: none;
  border-radius: 4px;
  background: #5ED4F5;
  color: #03071F;
  font-family: 'Unbounded', sans-serif;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s ease;
  align-self: flex-start;
}
.contact-submit:hover {
  background: #4DC4E5;
}

/* Info column */
.contact-info-col {
  color: #9796A3;
}
.contact-subtitle {
  font-family: 'Montserrat', sans-serif;
  font-size: 14px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 3px;
  color: #5ED4F5;
  margin-bottom: 8px;
}
.contact-info-col h2 {
  font-family: 'Unbounded', sans-serif !important;
  font-size: 32px !important;
  font-weight: 600 !important;
  color: #ffffff !important;
  margin-bottom: 16px;
}
.contact-info-col p {
  font-family: 'Montserrat', sans-serif;
  font-size: 15px;
  line-height: 1.7;
  color: #9796A3;
}
.contact-divider {
  border: none;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  margin: 32px 0;
}
.contact-info-col h3 {
  font-family: 'Unbounded', sans-serif;
  font-size: 18px;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 16px;
}
.contact-social {
  display: flex;
  gap: 12px;
}
.contact-social a {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  color: #5ED4F5;
  font-size: 18px;
  text-decoration: none;
  transition: background 0.2s ease, transform 0.2s ease;
}
.contact-social a:hover {
  background: #5ED4F5;
  color: #03071F;
  transform: scale(0.95);
}

/* Mobile */
@media (max-width: 768px) {
  .contact-hero {
    padding: 140px 24px 100px;
  }
  .contact-grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .contact-info-col {
    order: -1;
  }
}
</style>

</Layout>
