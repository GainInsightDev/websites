---
import Layout from '../layouts/Layout.astro';

const packages = [
  {
    name: 'Basics',
    price: '£249 per month*',
    features: [
      'Policy templates and customisation',
      'Quarterly compliance monitoring',
      'Annual risk assessments',
      'Basic time and attendance tracking',
      '24/7 Q&A support',
    ],
  },
  {
    name: 'Essentials',
    price: '£449 per month*',
    features: [
      'Everything in Basics',
      '5 hours monthly HR consultancy',
      'Recruitment support (job descriptions, posting guidance)',
      'Standard training library access',
      'Performance review templates',
      'Crisis management and annual safety training',
    ],
  },
  {
    name: 'Complete',
    price: '£949 per month*',
    features: [
      'Everything in Essentials',
      'Fully customised policies with implementation',
      'Monthly compliance reviews',
      'Up to 15 hours monthly consultation',
      'Full recruitment cycle management',
      'Custom employee engagement initiatives',
      'Diversity and inclusion strategy development',
      'Wellness program design',
      'Custom training delivery',
      'Full HRIS setup and integration',
      'Advanced scheduling systems',
    ],
  },
];

const addons = [
  { name: 'On-Site HR Support', price: '£300/day' },
  { name: 'Employee Satisfaction Survey', price: '£575/annually' },
  { name: 'Team Building Event', price: 'Starting at £700' },
  { name: 'Advanced Leadership Training', price: '£950/program' },
];
---

<Layout title="HR Services — ClimbHQ" description="HR policies, recruitment, training, and compliance packages designed for climbing centres.">
  <!-- Banner -->
  <section class="page-banner" style="background-image: url('/images/stock/climbing-man-rear.jpg');">
    <h2>HR Services</h2>
    <p>Creating amazing places to work, where team members know they are looked after and treated fairly.</p>
  </section>

  <!-- Pricing -->
  <section class="section-navy" style="padding: 80px 48px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div class="pricing-grid">
        {packages.map((pkg) => (
          <div class="pricing-card reveal">
            <h3 class="pricing-name">{pkg.name}</h3>
            <p class="pricing-price">{pkg.price}</p>
            <ul class="pricing-features">
              {pkg.features.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Add-ons -->
  <section class="section" style="text-align: center;">
    <p class="section-label reveal">ADD-ON SERVICES</p>
    <h2 class="section-title reveal">Additional support when you need it</h2>
    <p class="section-body reveal" style="margin-left: auto; margin-right: auto;">All packages include a dedicated HR consultant and are priced monthly per site.</p>
    <div class="addon-grid">
      {addons.map((addon, i) => (
        <div class={`addon-item reveal reveal-delay-${i + 1}`}>
          <span class="addon-name">{addon.name}</span>
          <span class="addon-price">{addon.price}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="section-navy" style="padding: 80px 48px; text-align: center;">
    <div class="section">
      <h2 class="section-title reveal" style="color: #FFFFFF;">Ready to build a better workplace?</h2>
      <p class="section-body reveal" style="margin-left: auto; margin-right: auto;">Let's discuss which HR package is right for your climbing centre.</p>
      <a href="/contact" class="btn btn-primary reveal">Get in touch</a>
    </div>
  </section>
</Layout>

<style>
  .addon-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-top: 32px;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
    text-align: left;
  }
  .addon-item {
    padding: 20px;
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-btn);
  }
  .addon-name {
    display: block;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 16px;
    color: var(--color-text-dark);
    margin-bottom: 4px;
  }
  .addon-price {
    font-size: 14px;
    color: var(--color-accent);
    font-weight: 600;
  }
  @media (max-width: 900px) {
    .addon-grid { grid-template-columns: 1fr; }
  }
</style>
