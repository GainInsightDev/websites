---
import Layout from '../layouts/Layout.astro';

const services = [
  { name: 'Social Media Marketing', desc: 'Platform management across Instagram, Facebook, and TikTok with content creation and targeted ad campaigns to build community engagement.' },
  { name: 'Search Engine Optimisation', desc: 'Keyword research and technical improvements to increase visibility in search results for local climbing centre searches.' },
  { name: 'Pay-Per-Click Advertising', desc: 'Google Ads campaigns targeting potential climbers with focus on ROI maximisation.' },
  { name: 'Email Marketing', desc: 'Professional messaging about classes, offers, and updates with personalised content and design.' },
  { name: 'Website Design & Optimisation', desc: 'New website creation or existing site improvements emphasising user-friendly, conversion-focused design.' },
  { name: 'Content Marketing', desc: 'Blog articles, guides, and downloadable resources positioning your centre as a climbing authority.' },
];

const packages = [
  {
    name: 'Base Camp',
    price: '£499',
    featured: false,
    features: [
      'Website audit',
      '3 weekly social posts',
      'Google My Business management',
    ],
  },
  {
    name: 'Summit Club',
    price: '£999',
    featured: true,
    features: [
      'Everything in Base Camp',
      '6 weekly social posts',
      'CRM setup',
      'Email newsletters',
      'SMS campaigns',
      'Blog creation',
      'Paid awareness campaign',
    ],
  },
  {
    name: 'Peak Performer',
    price: '£1,299',
    featured: false,
    features: [
      'Everything in Summit Club',
      '9 weekly social posts',
      'Review outreach',
      'Booking system integration',
      '2 custom lead campaigns',
      'Weekly newsletters',
      'Quarterly reporting',
    ],
  },
];
---

<Layout title="Marketing Services — ClimbHQ" description="Social media, SEO, PPC, email marketing, and content creation packages designed specifically for climbing centres.">
  <!-- Hero -->
  <section class="hero-page">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container">
      <span class="hero-badge reveal">
        <span class="hero-badge-dot" aria-hidden="true"></span>
        Marketing
      </span>
      <h1 class="hero-title reveal reveal-delay-1">Marketing that <em>climbs</em></h1>
      <p class="hero-subtitle reveal reveal-delay-2">Digital marketing solutions built exclusively for climbing centres. Attract visitors, boost engagement, and drive memberships.</p>
      <div class="hero-actions reveal reveal-delay-3">
        <a href="/contact" class="btn btn-primary">Get started</a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="section-label reveal">Our Services</div>
    <h2 class="section-title reveal">Six core marketing services</h2>
    <p class="section-body reveal">Everything your climbing centre needs to build a strong digital presence and attract more climbers.</p>
    <div class="services-detail-grid">
      {services.map((service, i) => (
        <div class={`card reveal reveal-delay-${(i % 3) + 1}`}>
          <h3 class="service-detail-name">{service.name}</h3>
          <p class="service-detail-desc">{service.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Pricing -->
  <section class="section" style="border-top: 1px solid var(--color-border);">
    <div class="section-label reveal">Pricing</div>
    <h2 class="section-title reveal">Choose your package</h2>
    <p class="section-body reveal">Transparent pricing with no hidden fees. All packages are monthly per site.</p>
    <div class="pricing-grid">
      {packages.map((pkg) => (
        <div class={`pricing-card reveal${pkg.featured ? ' featured' : ''}`}>
          <h3 class="pricing-name">{pkg.name}</h3>
          <p class="pricing-price">{pkg.price}</p>
          <p class="pricing-period">per month</p>
          <ul class="pricing-features">
            {pkg.features.map((feature) => (
              <li>{feature}</li>
            ))}
          </ul>
          <a href="/contact" class={`btn ${pkg.featured ? 'btn-primary' : 'btn-secondary'}`} style="width: 100%;">Get in touch</a>
        </div>
      ))}
    </div>
    <p class="pricing-note reveal">Additional costs apply for SMS (£0.05 per message) and email campaigns (£0.60 per 1,000 sent).</p>
  </section>

  <!-- CTA -->
  <section class="section-brand">
    <div class="section" style="text-align: center; padding-top: 100px; padding-bottom: 100px;">
      <div class="cta-glow" aria-hidden="true"></div>
      <h2 class="section-title reveal" style="position: relative;">Ready to boost your visibility?</h2>
      <p class="section-body reveal" style="margin-left: auto; margin-right: auto; position: relative;">Let's discuss which marketing package is right for your climbing centre.</p>
      <div class="hero-actions reveal" style="justify-content: center; position: relative;">
        <a href="/contact" class="btn btn-outline-light">Get in touch</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .services-detail-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }
  .service-detail-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    color: var(--color-text);
    margin-bottom: 12px;
  }
  .service-detail-desc {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
  .pricing-note {
    margin-top: 24px;
    font-size: 14px;
    color: var(--color-text-muted);
    text-align: center;
  }

  @media (max-width: 900px) {
    .services-detail-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
