---
import Layout from '../layouts/Layout.astro';

const services = [
  { name: 'Social Media Marketing', tagline: 'Get your centre noticed online.', desc: "We'll manage your social media accounts, create engaging content, and run targeted ad campaigns on platforms like Instagram, Facebook, and TikTok. From eye-catching posts to data-driven strategies, we'll connect you with your audience and build your community." },
  { name: 'Search Engine Optimization (SEO)', tagline: 'Help climbers find you first.', desc: "We'll optimise your website to rank higher in search engine results, ensuring local climbers can easily find your centre. From keyword research to technical improvements, we'll boost your visibility and drive more traffic to your site." },
  { name: 'Pay-Per-Click (PPC) Advertising', tagline: 'Turn clicks into climbers.', desc: "We'll run targeted PPC campaigns through Google Ads to help you reach potential climbers actively searching for climbing centres or related activities. Our goal is to maximise your return on investment and fill your walls." },
  { name: 'Email Marketing Campaigns', tagline: 'Stay connected with your community.', desc: "We'll craft professional email campaigns that keep climbers in the loop about new classes, special offers, and centre updates. With personalized messaging and stunning designs, we'll help you build loyalty and engagement." },
  { name: 'Website Design & Optimization', tagline: "Your centre's digital home, perfected.", desc: "From creating new websites to optimising existing ones, we'll ensure your online presence is as inviting and functional as your climbing walls. Our designs are clean, user-friendly, and built to convert visitors into loyal climbers." },
  { name: 'Content Marketing', tagline: 'Tell your story, inspire action.', desc: "We'll create engaging blogs, articles, and downloadable resources tailored to your audience. Whether it's a guide for beginners or tips for experienced climbers, content marketing builds trust and positions your centre as an authority in the climbing world." },
];

const packages = [
  {
    name: 'Base Camp',
    price: '£499 per month*',
    features: [
      'Website audit and SEO optimisation',
      'Social media management - 3 social posts per week across 3 channels including graphic creation and copy writing.',
      'Google My Business set up/management - monthly updates and optimisation',
    ],
  },
  {
    name: 'Summit Club',
    price: '£999 per month*',
    features: [
      'Everything in Base Camp',
      'Social media management - 6 social posts per week across 3 channels including graphic creation and copy writing.',
      'CRM set up with GoHighLevel',
      'Email newsletter twice per month',
      'SMS text campaign 2 per month',
      'Blog creation for website',
      'Advanced keyword monitoring and backlink building to increase SEO presence',
      'Monthly strategy report',
      '1 social media paid brand awareness campaign per month',
      '*Text and email campaigns charged in units at the following rates:',
      'Text: £0.05',
      'Email: £0.60 per 1,000 sent',
    ],
  },
  {
    name: 'Peak Performer',
    price: '£1299 per month*',
    features: [
      'Everything in Summit Club',
      'Google My Business review outreach',
      'Full integration of marketing CRM with booking systems and email automations.',
      'Social media management - 9 social posts per week across 3 channels including graphic creation and copy writing.',
      'Weekly newsletter',
      '2* custom lead generation campaign on social media or Google Ads*',
      'Landing page creation for lead generation campaigns',
      '4 SMS campaigns per month',
      'Quarterly deep dive reporting',
      'Monthly status report',
      '*Additional ad spend required for paid campaigns',
    ],
  },
];
---

<Layout title="Marketing Services — ClimbHQ" description="Digital marketing packages designed specifically for climbing centres. Social media, SEO, PPC, and more.">
  <!-- Banner -->
  <section class="page-banner" style="background-image: url('/images/stock/climbing-man-fit.jpg');">
    <h2>Marketing Services</h2>
    <p>The packages below are an example of our monthly, fixed cost service.<br/>Bespoke services are provided on request – Get in touch today to find out more!</p>
  </section>

  <!-- Services detail -->
  <section class="services-section section-dark">
    <div class="services-inner">
      <div class="services-heading">
        <p class="section-label reveal">HOW WE SUPPORT YOU</p>
        <h2 class="section-title reveal" style="color: #FFFFFF;">The growth starts here</h2>
        <a href="/contact" class="btn btn-primary reveal">Get in touch</a>
      </div>
      <div class="services-list">
        {services.map((service, i) => (
          <div class={`service-item reveal reveal-delay-${(i % 3) + 1}`}>
            <div class="service-icon-circle" aria-hidden="true"></div>
            <div>
              <h3 class="service-name">{service.name}</h3>
              <p class="service-tagline"><em>{service.tagline}</em></p>
              <p class="service-desc">{service.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section-navy" style="padding: 80px 48px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div class="pricing-grid">
        {packages.map((pkg) => (
          <div class="pricing-card reveal">
            <h3 class="pricing-name">{pkg.name}</h3>
            <p class="pricing-price">{pkg.price}</p>
            <ul class="pricing-features">
              {pkg.features.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .services-section {
    padding: 80px 48px;
  }
  .services-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 64px;
  }
  .services-heading {
    position: sticky;
    top: 100px;
    align-self: start;
  }
  .services-list {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  .service-item {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }
  .service-icon-circle {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
  }
  .service-name {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 18px;
    color: #FFFFFF;
    margin-bottom: 4px;
  }
  .service-tagline {
    font-size: 14px;
    color: var(--color-accent);
    margin-bottom: 8px;
  }
  .service-desc {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .services-section { padding: 48px 20px; }
    .services-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .services-heading {
      position: static;
    }
  }
</style>
