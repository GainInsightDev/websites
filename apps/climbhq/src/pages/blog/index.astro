---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    href: '/blog/march-consistency-check',
    title: 'The March Consistency Check',
    date: 'March 17, 2026',
    excerpt: 'As Q1 comes to an end, March is a good moment to pause and ask three simple questions about what\'s predictable, where people linger, and what quietly faded.',
    image: '/images/stock/rear-view-athlete-climbing.jpg',
    imageAlt: 'Climber on wall',
  },
  {
    href: '/blog/campfire-effect',
    title: 'The Campfire Effect: How Belonging Is Built in Climbing Centres',
    date: 'February 6, 2026',
    excerpt: 'The New Year rush fades, routines start to settle, and climbing centres begin to see what actually sticks. Here\'s how the best centres build belonging that lasts.',
    image: '/images/stock/climbing-in-gym.jpg',
    imageAlt: 'Community climbing in a gym',
  },
  {
    href: '/blog/january-footfall',
    title: 'January Footfall Is Easy. Turning It Into Long-Term Performance Isn\'t.',
    date: 'January 16, 2026',
    excerpt: 'January is usually busy for climbing centres. New Year motivation brings lots of people trying climbing for the first time. The question is - how many come back?',
    image: '/images/stock/young-woman-bouldering-overhanging.jpg',
    imageAlt: 'Woman bouldering on overhanging wall',
  },
];
---

<Layout title="Blog - ClimbHQ" description="Insights and ideas for climbing centre owners from the ClimbHQ team - practical thinking on marketing, finance and people from people who know the sector." bodyClass="climbhq-blog-index">

  <!-- Hero -->
  <section class="blog-hero">
    <div class="blog-hero-inner">
      <p class="blog-hero-label">Insights &amp; Ideas</p>
      <h1 class="blog-hero-title">The ClimbHQ Blog</h1>
      <p class="blog-hero-sub">Practical thinking for climbing centre owners - from the people who work with them every day.</p>
    </div>
  </section>

  <!-- Post grid -->
  <section class="blog-grid-section">
    <div class="blog-grid-container">
      <div class="blog-grid">
        {posts.map((post) => (
          <article class="blog-card">
            <a href={post.href} class="blog-card-image-link">
              <img
                src={post.image}
                alt={post.imageAlt}
                width="800"
                height="450"
                loading="lazy"
                class="blog-card-image"
              />
            </a>
            <div class="blog-card-body">
              <p class="blog-card-date">{post.date}</p>
              <h2 class="blog-card-title">
                <a href={post.href}>{post.title}</a>
              </h2>
              <p class="blog-card-excerpt">{post.excerpt}</p>
              <a href={post.href} class="blog-card-cta">Read More</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .blog-hero {
    background: #03071F;
    padding: 100px 24px 80px;
    text-align: center;
    border-bottom: 1px solid rgba(24, 171, 215, 0.15);
  }
  .blog-hero-inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .blog-hero-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 4px;
    color: #18ABD7;
    margin: 0 0 16px;
  }
  .blog-hero-title {
    font-family: 'Unbounded', sans-serif;
    font-size: 48px;
    font-weight: 500;
    color: #ffffff;
    margin: 0 0 20px;
    line-height: 1.2;
  }
  .blog-hero-sub {
    font-family: 'Montserrat', sans-serif;
    font-size: 17px;
    font-weight: 400;
    color: #9796A3;
    line-height: 1.7;
    margin: 0;
  }

  @media (max-width: 768px) {
    .blog-hero { padding: 72px 20px 60px; }
    .blog-hero-title { font-size: 32px; }
  }

  /* Grid section */
  .blog-grid-section {
    background: #071F33;
    padding: 80px 24px 100px;
  }
  .blog-grid-container {
    max-width: 1200px;
    margin: 0 auto;
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  @media (max-width: 1024px) {
    .blog-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .blog-grid { grid-template-columns: 1fr; }
    .blog-grid-section { padding: 60px 20px 80px; }
  }

  /* Card */
  .blog-card {
    background: #2B2937;
    border: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .blog-card:hover {
    border-color: rgba(24, 171, 215, 0.4);
    transform: translateY(-3px);
  }

  .blog-card-image-link {
    display: block;
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }
  .blog-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .blog-card:hover .blog-card-image {
    transform: scale(1.04);
  }

  .blog-card-body {
    padding: 28px 28px 32px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .blog-card-date {
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #18ABD7;
    margin: 0 0 12px;
  }

  .blog-card-title {
    font-family: 'Unbounded', sans-serif;
    font-size: 18px;
    font-weight: 500;
    line-height: 1.4;
    margin: 0 0 16px;
  }
  .blog-card-title a {
    color: #ffffff;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .blog-card-title a:hover {
    color: #18ABD7;
  }

  .blog-card-excerpt {
    font-family: 'Montserrat', sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: #9796A3;
    line-height: 1.7;
    margin: 0 0 24px;
    flex: 1;
  }

  .blog-card-cta {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: #18ABD7;
    text-decoration: none;
    border-bottom: 1px solid rgba(24, 171, 215, 0.4);
    padding-bottom: 2px;
    align-self: flex-start;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .blog-card-cta:hover {
    border-color: #18ABD7;
    color: #ffffff;
  }
</style>
