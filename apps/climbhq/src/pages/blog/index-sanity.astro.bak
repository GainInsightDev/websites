---
import Layout from '../../layouts/Layout.astro';
import { fetchAll } from '../../lib/sanity';

let posts: any[] = [];
try {
  posts = await fetchAll('post', 'publishedAt desc');
} catch {
  // Sanity content not yet available
}
---

<Layout title="Blog — ClimbHQ" description="Insights, tips, and strategies for growing your climbing centre. Expert advice from ClimbHQ.">
  <!-- Hero -->
  <section class="hero-page">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container">
      <span class="hero-badge reveal">
        <span class="hero-badge-dot" aria-hidden="true"></span>
        Blog
      </span>
      <h1 class="hero-title reveal reveal-delay-1">Insights & <em>advice</em></h1>
      <p class="hero-subtitle reveal reveal-delay-2">Tips, strategies, and industry insights to help your climbing centre grow.</p>
    </div>
  </section>

  <!-- Posts -->
  <section class="section">
    {posts.length > 0 ? (
      <div class="blog-grid">
        {posts.map((post: any, i: number) => (
          <a href={`/blog/${post.slug?.current}`} class={`blog-card card reveal reveal-delay-${(i % 3) + 1}`}>
            <span class="blog-date">{new Date(post.publishedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
            <h2 class="blog-title">{post.title}</h2>
            {post.excerpt && <p class="blog-excerpt">{post.excerpt}</p>}
            <span class="blog-read-more">Read more →</span>
          </a>
        ))}
      </div>
    ) : (
      <div class="blog-empty reveal">
        <h2 class="section-title">Coming soon</h2>
        <p class="section-body">We're working on our first articles. Check back soon for insights on growing your climbing centre.</p>
        <a href="/contact" class="btn btn-primary">Get notified</a>
      </div>
    )}
  </section>
</Layout>

<style>
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .blog-card {
    text-decoration: none;
    transition: transform 0.3s var(--ease-spring), box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-lg);
  }
  .blog-date {
    font-size: 13px;
    color: var(--color-body-text);
    margin-bottom: 12px;
  }
  .blog-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 20px;
    color: var(--color-text-dark);
    margin-bottom: 12px;
    line-height: 1.3;
  }
  .blog-excerpt {
    font-size: 15px;
    color: var(--color-body-text);
    line-height: 1.6;
    flex: 1;
  }
  .blog-read-more {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 16px;
  }
  .blog-empty {
    text-align: center;
    padding: 64px 0;
  }
  .blog-empty .section-body {
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 900px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
