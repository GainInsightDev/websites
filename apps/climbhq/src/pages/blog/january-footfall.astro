	            url('/images/stock/behind-the-bloc-5.png') center/cover no-repeat;
	padding: 140px 24px 80px;
	text-align: center;
}
.blog-hero-inner {
	max-width: 720px;
	margin: 0 auto;
}
.blog-category {
	display: inline-block;
	font-family: 'Unbounded', sans-serif;
	font-size: 12px;
	font-weight: 500;
	letter-spacing: 3px;
	text-transform: uppercase;
	color: #18ABD7;
	margin-bottom: 24px;
	padding: 6px 16px;
	border: 1px solid rgba(24, 171, 215, 0.3);
	border-radius: 2px;
}
.blog-hero h1 {
	font-family: 'Unbounded', sans-serif;
	font-size: clamp(28px, 4vw, 42px);
