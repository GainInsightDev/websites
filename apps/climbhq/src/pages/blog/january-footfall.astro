	max-width: 720px;
	margin: 0 auto;
	padding: 48px 24px 80px;
}

/* Lead paragraph */
.blog-lead {
	font-size: 19px;
	line-height: 1.9;
	color: #d0d4dc;
	margin-bottom: 32px;
	padding-bottom: 32px;
	border-bottom: 1px solid rgba(24, 171, 215, 0.15);
}
.blog-lead p {
	margin-bottom: 1em;
}

/* Section headings */
.blog-content section {
	margin-bottom: 48px;
}
.blog-content h2 {
	font-family: 'Unbounded', sans-serif;
	font-size: 24px;
	font-weight: 600;
	color: #18ABD7;
	margin-bottom: 20px;
	padding-bottom: 12px;
	border-bottom: 1px solid rgba(24, 171, 215, 0.2);
}

/* Body text */
.blog-content p {
	font-family: 'Montserrat', sans-serif;
	font-size: 17px;
	line-height: 1.85;
	color: #d0d4dc;
	margin-bottom: 1.3em;
}
.blog-content strong {
	color: #ffffff;
