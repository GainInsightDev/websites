	height: auto;
	border-radius: 8px;
	transition: transform 0.2s ease;
}
.blog-cta img:hover {
	transform: scale(1.02);
}

/* Mobile responsive */
@media (max-width: 768px) {
	.blog-hero {
		padding: 100px 16px 60px;
	}
	.blog-content {
		padding: 32px 16px 60px;
	}
	.blog-pullquote {
		padding: 20px 0 20px 20px;
		margin: 32px 0;
	}
	.blog-insight,
	.blog-coming-next {
