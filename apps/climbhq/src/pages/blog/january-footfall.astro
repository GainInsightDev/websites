}

/* Lists */
.blog-content ul {
	margin: 1em 0 1.5em 0;
	padding: 0;
	list-style: none;
}
.blog-content li {
	font-family: 'Montserrat', sans-serif;
	font-size: 17px;
	line-height: 1.85;
	color: #d0d4dc;
	margin-bottom: 0.5em;
	padding-left: 24px;
	position: relative;
}
.blog-content li::before {
	content: '';
	position: absolute;
	left: 0;
	top: 11px;
	width: 8px;
	height: 8px;
	background: #18ABD7;
	border-radius: 50%;
}
.blog-signal-list li {
	font-size: 18px;
	font-style: italic;
	color: #ffffff;
}
.blog-signal-list li::before {
	background: #FFA269;
}

/* Pull quotes */
.blog-pullquote {
	font-family: 'Unbounded', sans-serif;
	font-size: clamp(20px, 3vw, 26px);
	font-weight: 500;
	color: #18ABD7;
	line-height: 1.5;
	border-left: 4px solid #18ABD7;
	padding: 24px 0 24px 32px;
	margin: 40px 0;
