---
import Layout from '../layouts/Layout.astro';

const packages = [
  {
    name: 'Anchor',
    price: '£500 per month*',
    features: [
      'Bookkeeping management',
      'Expense tracking and income analysis',
      'Monthly pre-built financial reports',
      'Payroll processing',
      'Customer support access',
    ],
  },
  {
    name: 'Ascend',
    price: '£1,000 per month*',
    features: [
      'Everything in Anchor',
      'More in-depth financial reports and KPI Dashboards',
      'Integrated KPI reporting (memberships, attendance stats)',
      'Monthly dedicated Finance Business Partner check-in',
    ],
  },
  {
    name: 'Apex',
    price: '£1,500 per month*',
    features: [
      'Everything in Ascend',
      'Annual financial business planning with forecasts',
      'Bespoke financial reporting and dashboards',
      'Cashflow forecasting',
      'Half-day monthly CFO access for mentoring',
    ],
  },
];

const addons = [
  'Finance raising support',
  'Event preparation assistance (sales/investment)',
  'Acquisition support',
  'Accounting system migration',
];
---

<Layout title="Accounting Services — ClimbHQ" description="Bookkeeping, financial reporting, KPI dashboards, and CFO access for climbing centres.">
  <!-- Banner -->
  <section class="page-banner" style="background-image: url('/images/stock/climbing-man-rear.jpg');">
    <h2>Accounting Services</h2>
    <p>No Jargon, just easy to understand numbers that make sense and allow you to make informed decisions.</p>
  </section>

  <!-- Pricing -->
  <section class="section-navy" style="padding: 80px 48px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div class="pricing-grid">
        {packages.map((pkg) => (
          <div class="pricing-card reveal">
            <h3 class="pricing-name">{pkg.name}</h3>
            <p class="pricing-price">{pkg.price}</p>
            <ul class="pricing-features">
              {pkg.features.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Add-ons -->
  <section class="section" style="text-align: center;">
    <p class="section-label reveal">ADD-ON SERVICES</p>
    <h2 class="section-title reveal">Additional support when you need it</h2>
    <div class="addon-grid">
      {addons.map((addon, i) => (
        <div class={`addon-item reveal reveal-delay-${i + 1}`}>
          <span class="addon-bullet" aria-hidden="true">+</span>
          <span>{addon}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="section-navy" style="padding: 80px 48px; text-align: center;">
    <div class="section">
      <h2 class="section-title reveal" style="color: #FFFFFF;">Ready for clear financial reporting?</h2>
      <p class="section-body reveal" style="margin-left: auto; margin-right: auto;">Let's discuss which accounting package is right for your climbing centre.</p>
      <a href="/contact" class="btn btn-primary reveal">Get in touch</a>
    </div>
  </section>
</Layout>

<style>
  .addon-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-top: 32px;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
    text-align: left;
  }
  .addon-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-btn);
    font-size: 15px;
    color: var(--color-text-dark);
  }
  .addon-bullet {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-accent);
    font-size: 18px;
    flex-shrink: 0;
  }
  @media (max-width: 900px) {
    .addon-grid { grid-template-columns: 1fr; }
  }
</style>
