---
import Layout from '../layouts/Layout.astro';

const team = [
  { name: 'Rob', role: 'Chief Executive Officer', image: '/images/team/rob.png' },
  { name: 'Dave Swis', role: 'Chief Marketing Officer', image: '/images/team/dave.png' },
  { name: 'Jez', role: 'Chief Commercial & Climbing Officer', image: '/images/team/jez.png' },
  { name: 'Andy', role: 'Board Advisor / Founder', image: '' },
  { name: 'Andy Mellor', role: 'Chief Financial Officer', image: '' },
  { name: 'Sam Beeny', role: 'Marketing Manager', image: '' },
];

const faqs = [
  { q: '1. What does ClimbHQ do?', a: 'ClimbHQ is a specialised service provider offering Marketing, HR, and Finance & Data services specifically designed for indoor climbing walls, bouldering gyms, and clip & climb centres in the UK. We help climbing businesses optimise their operations, attract more customers, and increase profitability through our industry-specific expertise.' },
  { q: '2. Do you only work with climbing centres?', a: 'Yes — we exclusively serve indoor climbing centres, bouldering gyms, and clip & climb facilities across the UK. This laser focus means we understand your specific challenges better than a generic agency ever could.' },
  { q: '3. How can ClimbHQ help my climbing centre attract more customers?', a: 'We use a combination of digital marketing strategies including social media management, SEO optimisation, PPC advertising, email campaigns, and content marketing — all tailored specifically for the climbing sector.' },
  { q: '4. What makes ClimbHQ different from marketing agencies?', a: "We're like having an in-house team rather than an outside agency. Our entire team has deep climbing industry experience and our services are purpose-built for the sector." },
  { q: '5. Do you offer one-time services or only ongoing packages?', a: 'Both. We offer ongoing monthly packages for sustained growth, as well as one-time project-based services. Results typically become visible within 1 to 6 months depending on the service.' },
  { q: '6. Can you help promote NICAS courses at my centre?', a: 'Absolutely! We have specific experience promoting National Indoor Climbing Award Schemes (NICAS) courses. Our approach includes targeted marketing to schools and parents, highlighting the developmental benefits for children.' },
  { q: '7. How do you measure success?', a: 'We provide regular reporting on key metrics including website traffic, social media engagement, lead generation, membership growth, and ROI on marketing spend.' },
  { q: '8. How much do your services cost?', a: 'Our packages are designed to be cost-effective. Marketing starts from £499/month, Accounting from £500/month, and HR from £249/month. Custom packages are available.' },
  { q: '9. How long does it take to see results?', a: 'Results vary by service. Some improvements like social media engagement can be seen within weeks, while SEO and broader marketing campaigns typically show results within 1-6 months.' },
  { q: '10. How do we get started?', a: 'Simply get in touch via our contact page or email hello@climbhq.co.uk. We\'ll arrange a discovery call to understand your needs and recommend the right package.' },
];
---

<Layout title="About — ClimbHQ" description="Learn about ClimbHQ and the team behind the UK's leading climbing centre support services.">
  <!-- Banner -->
  <section class="page-banner" style="background-image: url('/images/stock/climbing-man-fit.jpg');">
    <h2>About</h2>
  </section>

  <!-- About content -->
  <section class="section">
    <div class="about-grid">
      <div class="about-image reveal">
        <img src="/images/stock/climbing-man-fit.jpg" alt="Climber on indoor wall" width="500" height="400" loading="lazy" style="width:100%;height:auto;border-radius:var(--radius-card);object-fit:cover;" />
      </div>
      <div class="about-text reveal reveal-delay-1">
        <p class="section-label">READY TO CLIMB?</p>
        <h2 class="section-title">Scaling to new heights</h2>
        <p style="color: #666; line-height: 1.7; margin-bottom: 16px;">ClimbHQ is a commercial services partner dedicated to helping climbing centres grow. We combine industry expertise with digital marketing strategies, innovative and commercial HR support and dedicated finance and data professionals. We are able to support you with cost effective packages and tailored solutions.</p>
        <p style="color: #666; line-height: 1.7; margin-bottom: 24px;">As proud NICAS partners, we understand the unique needs of climbing walls, bouldering gyms and clip &amp; climb centres. Our goal is to support your growth and ensure you have your 'head office' functions covered.</p>
        <a href="/contact" class="btn btn-primary">Get in touch</a>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="section" style="text-align: center; border-top: 1px solid var(--color-border-light);">
    <p class="section-label reveal">LET'S GET ACQUAINTED</p>
    <h2 class="section-title reveal">Meet the team</h2>
    <div class="team-grid">
      {team.map((member, i) => (
        <div class={`team-card reveal reveal-delay-${(i % 3) + 1}`}>
          <div class="team-photo" style={member.image ? `background-image:url(${member.image})` : ''}></div>
          <h3 class="team-name">{member.name}</h3>
          <p class="team-role">{member.role}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Marketing CTA -->
  <section class="section-navy" style="padding: 80px 48px;">
    <div class="section" style="max-width: 700px;">
      <p class="section-label reveal">GET MORE CUSTOMERS</p>
      <h2 class="section-title reveal" style="color: #FFFFFF;">Pump up your centre's marketing adrenaline</h2>
      <p class="section-body reveal">Take your climbing centre's marketing to the next level with proven strategies that attract more climbers, boost engagement, and grow your community.</p>
      <a href="/contact" class="btn btn-primary reveal">Get Started</a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="text-align: center;">
    <p class="section-label reveal">FAQ'S</p>
    <h2 class="section-title reveal">Common Questions</h2>
    <div class="faq-grid">
      <div class="faq-col">
        {faqs.slice(0, 5).map((faq, i) => (
          <details class={`faq-item reveal reveal-delay-${(i % 3) + 1}`}>
            <summary class="faq-question">{faq.q}</summary>
            <p class="faq-answer">{faq.a}</p>
          </details>
        ))}
      </div>
      <div class="faq-col">
        {faqs.slice(5).map((faq, i) => (
          <details class={`faq-item reveal reveal-delay-${(i % 3) + 1}`}>
            <summary class="faq-question">{faq.q}</summary>
            <p class="faq-answer">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 48px;
  }
  .team-card { text-align: center; }
  .team-photo {
    width: 100%;
    aspect-ratio: 1;
    border-radius: var(--radius-card);
    background: #eee;
    background-size: cover;
    background-position: center;
    margin-bottom: 16px;
  }
  .team-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    color: var(--color-text-dark);
    margin-bottom: 4px;
  }
  .team-role {
    font-size: 14px;
    color: var(--color-accent);
    font-weight: 600;
  }
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 32px;
    text-align: left;
  }
  .faq-item {
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-btn);
    overflow: hidden;
  }
  .faq-question {
    padding: 16px 20px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    color: var(--color-accent);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .faq-question::after {
    content: '›';
    font-size: 20px;
    transition: transform 0.2s ease;
  }
  details[open] .faq-question::after {
    transform: rotate(90deg);
  }
  .faq-answer {
    padding: 0 20px 16px;
    font-size: 14px;
    color: #666;
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .about-grid { grid-template-columns: 1fr; }
    .team-grid { grid-template-columns: repeat(2, 1fr); }
    .faq-grid { grid-template-columns: 1fr; }
  }
</style>
