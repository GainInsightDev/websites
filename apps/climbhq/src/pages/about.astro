---
import Layout from '../layouts/Layout.astro';

const team = [
  { name: 'Rob', title: 'Chief Executive Officer', image: '/images/icons/about-2.png', bio: 'Rob has over 20 years experience in senior commercial and People leadership roles. He has a passion for innovation and developing both businesses and the people that make them great.' },
  { name: 'Dave Swis', title: 'Chief Marketing Officer', image: '/images/team/dave.webp', bio: 'Dave is a commercial CMO with a strong background in leisure operations and marketing. With deep experience across the leisure sector, he specialises in growing memberships, delivering great customer experiences, and boosting retention.' },
  { name: 'Jez', title: 'Chief Commercial & Climbing Officer', image: '/images/team/jez.webp', bio: 'A passionate advocate for industry growth, Jez holds board and advisory roles, shaping governance, commercial growth, safeguarding, and best practices to ensure a thriving future for climbing businesses.' },
  { name: 'Andy', title: 'Board Advisor', image: '/images/icons/about-1.png', bio: "Andy is a seasoned entrepreneur. With a background in finance, data analysis and growing start-ups into great businesses. Andy's passion is scaling businesses and the role that data analytics can play in it." },
  { name: 'Andy Mellor', title: 'Chief Financial Officer', image: '/images/team/andy.webp', bio: 'Andy Mellor is a commercial CFO with a strong background in strategic financial management, performance improvement, and M&A. With significant expertise in the leisure sector, Andy specialises in helping growing businesses thrive.' },
  { name: 'Sam Beeny', title: 'Marketing Manager', image: '/images/team/rob-new.png', bio: 'Sam Beeny is a Marketing Manager, with a background in brand strategy, content, and campaign delivery. Sam supports businesses in turning discovery moments into check-ins through clear, consistent marketing.' },
];
---

<Layout title="About - ClimbHQ" description="Meet the ClimbHQ team - specialist partners for indoor climbing centres providing marketing, HR and finance support to help you grow." bodyClass="page-about">

<section class="about-hero">
  <div class="about-hero-inner">
    <h1>About</h1>
  </div>
</section>

<section class="about-intro">
  <div class="about-intro-inner">
    <p class="about-subtitle">Ready to Climb?</p>
    <h2>Scaling to new heights</h2>
    <p>ClimbHQ is a commercial services partner dedicated to helping climbing centres grow. We combine industry expertise with digital marketing strategies, innovative and commercial HR support and dedicated finance and data professionals. We are able to support you with cost effective packages and tailored solutions.</p>
    <p>As proud NICAS partners, we understand the unique needs of climbing walls, bouldering gyms and clip &amp; climb centres. Our goal is to support your growth and ensure you have your 'head office' functions covered.</p>
    <a href="/contact" class="about-cta-btn">Get in touch</a>
  </div>
</section>

<section class="about-team">
  <div class="about-team-header">
    <p class="about-subtitle">Let's get acquainted</p>
    <h2>Meet the team</h2>
  </div>

  <div class="team-grid">
    {team.map((member) => (
      <div class="team-card">
        <div class="team-card-image">
          <img src={member.image} alt={member.name} width="400" height="400" loading="lazy" decoding="async" />
          <div class="team-card-overlay">
            <p class="team-card-bio">{member.bio}</p>
          </div>
        </div>
        <h3>{member.name}</h3>
        <p class="team-card-title">{member.title}</p>
      </div>
    ))}
  </div>
</section>

</Layout>

<style is:global>
/* About hero */
.about-hero {
  background: linear-gradient(200deg, #071F33 20%, rgba(47, 36, 27, 0.78) 80%),
    url('/images/bg/athletes-climbing-on-bouldering-wall.jpg') center/cover no-repeat;
  padding: 200px 24px 170px;
  text-align: center;
  margin-bottom: -4.5%;
  position: relative;
  z-index: 1;
}
.about-hero h1 {
  font-family: 'Unbounded', sans-serif;
  font-size: clamp(36px, 5vw, 60px);
  font-weight: 700;
  color: #ffffff;
  margin: 0;
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
}

/* Intro section */
.about-intro {
  background: url('/images/bg/shape-8.png') top center / contain no-repeat,
    #03071F;
  padding: 80px 24px 60px;
  position: relative;
  z-index: 2;
}
.about-intro-inner {
  max-width: 800px;
  margin: 0 auto;
}
.about-subtitle {
  font-family: 'Montserrat', sans-serif;
  font-size: 14px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 3px;
  color: #5ED4F5;
  margin-bottom: 8px;
}
.about-intro h2 {
  font-family: 'Unbounded', sans-serif !important;
  font-size: clamp(28px, 4vw, 40px) !important;
  font-weight: 700 !important;
  color: #ffffff !important;
  margin: 0 0 24px;
}
.about-intro p {
  font-family: 'Montserrat', sans-serif;
  font-size: 15px;
  line-height: 1.8;
  color: #9796A3;
  margin-bottom: 16px;
}
.about-cta-btn {
  display: inline-block;
  padding: 14px 32px;
  border: 2px solid #5ED4F5;
  border-radius: 4px;
  color: #5ED4F5;
  font-family: 'Unbounded', sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  text-decoration: none;
  margin-top: 16px;
  transition: background 0.2s ease, color 0.2s ease;
}
.about-cta-btn:hover {
  background: #5ED4F5;
  color: #03071F;
}

/* Team section */
.about-team {
  background: #03071F;
  padding: 60px 24px 80px;
}
.about-team-header {
  text-align: center;
  margin-bottom: 48px;
}
.about-team-header h2 {
  font-family: 'Unbounded', sans-serif !important;
  font-size: clamp(28px, 4vw, 40px) !important;
  font-weight: 700 !important;
  color: #ffffff !important;
  margin: 0;
}
.team-grid {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}
.team-card {
  text-align: center;
}
.team-card-image {
  position: relative;
  border-radius: 12px;
  overflow: hidden;
  aspect-ratio: 1;
  margin-bottom: 16px;
}
.team-card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}
.team-card-overlay {
  position: absolute;
  inset: 0;
  background: rgba(3, 7, 31, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
  opacity: 0;
  transition: opacity 0.3s ease;
}
.team-card:hover .team-card-overlay {
  opacity: 1;
}
.team-card-bio {
  font-family: 'Montserrat', sans-serif;
  font-size: 13px;
  line-height: 1.7;
  color: #eef0f4;
  text-align: center;
  margin: 0;
}
.team-card h3 {
  font-family: 'Unbounded', sans-serif;
  font-size: 18px;
  font-weight: 600;
  color: #ffffff;
  margin: 0 0 4px;
}
.team-card-title {
  font-family: 'Montserrat', sans-serif;
  font-size: 13px;
  color: #5ED4F5;
  margin: 0;
}

/* Mobile */
@media (max-width: 768px) {
  .about-hero {
    padding: 140px 24px 100px;
  }
  .team-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
}
@media (max-width: 480px) {
  .team-grid {
    grid-template-columns: 1fr;
    max-width: 300px;
  }
}
</style>
