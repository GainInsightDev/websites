# Amplify Gen 2 Build Configuration
# Template for GainInsight Standard projects
#
# This configuration works with:
# - Next.js 15 with SSR (WEB_COMPUTE platform)
# - npm package manager with package-lock.json
# - Amplify Gen 2 backend

version: 1
backend:
  phases:
    build:
      commands:
        - nvm use 20
        - npm install
        - npx ampx pipeline-deploy --branch $AWS_BRANCH --app-id $AWS_APP_ID
frontend:
  phases:
    build:
      commands:
        - nvm use 20
        - npm install
        - npx ampx generate outputs --branch $AWS_BRANCH --app-id $AWS_APP_ID
        - npm run build
  artifacts:
    baseDirectory: .next
    files:
      - "**/*"
  cache:
    paths:
      - .next/cache/**/*
      - node_modules/**/*
