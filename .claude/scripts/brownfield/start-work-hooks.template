#!/bin/bash
# .start-work-hooks - AgentFlow Brownfield Setup
# Copy this file to your project root as .start-work-hooks
# Auto-executed by start-work when creating/resuming a worktree
#
# This is a minimal template - add project-specific setup below

set -euo pipefail

# Arguments from start-work script
WORKTREE_PATH="$1"
ISSUE_KEY="$2"

# Configuration
AGENTFLOW_PATH="/srv/worktrees/agentflow/main"

cd "$WORKTREE_PATH"

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
