{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/git-commit-reminder.sh"
          }
        ]
      },
      {
        "matcher": "(Edit|Write|Task)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/skill-reminder.sh"
          }
        ]
      },
      {
        "matcher": "mcp__slack__slack_reply_to_thread",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-services-before-slack.sh"
          }
        ]
      },
      {
